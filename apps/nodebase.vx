# ── Layout constants ───────────────────────────────────────────────────────────
NW      = 170     # node width
TH      = 22      # title bar height
PH      = 17      # port row height
PARAMH  = 18      # param row height
PR      = 5       # port circle radius
PAD     = 10      # horizontal padding inside node

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  PLUGIN SYSTEM — Blender-style addons for NodeBase                       ║
# ║  Plugins register new node types at runtime via register_node().         ║
# ║  Drop a .nbgplugin/ folder OR .zip into Vinx-Desktop/plugins/ → loaded.  ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

_PLUGIN_REGISTRY     = {}    # ntype -> executor function (extends _exec)
_PLUGIN_MANIFESTS    = []    # [{name, version, author, ntypes:[...]}, ...]
_PLUGIN_HASHES       = {}    # ntype -> sha256 fingerprint (for protection)

def register_node(ntype, defn, executor):
    """PUBLIC API — plugins call this to add a new node type to NodeBase.

    ntype:    unique type id, e.g., "toon_shader"
    defn:     dict with keys: label, cat, inputs[], outputs[], params[]
              (same structure as built-in DEFS entries)
    executor: function(ex, node, inp, put, p) -> None
              ex   = the running _Executor instance
              node = the node dict
              inp  = function(port_name) -> value resolved from upstream
              put  = function(port_name, value) -> writes to output cache
              p    = node["params"] dict
    """
    if ntype in DEFS:
        # Plugin trying to override built-in node — block silently
        return False
    DEFS[ntype]              = defn
    _PLUGIN_REGISTRY[ntype]  = executor
    return True


def _plugin_dir():
    """Location where plugins live."""
    return os.path.join(os.path.dirname(_GRAPH_DIR), "plugins")


def load_plugins(plugin_dir=None, verbose=True):
    """Scan plugin_dir for plugins and load them. Idempotent."""
    pd = plugin_dir or _plugin_dir()
    os.makedirs(pd, exist_ok=True)
    loaded = []
    for entry in sorted(os.scandir(pd), key=lambda e: e.name):
        if entry.name.startswith("."): continue
        try:
            if entry.is_dir():
                m = _load_plugin_folder(entry.path)
                if m: loaded.append(m)
            elif entry.name.endswith((".zip", ".nbgplugin")):
                m = _load_plugin_zip(entry.path)
                if m: loaded.append(m)
        except Exception as e:
            if verbose:
                print(f"[NodeBase] plugin '{entry.name}' failed: {e}")
    if verbose and loaded:
        print(f"[NodeBase] loaded {len(loaded)} plugin(s): "
              f"{', '.join(m['name'] for m in loaded)}")
    return loaded


def _verify_manifest(manifest):
    """Sanity-check a plugin manifest. Returns (ok, reason)."""
    required = ("name", "version", "author")
    for k in required:
        if k not in manifest:
            return False, f"manifest missing '{k}'"
    if not isinstance(manifest["name"], str) or len(manifest["name"]) > 60:
        return False, "invalid name"
    return True, ""


def _load_plugin_folder(folder):
    """Load an unpacked plugin folder. Returns manifest dict on success."""
    manifest_path = os.path.join(folder, "manifest.json")
    if not os.path.isfile(manifest_path): return None
    manifest = json.load(open(manifest_path, encoding="utf-8"))
    ok, why = _verify_manifest(manifest)
    if not ok:
        print(f"[NodeBase] plugin {folder}: {why}")
        return None

    nodes_py = os.path.join(folder, "nodes.py")
    registered_types = []
    if os.path.isfile(nodes_py):
        # Compute fingerprint BEFORE loading (for protection / change detection)
        import hashlib
        h = hashlib.sha256(open(nodes_py, "rb").read()).hexdigest()[:16]
        from importlib.machinery import SourceFileLoader
        mod_name = f"plugin_{manifest['name'].replace(' ', '_').lower()}"
        mod = SourceFileLoader(mod_name, nodes_py).load_module()
        if hasattr(mod, "register"):
            # Wrap register_node to track what this plugin owns
            def _tracked_register(ntype, defn, executor):
                if register_node(ntype, defn, executor):
                    registered_types.append(ntype)
                    _PLUGIN_HASHES[ntype] = h
                    return True
                return False
            mod.register(_tracked_register)
    manifest["ntypes"]      = registered_types
    manifest["folder"]      = folder
    _PLUGIN_MANIFESTS.append(manifest)
    return manifest


def _load_plugin_zip(zip_path):
    """Extract a .zip / .nbgplugin into a temp folder and load it."""
    import zipfile, tempfile
    tmp = tempfile.mkdtemp(prefix="nbg_plugin_")
    with zipfile.ZipFile(zip_path) as z:
        z.extractall(tmp)
    # If zip has a single top folder, descend into it
    children = [c for c in os.scandir(tmp)
                if not c.name.startswith(".")]
    if len(children) == 1 and children[0].is_dir():
        tmp = children[0].path
    return _load_plugin_folder(tmp)


def get_plugin_info():
    """Public: returns list of loaded plugin manifests."""
    return list(_PLUGIN_MANIFESTS)


# ── Luna software renderer ────────────────────────────────────────────────────
# Pure-Python 3D rasterizer using PIL. Inspired by Cycles/Eevee passes,
# Blender bpy.ops mesh primitives, and Houdini's GEO descriptor pattern.
# No GPU/OpenGL needed — works anywhere PIL works.
#
# Supports three modes (Blender-style):
#   wireframe — just edges
#   shaded    — flat-shaded filled polygons (with basic lights)
#   rendered  — gouraud-like smoother shading with all lights

def _parse_hex(c):
    if not c or not c.startswith("#") or len(c) < 7: return (170, 170, 170)
    return (int(c[1:3], 16), int(c[3:5], 16), int(c[5:7], 16))

def _vec_sub(a, b): return (a[0]-b[0], a[1]-b[1], a[2]-b[2])
def _vec_cross(a, b):
    return (a[1]*b[2] - a[2]*b[1],
            a[2]*b[0] - a[0]*b[2],
            a[0]*b[1] - a[1]*b[0])
def _vec_dot(a, b): return a[0]*b[0] + a[1]*b[1] + a[2]*b[2]
def _vec_norm(v):
    import math
    L = math.sqrt(v[0]*v[0] + v[1]*v[1] + v[2]*v[2]) or 1.0
    return (v[0]/L, v[1]/L, v[2]/L)

def _build_mesh(kind, params, tx, ty, tz):
    """Generate (vertices, faces) for a primitive at offset (tx,ty,tz).
    faces = list of tuples of vertex indices (triangles or quads).
    Each vertex is already translated to its scene position."""
    import math
    verts, faces = [], []
    # ── Imported mesh: vertices/faces already supplied (OBJ, FBX, USD) ──
    if kind == "imported":
        scl = float(params.get("scale", 1.0))
        verts = [(x*scl + tx, y*scl + ty, z*scl + tz)
                 for x, y, z in params.get("_verts", [])]
        faces = list(params.get("_faces", []))
        return verts, faces
    sz = float(params.get("size", params.get("radius", 1.0)))
    if kind == "cube":
        s = sz
        v = [(-s,-s,-s),(s,-s,-s),(s,s,-s),(-s,s,-s),
             (-s,-s, s),(s,-s, s),(s,s, s),(-s,s, s)]
        f = [(0,3,2,1),(4,5,6,7),(0,1,5,4),(2,3,7,6),(1,2,6,5),(0,4,7,3)]
        verts = [(x+tx, y+ty, z+tz) for x,y,z in v]
        faces = f
    elif kind == "plane":
        s = sz
        verts = [(-s+tx, ty, -s+tz),(s+tx, ty, -s+tz),
                 (s+tx, ty, s+tz),(-s+tx, ty, s+tz)]
        faces = [(0,1,2,3)]
    elif kind == "sphere":
        r = sz
        rings = int(params.get("rings", 8))
        segs  = int(params.get("segments", 12))
        for i in range(rings + 1):
            phi = math.pi * i / rings - math.pi / 2
            for j in range(segs):
                th = 2 * math.pi * j / segs
                verts.append((tx + r*math.cos(phi)*math.cos(th),
                              ty + r*math.sin(phi),
                              tz + r*math.cos(phi)*math.sin(th)))
        for i in range(rings):
            for j in range(segs):
                a = i*segs + j
                b = i*segs + (j+1)%segs
                c = (i+1)*segs + (j+1)%segs
                d = (i+1)*segs + j
                faces.append((a, b, c, d))
    elif kind == "torus":
        major = float(params.get("major", 1.0))
        minor = float(params.get("minor", 0.3))
        sub   = int(params.get("_subdiv", 1))   # subdivision multiplier
        rings = 16 * max(1, sub)
        segs  = 12 * max(1, sub)
        for i in range(rings):
            u = 2 * math.pi * i / rings
            for j in range(segs):
                v_ = 2 * math.pi * j / segs
                cx = (major + minor*math.cos(v_)) * math.cos(u)
                cy = minor * math.sin(v_)
                cz = (major + minor*math.cos(v_)) * math.sin(u)
                verts.append((tx + cx, ty + cy, tz + cz))
        for i in range(rings):
            for j in range(segs):
                a = i*segs + j
                b = i*segs + (j+1)%segs
                c = ((i+1)%rings)*segs + (j+1)%segs
                d = ((i+1)%rings)*segs + j
                faces.append((a, b, c, d))
    elif kind in ("cyl", "cylinder"):
        r = sz; h = float(params.get("height", 2.0))
        segs = 16
        # top + bottom rings
        for k, y in ((0, h/2), (segs, -h/2)):
            for j in range(segs):
                th = 2 * math.pi * j / segs
                verts.append((tx + r*math.cos(th), ty + y,
                              tz + r*math.sin(th)))
        for j in range(segs):
            a, b = j, (j+1)%segs
            c, d = segs + (j+1)%segs, segs + j
            faces.append((a, b, c, d))
    elif kind == "cone":
        r = sz; h = float(params.get("height", 2.0)); segs = 16
        apex_idx = 0
        verts.append((tx, ty + h/2, tz))     # apex
        base_start = len(verts)
        for j in range(segs):
            th = 2 * math.pi * j / segs
            verts.append((tx + r*math.cos(th), ty - h/2, tz + r*math.sin(th)))
        for j in range(segs):
            a = base_start + j
            b = base_start + (j+1)%segs
            faces.append((apex_idx, a, b))
    return verts, faces


def _build_mesh_trs(m):
    """Generate verts/faces for a mesh dict with full transform applied
    in standard SRT order: scale-around-origin → rotate-around-origin →
    translate. Each mesh dict carries:
        tx,ty,tz   translation (defaults 0)
        rx,ry,rz   rotation in radians (defaults 0)
        sx,sy,sz   scale (defaults 1)
    Falls back to legacy translation-only behaviour for meshes that
    don't declare rotation/scale, so old graphs keep working."""
    import math
    kind   = m.get("kind", "cube")
    params = m.get("params", {})
    tx, ty, tz = m.get("tx", 0.0), m.get("ty", 0.0), m.get("tz", 0.0)
    rx, ry, rz = m.get("rx", 0.0), m.get("ry", 0.0), m.get("rz", 0.0)
    sx, sy, sz = m.get("sx", 1.0), m.get("sy", 1.0), m.get("sz", 1.0)

    # No rotation/scale → cheap legacy path
    if rx == 0 and ry == 0 and rz == 0 and sx == 1 and sy == 1 and sz == 1:
        return _build_mesh(kind, params, tx, ty, tz)

    # Origin-centred verts (translation = 0)
    verts, faces = _build_mesh(kind, params, 0.0, 0.0, 0.0)
    crx, srx = math.cos(rx), math.sin(rx)
    cry, sry = math.cos(ry), math.sin(ry)
    crz, srz = math.cos(rz), math.sin(rz)
    out = []
    for x, y, z in verts:
        # 1) Scale
        x, y, z = x * sx, y * sy, z * sz
        # 2) Rotate X
        ny, nz = y * crx - z * srx, y * srx + z * crx
        y, z = ny, nz
        # 3) Rotate Y
        nx, nz = x * cry + z * sry, -x * sry + z * cry
        x, z = nx, nz
        # 4) Rotate Z
        nx, ny = x * crz - y * srz, x * srz + y * crz
        x, y = nx, ny
        # 5) Translate
        out.append((x + tx, y + ty, z + tz))
    return out, faces


def _luna_render_scene(executor, scene, params):
    """Render a Luna scene dict to a PIL image. Returns None on failure.
    Supports modes: wireframe, shaded, rendered."""
    if scene is None:
        executor.out("⚠  luna_render needs a scene input", "err")
        return None
    try:
        from PIL import Image, ImageDraw
        import math as _m, random as _rnd
    except ImportError:
        executor.out("❌  PIL not available — pip install Pillow", "err")
        return None

    try:
        rw   = int(float(params.get("w", 640)))
        rh   = int(float(params.get("h", 480)))
        # Scene mode overrides param mode if set (so viewport toggle works)
        mode = scene.get("mode", params.get("mode", "wireframe"))
        bg_color = (8, 10, 22) if mode == "wireframe" else (24, 26, 36)
        img  = Image.new("RGB", (rw, rh), bg_color)
        dr   = ImageDraw.Draw(img)
        # Render from EDIT cam when in edit mode (so user can navigate
        # freely while the named camera stays put as a 3D object).
        if scene.get("camera_mode") == "edit" and "edit_cam" in scene:
            cam = scene["edit_cam"]
        else:
            cam = scene.get("camera", {"x":0,"y":0,"z":-5,"fov":50,
                                       "target_x":0,"target_y":0,"target_z":0})
        fov  = float(cam.get("fov", 50))
        f    = (rh / 2) / _m.tan(_m.radians(fov / 2))
        cx_, cy_ = rw / 2, rh / 2

        # Camera basis vectors for proper view transform
        cam_pos = (cam.get("x", 0), cam.get("y", 0), cam.get("z", -5))
        cam_tgt = (cam.get("target_x", 0), cam.get("target_y", 0),
                   cam.get("target_z", 0))
        forward = _vec_norm(_vec_sub(cam_tgt, cam_pos))
        # Compute right vector (forward × world_up), then up (right × forward)
        world_up = (0, 1, 0)
        right = _vec_norm(_vec_cross(forward, world_up))
        if abs(_vec_dot(right, right)) < 0.001:
            right = (1, 0, 0)   # camera looking straight up/down
        up = _vec_norm(_vec_cross(right, forward))

        def _to_camera(v):
            """World coords → camera coords."""
            d = _vec_sub(v, cam_pos)
            return (_vec_dot(d, right),
                    _vec_dot(d, up),
                    _vec_dot(d, forward))

        def _project_cam(cv):
            """Camera coords → screen + depth. Returns (sx, sy, z)."""
            cz = max(0.01, cv[2])
            return (cx_ + cv[0] * f / cz,
                    cy_ - cv[1] * f / cz,
                    cz)

        def _proj(v):
            """Full world → screen."""
            return _project_cam(_to_camera(v))

        # ── Lights setup ────────────────────────────────────────────────
        lights = scene.get("lights", [])
        light_dirs = []  # normalized "to light" vectors in world space
        light_intensities = []
        for L in lights:
            if L.get("type") == "sun":
                d = (-L["dir_x"], -L["dir_y"], -L["dir_z"])
                light_dirs.append(_vec_norm(d))
                light_intensities.append(L.get("intensity", 1.0))
            elif L.get("type") in ("omni", "point", "spot", "area"):
                light_dirs.append(_vec_norm((L["x"], L["y"], L["z"])))
                light_intensities.append(L.get("intensity", 1.0))
        if not light_dirs:
            light_dirs = [_vec_norm((0.4, 0.8, 0.3))]
            light_intensities = [1.0]

        # ── Floor with grid (rendered first as background) ──────────────
        floors = scene.get("floors", [])
        for floor in floors:
            size = floor.get("size", 10)
            divs = floor.get("divisions", 20)
            y_   = floor.get("y", -1.0)
            col  = _parse_hex(floor.get("color", "#2a3a55"))
            step = (2 * size) / divs
            for i in range(divs + 1):
                t = -size + i * step
                a = _proj((-size, y_, t))
                b = _proj(( size, y_, t))
                if a[2] > 0.05 and b[2] > 0.05:
                    dr.line([a[0], a[1], b[0], b[1]], fill=col, width=1)
                c = _proj((t, y_, -size))
                d_ = _proj((t, y_,  size))
                if c[2] > 0.05 and d_[2] > 0.05:
                    dr.line([c[0], c[1], d_[0], d_[1]], fill=col, width=1)

        # ── Drop shadows — project each mesh's silhouette onto the floor
        # along the direction of the first directional/sun light. Cheap
        # approximation but visually convincing.
        sh_cfg = scene.get("shadows", {"enabled": True, "darkness": 0.45})
        if sh_cfg.get("enabled", True) and floors and mode != "wireframe":
            try:
                from PIL import Image as _Img
                # Find a sun-style light direction for projection
                proj_dir = None
                for L in scene.get("lights", []):
                    if L.get("type") == "sun":
                        proj_dir = (L["dir_x"], L["dir_y"], L["dir_z"])
                        break
                if proj_dir is None:
                    proj_dir = (-0.4, -1.0, -0.3)   # default key light
                pdx, pdy, pdz = proj_dir
                if abs(pdy) < 0.05: pdy = -1.0   # avoid horizontal beams
                # Use the first floor as the receiver
                floor_y = floors[0].get("y", -1.0)
                # Build a translucent shadow layer that we'll blend onto img
                shadow_img = _Img.new("RGBA", (rw, rh), (0, 0, 0, 0))
                shadow_dr  = ImageDraw.Draw(shadow_img)
                dark = int(255 * sh_cfg.get("darkness", 0.45))

                def _drop(x, y, z):
                    """Project world point along proj_dir until y=floor_y."""
                    dy = floor_y - y
                    if abs(pdy) < 1e-6: return (x, floor_y, z)
                    t = dy / pdy
                    return (x + pdx * t, floor_y, z + pdz * t)

                for m in scene.get("meshes", []):
                    kind = m.get("kind", "cube")
                    tx, ty, tz = m.get("tx", 0), m.get("ty", 0), m.get("tz", 0)
                    verts, faces = _build_mesh_trs(m)
                    if not verts: continue
                    # Project all vertices to floor, then take 2D convex hull
                    # in screen space (cheap: just draw projected polygon
                    # for each face — overlapping is fine, alpha caps at one).
                    for fc in faces:
                        if len(fc) < 3: continue
                        pts = []
                        ok = True
                        for vi in fc:
                            wx_, wy_, wz_ = verts[vi]
                            sx_, sy_, dz_ = _proj(_drop(wx_, wy_, wz_))
                            if dz_ < 0.05: ok = False; break
                            pts.append((sx_, sy_))
                        if ok and len(pts) >= 3:
                            shadow_dr.polygon(pts, fill=(0, 0, 0, dark))
                # Composite the shadow layer onto the main image
                img = img.convert("RGBA")
                img.alpha_composite(shadow_img)
                img = img.convert("RGB")
                dr  = ImageDraw.Draw(img)
            except Exception:
                pass

        # ── Render meshes ───────────────────────────────────────────────
        if mode == "wireframe":
            # Wireframe stays per-mesh (no occlusion needed)
            for m in scene.get("meshes", []):
                kind = m.get("kind", "cube")
                tx, ty, tz = m.get("tx", 0), m.get("ty", 0), m.get("tz", 0)
                mat = m.get("material", {})
                base = _parse_hex(mat.get("color", "#aaccee"))
                verts, faces = _build_mesh_trs(m)
                edges = set()
                for fc in faces:
                    n = len(fc)
                    for i in range(n):
                        a, b = fc[i], fc[(i+1) % n]
                        edges.add((min(a,b), max(a,b)))
                pts = [_proj(v) for v in verts]
                for a, b in edges:
                    if pts[a][2] > 0.05 and pts[b][2] > 0.05:
                        dr.line([pts[a][0], pts[a][1], pts[b][0], pts[b][1]],
                                fill=base, width=1)
        else:
            # ── Pre-bake all-mesh triangle geometry for inter-object
            #    shadow ray casting. Done once per render, not per face.
            #    Quads are split into two triangles for Möller-Trumbore.
            ray_shadows_on = (
                scene.get("ray_shadows", True) is not False
                and scene.get("ray_shadows", True) != "off"
                and mode != "wireframe")
            shadow_tris   = []   # [(mesh_idx, v0, v1, v2), ...]
            mesh_bboxes   = []   # [(mesh_idx, (minx,miny,minz),(maxx,maxy,maxz))]
            if ray_shadows_on:
                for mi_p, mp in enumerate(scene.get("meshes", [])):
                    vp, fp = _build_mesh_trs(mp)
                    if not vp: continue
                    minp = [ 1e9,  1e9,  1e9]
                    maxp = [-1e9, -1e9, -1e9]
                    for v in vp:
                        if v[0] < minp[0]: minp[0] = v[0]
                        if v[1] < minp[1]: minp[1] = v[1]
                        if v[2] < minp[2]: minp[2] = v[2]
                        if v[0] > maxp[0]: maxp[0] = v[0]
                        if v[1] > maxp[1]: maxp[1] = v[1]
                        if v[2] > maxp[2]: maxp[2] = v[2]
                    mesh_bboxes.append((mi_p, tuple(minp), tuple(maxp)))
                    for fcp in fp:
                        if len(fcp) < 3: continue
                        for ti in range(1, len(fcp) - 1):
                            shadow_tris.append((mi_p,
                                                vp[fcp[0]],
                                                vp[fcp[ti]],
                                                vp[fcp[ti+1]]))

            def _ray_tri_hit(o, d, v0, v1, v2):
                """Möller-Trumbore. Returns t > 1e-4 on hit, else None."""
                e1x = v1[0]-v0[0]; e1y = v1[1]-v0[1]; e1z = v1[2]-v0[2]
                e2x = v2[0]-v0[0]; e2y = v2[1]-v0[1]; e2z = v2[2]-v0[2]
                px_ = d[1]*e2z - d[2]*e2y
                py_ = d[2]*e2x - d[0]*e2z
                pz_ = d[0]*e2y - d[1]*e2x
                a = e1x*px_ + e1y*py_ + e1z*pz_
                if -1e-8 < a < 1e-8: return None
                inv = 1.0 / a
                sx_ = o[0]-v0[0]; sy_ = o[1]-v0[1]; sz_ = o[2]-v0[2]
                u = inv * (sx_*px_ + sy_*py_ + sz_*pz_)
                if u < 0.0 or u > 1.0: return None
                qx_ = sy_*e1z - sz_*e1y
                qy_ = sz_*e1x - sx_*e1z
                qz_ = sx_*e1y - sy_*e1x
                v = inv * (d[0]*qx_ + d[1]*qy_ + d[2]*qz_)
                if v < 0.0 or u + v > 1.0: return None
                t = inv * (e2x*qx_ + e2y*qy_ + e2z*qz_)
                return t if t > 1e-4 else None

            def _aabb_hit(o, d, mn, mx):
                """Slab test — does ray hit AABB at any positive t?"""
                tmin, tmax = -1e9, 1e9
                for k in range(3):
                    if abs(d[k]) < 1e-9:
                        if o[k] < mn[k] or o[k] > mx[k]: return False
                    else:
                        t1 = (mn[k]-o[k]) / d[k]
                        t2 = (mx[k]-o[k]) / d[k]
                        if t1 > t2: t1, t2 = t2, t1
                        if t1 > tmin: tmin = t1
                        if t2 < tmax: tmax = t2
                        if tmin > tmax: return False
                return tmax > 0.0

            # ── GLOBAL face collection across ALL meshes ──────────────────
            sel_idx = scene.get("selected_mesh", -1)
            all_faces = []
            for mi, m in enumerate(scene.get("meshes", [])):
                kind = m.get("kind", "cube")
                tx, ty, tz = m.get("tx", 0), m.get("ty", 0), m.get("tz", 0)
                mat = m.get("material", {})
                base = _parse_hex(mat.get("color", "#aaccee"))
                verts, faces = _build_mesh_trs(m)
                is_selected = (mi == sel_idx)
                for fc in faces:
                    if len(fc) < 3: continue
                    v0, v1, v2 = verts[fc[0]], verts[fc[1]], verts[fc[2]]
                    n = _vec_norm(_vec_cross(_vec_sub(v1, v0),
                                             _vec_sub(v2, v0)))
                    face_ctr = ((v0[0]+v1[0]+v2[0])/3,
                                (v0[1]+v1[1]+v2[1])/3,
                                (v0[2]+v1[2]+v2[2])/3)
                    view_dir = _vec_norm(_vec_sub(cam_pos, face_ctr))
                    if _vec_dot(n, view_dir) < 0: continue
                    # Shadow-aware lighting: cast a ray from this face's
                    # centre (lifted slightly along the normal so we don't
                    # self-intersect) toward each light. If another mesh's
                    # triangles block the ray, that light is occluded.
                    shadow_origin = (face_ctr[0] + n[0]*0.002,
                                     face_ctr[1] + n[1]*0.002,
                                     face_ctr[2] + n[2]*0.002)
                    diffuse = 0.0
                    for ld, li in zip(light_dirs, light_intensities):
                        nd = max(0, _vec_dot(n, ld))
                        if nd <= 0: continue
                        blocked = False
                        if ray_shadows_on and shadow_tris:
                            for (mi_p, mn_, mx_) in mesh_bboxes:
                                if mi_p == mi: continue
                                if not _aabb_hit(shadow_origin, ld, mn_, mx_):
                                    continue
                                # Walk this mesh's tris
                                for (mi_t, ta, tb, tc) in shadow_tris:
                                    if mi_t != mi_p: continue
                                    h = _ray_tri_hit(shadow_origin, ld,
                                                      ta, tb, tc)
                                    if h is not None:
                                        blocked = True; break
                                if blocked: break
                        if not blocked:
                            diffuse += nd * 0.6 * li
                    ambient = 0.25
                    fac = min(1.0, ambient + diffuse)
                    col = (int(base[0] * fac),
                           int(base[1] * fac),
                           int(base[2] * fac))
                    poly_pts, ok = [], True
                    depths = []
                    for vi in fc:
                        sx, sy, dz = _proj(verts[vi])
                        if dz < 0.05: ok = False; break
                        poly_pts.append((sx, sy)); depths.append(dz)
                    if not ok: continue
                    # Sort key: MAX depth of any vertex on this face. Avg
                    # depth caused overlapping cubes/torus to draw out of
                    # order — a face whose mean was small could still
                    # have parts further back than another face's whole
                    # extent. Sorting by MAX gives reliable back-to-front
                    # order for convex / non-intersecting meshes.
                    sort_depth = max(depths)
                    all_faces.append((sort_depth, poly_pts, col, is_selected))

            all_faces.sort(key=lambda r: -r[0])
            for depth, poly, col, sel in all_faces:
                if sel:
                    # Selected mesh: bright yellow outline + slight tint
                    tint = (min(255, col[0] + 40),
                            min(255, col[1] + 30),
                            min(255, col[2] + 10))
                    dr.polygon(poly, fill=tint, outline=(255, 220, 50))
                elif mode == "rendered":
                    outline = (int(col[0]*0.6), int(col[1]*0.6), int(col[2]*0.6))
                    dr.polygon(poly, fill=col, outline=outline)
                else:
                    dr.polygon(poly, fill=col)

        # ── Camera wireframe (only visible when in EDIT mode) ───────────
        # Draws the user's named camera as a small wireframe pyramid at
        # its world position so it can be selected + transformed.
        if scene.get("camera_mode") == "edit":
            uc = scene.get("camera", {})
            ucp = (uc.get("x", 0), uc.get("y", 0), uc.get("z", -5))
            uct = (uc.get("target_x", 0), uc.get("target_y", 0),
                   uc.get("target_z", 0))
            is_cam_sel = scene.get("selected_camera", False)
            ccol = (255, 220, 50) if is_cam_sel else (200, 200, 220)
            # 4 corners of a small frustum in front of the camera
            cam_fwd = _vec_norm(_vec_sub(uct, ucp))
            cam_rt  = _vec_norm(_vec_cross(cam_fwd, (0, 1, 0)))
            if abs(_vec_dot(cam_rt, cam_rt)) < 0.001: cam_rt = (1, 0, 0)
            cam_up  = _vec_norm(_vec_cross(cam_rt, cam_fwd))
            fs = 0.6   # frustum scale
            corners = [
                (ucp[0]+cam_fwd[0]*1.0+(cam_rt[0]+cam_up[0])*fs,
                 ucp[1]+cam_fwd[1]*1.0+(cam_rt[1]+cam_up[1])*fs,
                 ucp[2]+cam_fwd[2]*1.0+(cam_rt[2]+cam_up[2])*fs),
                (ucp[0]+cam_fwd[0]*1.0+(-cam_rt[0]+cam_up[0])*fs,
                 ucp[1]+cam_fwd[1]*1.0+(-cam_rt[1]+cam_up[1])*fs,
                 ucp[2]+cam_fwd[2]*1.0+(-cam_rt[2]+cam_up[2])*fs),
                (ucp[0]+cam_fwd[0]*1.0+(-cam_rt[0]-cam_up[0])*fs,
                 ucp[1]+cam_fwd[1]*1.0+(-cam_rt[1]-cam_up[1])*fs,
                 ucp[2]+cam_fwd[2]*1.0+(-cam_rt[2]-cam_up[2])*fs),
                (ucp[0]+cam_fwd[0]*1.0+(cam_rt[0]-cam_up[0])*fs,
                 ucp[1]+cam_fwd[1]*1.0+(cam_rt[1]-cam_up[1])*fs,
                 ucp[2]+cam_fwd[2]*1.0+(cam_rt[2]-cam_up[2])*fs),
            ]
            apex = _proj(ucp)
            corners_2d = [_proj(c) for c in corners]
            if apex[2] > 0.05:
                # Pyramid: apex to each corner
                for c2d in corners_2d:
                    if c2d[2] > 0.05:
                        dr.line([apex[0], apex[1], c2d[0], c2d[1]],
                                fill=ccol, width=2 if is_cam_sel else 1)
                # Frustum rectangle
                for i in range(4):
                    a = corners_2d[i]; b = corners_2d[(i+1)%4]
                    if a[2] > 0.05 and b[2] > 0.05:
                        dr.line([a[0], a[1], b[0], b[1]],
                                fill=ccol, width=2 if is_cam_sel else 1)
                # CAM label
                dr.text((apex[0]+8, apex[1]-12), "CAM", fill=ccol)

        # ── UNIFIED TRANSFORM GIZMO — works for mesh, light, OR camera ─
        sel_target = None
        sel_world  = None
        sel_kind   = None
        sm_idx = scene.get("selected_mesh", -1)
        sl_idx = scene.get("selected_light", -1)
        sc_sel = scene.get("selected_camera", False)
        if sc_sel and scene.get("camera_mode") == "edit":
            cm = scene.get("camera", {})
            sel_target = cm
            sel_kind   = "camera"
            sel_world  = (cm.get("x", 0), cm.get("y", 0), cm.get("z", -5))
        elif 0 <= sm_idx < len(scene.get("meshes", [])):
            m = scene["meshes"][sm_idx]
            sel_target = m
            sel_kind   = "mesh"
            sel_world  = (m.get("tx", 0), m.get("ty", 0), m.get("tz", 0))
        elif 0 <= sl_idx < len(scene.get("lights", [])):
            L = scene["lights"][sl_idx]
            if L.get("type") != "sun":   # sun has no position, only direction
                sel_target = L
                sel_kind   = "light"
                sel_world  = (L.get("x", 0), L.get("y", 0), L.get("z", 0))

        if sel_world is not None:
            gsz  = float(scene.get("light_handle_size", 0.3)) * 4
            gmode = scene.get("gizmo_mode", "translate")
            sx0, sy0, dz0 = _proj(sel_world)
            ex,  ey,  _   = _proj((sel_world[0]+gsz, sel_world[1],      sel_world[2]))
            ey2, ey_y, _  = _proj((sel_world[0],      sel_world[1]+gsz, sel_world[2]))
            ez,  ez_y, _  = _proj((sel_world[0],      sel_world[1],     sel_world[2]+gsz))
            COL_X = (255, 80,  80)
            COL_Y = (80,  255, 80)
            COL_Z = (80,  140, 255)
            COL_W = (220, 220, 220)
            if dz0 > 0.05:
                if gmode == "translate":
                    # ── Arrow heads (lines + sphere tips) ─────────────────
                    for (tx_, ty_), col in ((( ex,  ey), COL_X),
                                            ((ey2, ey_y), COL_Y),
                                            (( ez, ez_y), COL_Z)):
                        dr.line([sx0, sy0, tx_, ty_], fill=col, width=3)
                        dr.ellipse([tx_-7, ty_-7, tx_+7, ty_+7],
                                   fill=col, outline=(255,255,255), width=1)
                    dr.text((ex+10,  ey-7),   "X", fill=(255,140,140), font=None)
                    dr.text((ey2+10, ey_y-7), "Y", fill=(140,255,140), font=None)
                    dr.text((ez+10,  ez_y-7), "Z", fill=(140,170,255), font=None)

                elif gmode == "rotate":
                    # ── Projected rotation rings (16-segment poly) ─────────
                    import math as _gm
                    segs = 32
                    for plane, col in (("y", COL_Y), ("x", COL_X), ("z", COL_Z)):
                        pts = []
                        for i in range(segs + 1):
                            t = 2 * _gm.pi * i / segs
                            if plane == "y":
                                wp = (sel_world[0] + gsz*_gm.cos(t),
                                      sel_world[1],
                                      sel_world[2] + gsz*_gm.sin(t))
                            elif plane == "x":
                                wp = (sel_world[0],
                                      sel_world[1] + gsz*_gm.cos(t),
                                      sel_world[2] + gsz*_gm.sin(t))
                            else:
                                wp = (sel_world[0] + gsz*_gm.cos(t),
                                      sel_world[1] + gsz*_gm.sin(t),
                                      sel_world[2])
                            sx_, sy_, sz_ = _proj(wp)
                            if sz_ > 0.05:
                                pts.append((sx_, sy_))
                        if len(pts) >= 2:
                            for pi2 in range(len(pts)-1):
                                dr.line([pts[pi2][0], pts[pi2][1],
                                         pts[pi2+1][0], pts[pi2+1][1]],
                                        fill=col, width=3)
                    # White outer ring (view-aligned) — drawn as circle in screen space
                    ring_r = int(((ex-sx0)**2+(ey-sy0)**2)**0.5 * 1.25)
                    dr.ellipse([sx0-ring_r, sy0-ring_r, sx0+ring_r, sy0+ring_r],
                               outline=COL_W, width=2)
                    # Axis labels at ring edges
                    dr.text((sx0+ring_r+4, sy0-8), "Y", fill=(140,255,140))
                    dr.text((sx0-8, sy0-ring_r-14), "X", fill=(255,140,140))
                    dr.text((sx0+8, sy0-ring_r-14), "Z", fill=(140,170,255))
                    # Store ring endpoints for hit-test (reuse x/y/z ends as ring edge points)
                    ex, ey   = sx0+ring_r, sy0        # X-ring right edge
                    ey2,ey_y = sx0, sy0-ring_r        # Y-ring top edge
                    ez, ez_y = sx0-ring_r, sy0        # Z-ring left edge

                elif gmode == "scale":
                    # ── Scale handles (lines + cube tips) ─────────────────
                    for (tx_, ty_), col in ((( ex,  ey), COL_X),
                                            ((ey2, ey_y), COL_Y),
                                            (( ez, ez_y), COL_Z)):
                        dr.line([sx0, sy0, tx_, ty_], fill=col, width=3)
                        # Square cube tip
                        dr.rectangle([tx_-6, ty_-6, tx_+6, ty_+6],
                                     fill=col, outline=(255,255,255))
                    # Center white cube
                    dr.rectangle([sx0-5, sy0-5, sx0+5, sy0+5],
                                 fill=(200,200,200), outline=(255,255,255))
                    dr.text((ex+10,  ey-7),   "X", fill=(255,140,140))
                    dr.text((ey2+10, ey_y-7), "Y", fill=(140,255,140))
                    dr.text((ez+10,  ez_y-7), "Z", fill=(140,170,255))

                scene["_gizmo"] = {
                    "origin":  (sx0, sy0),
                    "x_end":   (ex,  ey),
                    "y_end":   (ey2, ey_y),
                    "z_end":   (ez,  ez_y),
                    "world":   sel_world,
                    "kind":    sel_kind,
                    "target":  sel_target,
                    "size":    gsz,
                    "mode":    gmode,
                }
            else:
                scene.pop("_gizmo", None)
        else:
            scene.pop("_gizmo", None)

        # ── Light handles (gizmos showing where lights are in 3D) ───────
        if scene.get("show_light_handles", False):
            hsz = float(scene.get("light_handle_size", 0.3))
            sel_light = scene.get("selected_light", -1)
            for li, L in enumerate(scene.get("lights", [])):
                ltype = L.get("type", "omni")
                lcol  = _parse_hex(L.get("color", "#ffffff"))
                is_sel = (li == sel_light)
                outline = (255, 220, 50) if is_sel else (255, 200, 80)

                if ltype == "sun":
                    # Sun = bright circle at top + arrow showing direction
                    sun_pos = (cam_tgt[0] - L["dir_x"]*4,
                               cam_tgt[1] - L["dir_y"]*4,
                               cam_tgt[2] - L["dir_z"]*4)
                    sx, sy, sz = _proj(sun_pos)
                    if sz > 0.05 and 0 <= sx < rw and 0 <= sy < rh:
                        r_px = max(8, int(20 / sz)) if sz else 12
                        dr.ellipse([sx-r_px, sy-r_px, sx+r_px, sy+r_px],
                                   fill=lcol, outline=outline, width=2)
                        # Direction arrow toward target
                        ex_, ey_, _ = _proj((cam_tgt[0], cam_tgt[1], cam_tgt[2]))
                        dr.line([sx, sy, ex_, ey_],
                                fill=outline, width=1)
                else:
                    # Omni/spot/area = small icon at position
                    sx, sy, sz = _proj((L.get("x", 0), L.get("y", 0),
                                        L.get("z", 0)))
                    if sz > 0.05 and 0 <= sx < rw and 0 <= sy < rh:
                        r_px = max(5, int(10 / sz)) if sz else 6
                        dr.ellipse([sx-r_px, sy-r_px, sx+r_px, sy+r_px],
                                   fill=lcol, outline=outline, width=2)
                        # Cross/glyph indicating light
                        dr.line([sx-r_px-3, sy, sx-r_px+1, sy],
                                fill=outline)
                        dr.line([sx+r_px-1, sy, sx+r_px+3, sy],
                                fill=outline)
                        dr.line([sx, sy-r_px-3, sx, sy-r_px+1],
                                fill=outline)
                        dr.line([sx, sy+r_px-1, sx, sy+r_px+3],
                                fill=outline)
                    # Type label below
                    if sz > 0.05:
                        dr.text((sx-12, sy+r_px+4),
                                ltype.upper(),
                                fill=outline)

        # ── Particles — Atom-style: light, cached, soft splat ───────────────
        # The old code reseeded the RNG for EVERY particle EVERY frame (500x
        # per render) — that was the weight. Here each particle's constants
        # are computed ONCE and cached on the emitter; motion is smooth and
        # time-based; far/tiny particles are culled; the blob is a soft splat.
        _now = time.time()
        for ps in scene.get("particles", []):
            kind = ps.get("kind", "generic")
            cnt  = int(ps.get("count", 0) or 0)
            if cnt <= 0:
                continue
            atom = ps.get("_atom")
            if atom is None or len(atom) != cnt:
                _ar = random.Random(int(ps.get("x", 0) * 131
                                        + ps.get("z", 0) * 17) + cnt)
                atom = [(_ar.random(),                      # phase 0..1
                         (_ar.random() - 0.5) * 0.34,       # x spread
                         (_ar.random() - 0.5) * 0.34,       # z spread
                         0.6 + _ar.random() * 0.8)          # speed jitter
                        for _ in range(cnt)]
                ps["_atom"] = atom
            buoy  = ps.get("buoyancy", 1.0)
            speed = ps.get("speed", 0.45)
            for i in range(cnt):
                phase, ox, oz, sj = atom[i]
                t = (_now * speed * sj + phase) % 1.0       # smooth rise loop
                x = ps["x"] + ox * (0.4 + t)
                y = ps["y"] + t * buoy
                z = ps["z"] + oz * (0.4 + t)
                sx, sy, depth = _proj((x, y, z))
                if depth < 0.05:
                    continue
                if not (0 <= sx < rw and 0 <= sy < rh):
                    continue
                rad = int((3.6 - t * 2.0) / max(depth * 0.4, 0.5))
                if rad < 1:                                 # cull tiny / far
                    continue
                fade = 1.0 - t
                if kind == "fire":
                    r = int(255 * (1 - t*0.55))
                    g = int(190 * (1 - t*0.80))
                    b = int(70  * (1 - t*0.95))
                elif kind == "smoke":
                    v = max(int(175 - t*150), 16); r = g = b = v
                elif kind == "water":
                    r, g, b = int(120*fade), int(185*fade), int(255*fade)
                else:
                    r, g, b = int(210*fade), int(210*fade), int(255*fade)
                # soft splat — dim outer glow + bright core (cheap, no numpy)
                dr.ellipse([sx-rad-2, sy-rad-2, sx+rad+2, sy+rad+2],
                           fill=(r//3, g//3, b//3))
                dr.ellipse([sx-rad, sy-rad, sx+rad, sy+rad], fill=(r, g, b))

        executor.out(f"☾  Luna rendered {rw}x{rh} ({mode})", "sys")
        return img
    except Exception as ex:
        executor.out(f"❌  Luna: {ex}", "err")
        import traceback; traceback.print_exc()
        return None


# ── Execution engine ───────────────────────────────────────────────────────────
class _Executor:
    def __init__(self, nodes, wires, out_fn, glow_fn=None):
        self.nodes    = {n["id"]: n for n in nodes}
        self.wires    = wires
        self.out      = out_fn
        self._glow_fn = glow_fn or (lambda nid: None)
        self._cache   = {}   # (node_id, port_name) → value
        self._vars  = {    # built-in variables
            "desktop_path": ROOT_DIR,
            "home":  os.path.expanduser("~"),
            "os":    sys.platform,
            "time":  time.strftime("%Y-%m-%d %H:%M:%S"),
        }

    def run(self):
        start = next((n for n in self.nodes.values() if n["type"] == "start"), None)
        if not start:
            self.out("❌  No [Start] node found.", "err"); return
        self.out("▶  Running graph...", "sys")
        try:
            self._flow(start["id"], set())
            self.out("■  Done.", "sys")
        except _StopExec:
            self.out("■  Stopped.", "sys")
        except Exception as e:
            self.out(f"❌  Runtime error: {e}", "err")

    def _flow(self, nid, visited):
        if nid in visited: return
        visited.add(nid)
        node = self.nodes.get(nid)
        if not node: return
        self._exec(node)
        # Follow all active flow outputs
        ntype = node["type"]
        for out_port in DEFS[ntype]["outputs"]:
            if out_port["t"] == "flow":
                active = self._cache.get((nid, out_port["n"]), False)
                if active:
                    for w in self.wires:
                        if w["fn"] == nid and w["fp"] == out_port["n"]:
                            self._flow(w["tn"], set(visited))

    def _resolve(self, nid, port):
        key = (nid, port)
        if key in self._cache: return self._cache[key]
        for w in self.wires:
            if w["tn"] == nid and w["tp"] == port:
                src_node = self.nodes.get(w["fn"])
                if src_node:
                    if (w["fn"], w["fp"]) not in self._cache:
                        self._exec(src_node)
                    return self._cache.get((w["fn"], w["fp"]))
        return None

    def _exec(self, node):
        nid   = node["id"]
        ntype = node["type"]
        p     = node.get("params", {})
        cache = self._cache
        self._glow_fn(nid)

        def inp(port): return self._resolve(nid, port)
        def put(port, val): cache[(nid, port)] = val

        try:
            if ntype == "start":
                put("flow", True)

            elif ntype == "end":
                raise _StopExec()

            elif ntype == "sequence":
                put("first", True); put("second", True); put("third", True)

            elif ntype == "val_str":
                v = p.get("value", "")
                for k, bv in self._vars.items():
                    v = v.replace(f"${k}", str(bv))
                put("value", v)

            elif ntype == "val_num":
                put("value", float(p.get("value", 0)))

            elif ntype == "val_bool":
                put("value", p.get("value", "True") == "True")

            elif ntype == "make_list":
                lst = [inp("a"), inp("b"), inp("c")]
                put("list", [x for x in lst if x is not None])

            elif ntype == "math_op":
                a = float(inp("a") or 0); b = float(inp("b") or 0)
                op = p.get("op", "+")
                r = {"+":a+b,"-":a-b,"*":a*b,"/":a/b if b else 0,
                     "%":a%b if b else 0,"**":a**b}.get(op, 0)
                put("result", r)

            elif ntype == "compare":
                a = inp("a"); b = inp("b")
                op = p.get("op", "==")
                try:
                    a2 = float(a) if isinstance(a,str) else a
                    b2 = float(b) if isinstance(b,str) else b
                except: a2,b2 = a,b
                r = {"==":a2==b2,"!=":a2!=b2,">":a2>b2,"<":a2<b2,
                     ">=":a2>=b2,"<=":a2<=b2}.get(op, False)
                put("result", r)

            elif ntype == "clamp":
                v = float(inp("value") or 0)
                mn = float(inp("min") or 0); mx = float(inp("max") or 1)
                put("result", max(mn, min(mx, v)))

            elif ntype == "rand_num":
                import random
                mn = float(p.get("min",0)); mx = float(p.get("max",100))
                put("value", random.uniform(mn, mx)); put("flow", True)

            elif ntype == "concat":
                put("result", str(inp("a") or "") + str(inp("b") or ""))

            elif ntype == "str_op":
                t = str(inp("text") or ""); op = p.get("op","upper")
                ops = {"upper":t.upper(),"lower":t.lower(),"strip":t.strip(),
                       "reverse":t[::-1],"title":t.title()}
                put("result", ops.get(op, t))

            elif ntype == "split":
                t = str(inp("text") or ""); sep = p.get("sep",",")
                put("parts", t.split(sep))

            elif ntype == "fmt":
                tmpl = p.get("template","{a} {b} {c}")
                result = tmpl.replace("{a}", str(inp("a") or "")) \
                             .replace("{b}", str(inp("b") or "")) \
                             .replace("{c}", str(inp("c") or ""))
                put("result", result)

            elif ntype == "print":
                lbl = p.get("label",""); v = inp("value")
                msg = f"{lbl}: {v}" if lbl else str(v)
                self.out(msg, "out"); put("flow", True)

            elif ntype == "file_read":
                path = str(inp("path") or "")
                if os.path.isfile(path):
                    content = open(path, encoding="utf-8", errors="replace").read()
                    put("content", content); put("lines", content.splitlines())
                    self.out(f"📄  Read: {os.path.basename(path)} ({len(content)} chars)", "sys")
                else:
                    self.out(f"❌  File not found: {path}", "err")
                    put("content", ""); put("lines", [])
                put("flow", True)

            elif ntype == "file_write":
                path = str(inp("path") or ""); content = str(inp("content") or "")
                os.makedirs(os.path.dirname(os.path.abspath(path)), exist_ok=True)
                open(path, "w", encoding="utf-8").write(content)
                self.out(f"💾  Wrote: {os.path.basename(path)}", "sys"); put("flow", True)

            elif ntype == "user_input":
                prompt = p.get("prompt", "Enter value:")
                val = simpledialog.askstring("NodeBase Input", prompt) or ""
                put("text", val); put("flow", True)

            elif ntype == "if_node":
                cond = bool(inp("cond"))
                put("true", cond); put("false", not cond)

            elif ntype == "for_each":
                lst = inp("list") or []
                if not isinstance(lst, list): lst = list(lst)
                # Execute loop body for each item
                for i, item in enumerate(lst):
                    cache[(nid, "item")]  = item
                    cache[(nid, "index")] = float(i)
                    cache[(nid, "loop")]  = True
                    # Trigger loop flow immediately
                    for w in self.wires:
                        if w["fn"] == nid and w["fp"] == "loop":
                            self._flow(w["tn"], set())
                put("done", True)

            elif ntype == "set_var":
                self._vars[p.get("name","x")] = inp("value"); put("flow", True)

            elif ntype == "get_var":
                put("value", self._vars.get(p.get("name","x")))

            elif ntype == "delay":
                time.sleep(float(p.get("seconds", 1))); put("flow", True)

            elif ntype == "ai_ask":
                # All AI nodes route through vinx_bridge, which honours
                # whatever brain the user picked in VinX Settings
                # (Local GGUF / API / Chat session). The bridge falls
                # back to the local GGUF when the chosen engine fails,
                # so this node always answers something — never silent.
                try:
                    import vinx_bridge as _vb
                    pr = str(inp("prompt") or "")
                    r = _vb.ask(pr, timeout=60)
                    put("response", r or "[VinX returned empty]")
                except Exception as e:
                    put("response", f"[VinX unavailable: {e}]")
                put("flow", True)

            elif ntype == "ai_summ":
                try:
                    import vinx_bridge as _vb
                    txt = str(inp("text") or "")
                    mw  = int(p.get("max_words", 50))
                    pr  = f"Summarize in max {mw} words:\n{txt}"
                    r = _vb.ask(pr, timeout=60)
                    put("summary", r or "")
                except Exception as e:
                    put("summary", f"[VinX error: {e}]")
                put("flow", True)

            elif ntype == "ai_act":
                # NEW node — let a graph call a registered VinX action
                # (system.brightness.set, files.write, etc.) directly.
                # `name` socket = action name, `args` = JSON string.
                try:
                    import vinx_bridge as _vb
                    nm = str(inp("name") or "")
                    raw = str(inp("args") or "{}")
                    try: args = json.loads(raw) if raw else {}
                    except Exception: args = {}
                    res = _vb.act(nm, args)
                    put("result", json.dumps(res))
                    put("ok", bool(res.get("ok")))
                except Exception as e:
                    put("result", json.dumps(
                        {"ok": False, "error": str(e)}))
                    put("ok", False)
                put("flow", True)

            elif ntype == "run_cmd":
                cmd = str(inp("cmd") or "")
                try:
                    res = subprocess.run(cmd, shell=True, capture_output=True,
                                         text=True, timeout=30)
                    out_txt = res.stdout + res.stderr
                    put("output", out_txt); put("code", float(res.returncode))
                    self.out(out_txt.strip()[:300] or "(no output)", "out")
                except Exception as e:
                    put("output", str(e)); put("code", -1.0)
                put("flow", True)

            elif ntype == "open_app":
                path = str(inp("path") or "")
                try: os.startfile(path)
                except Exception as e: self.out(f"❌  {e}", "err")
                put("flow", True)

            elif ntype == "http_get":
                try:
                    import urllib.request
                    url = str(inp("url") or "")
                    with urllib.request.urlopen(url, timeout=10) as r:
                        body = r.read().decode("utf-8", errors="replace")
                        code = r.status
                    put("body", body); put("code", float(code))
                except Exception as e:
                    put("body", str(e)); put("code", 0.0)
                put("flow", True)

            elif ntype == "convert":
                v = inp("value"); to = p.get("to","string")
                try:
                    if to == "string": v = str(v)
                    elif to == "number": v = float(v)
                    elif to == "bool":   v = bool(v)
                    elif to == "list":   v = list(v) if hasattr(v,"__iter__") and not isinstance(v,str) else [v]
                except: pass
                put("result", v)

            elif ntype == "length":
                v = inp("value")
                put("length", float(len(v)) if v is not None else 0.0)

            elif ntype == "index":
                lst = inp("list") or []; i = int(inp("i") or 0)
                try: put("item", lst[i])
                except: put("item", None)

            elif ntype == "note":
                pass  # decorative

            # ╔═══════════════════════════════════════════════════════════════╗
            # ║  PRO NODE EXECUTORS — UI / Graphics / Logic / App-system      ║
            # ╚═══════════════════════════════════════════════════════════════╝

            # ── UI / App nodes (IDEMPOTENT — re-runnable from event handlers) ──
            # Each UI-creating node caches its widget in _ui_kept[nid]. On
            # re-run (e.g., triggered by a button click via event), the cached
            # widget is reused instead of being recreated, so events don't
            # spawn duplicate windows/canvases.
            elif ntype == "window":
                self._ui_kept = getattr(self, "_ui_kept", {})
                if nid in self._ui_kept and self._ui_kept[nid].winfo_exists():
                    put("window", self._ui_kept[nid])
                else:
                    title = p.get("title", "App")
                    w = int(float(p.get("w", 480)))
                    h = int(float(p.get("h", 320)))
                    wn = tk.Toplevel()
                    wn.title(title); wn.geometry(f"{w}x{h}")
                    wn.configure(bg="#1a1a2e")
                    self._ui_kept[nid] = wn
                    put("window", wn)
                    self.out(f"🪟  Window: {title} ({w}x{h})", "sys")
                put("flow", True)

            elif ntype == "ui_canvas":
                self._ui_kept = getattr(self, "_ui_kept", {})
                if nid in self._ui_kept and self._ui_kept[nid].winfo_exists():
                    put("canvas", self._ui_kept[nid])
                else:
                    parent = inp("window")
                    if parent is None: parent = tk.Toplevel()
                    cw = int(float(inp("w") or 400)); ch = int(float(inp("h") or 300))
                    cv_w = tk.Canvas(parent, width=cw, height=ch,
                                     bg=p.get("bg", "#ffffff"),
                                     highlightthickness=0)
                    cv_w.pack(fill="both", expand=True)
                    self._ui_kept[nid] = cv_w
                    put("canvas", cv_w)
                put("flow", True)

            elif ntype == "ui_button":
                self._ui_kept = getattr(self, "_ui_kept", {})
                if nid in self._ui_kept and self._ui_kept[nid].winfo_exists():
                    put("flow", True)
                else:
                    parent = inp("window")
                    if parent is None:
                        self.out("⚠  ui_button needs a window input", "err")
                    else:
                        style    = p.get("style", "default")
                        bg_color = p.get("color", "#3a7bd5")
                        lbl_txt  = p.get("label", "?")
                        pack_dir = getattr(parent, "_pack_dir", "vertical")
                        pack_side = "left" if pack_dir == "horizontal" else "top"
                        if style == "icon":
                            btn = tk.Button(parent, text=lbl_txt,
                                            bg=bg_color, fg="white",
                                            relief="flat", bd=0,
                                            padx=6, pady=4,
                                            font=("Segoe UI Emoji", 11),
                                            activebackground="#3a4a6a",
                                            cursor="hand2")
                        elif style == "compact":
                            btn = tk.Button(parent, text=lbl_txt,
                                            bg=bg_color, fg="white",
                                            relief="flat", bd=0,
                                            padx=8, pady=4,
                                            font=("Segoe UI", 8),
                                            activebackground="#3a4a6a",
                                            cursor="hand2")
                        elif style == "accent":
                            btn = tk.Button(parent, text=lbl_txt,
                                            bg="#cc4422", fg="white",
                                            relief="flat", bd=0,
                                            padx=10, pady=4,
                                            font=("Segoe UI", 8, "bold"),
                                            activebackground="#ee6644",
                                            cursor="hand2")
                        else:
                            btn = tk.Button(parent, text=lbl_txt,
                                            bg=bg_color, fg="white",
                                            relief="flat", bd=0,
                                            padx=10, pady=4,
                                            font=("Segoe UI", 9),
                                            activebackground="#5a9be0",
                                            cursor="hand2")
                        btn.pack(side=pack_side, padx=2, pady=2)
                        self._ui_kept[nid] = btn
                        def _click(_=None, _nid=nid):
                            for ww in self.wires:
                                if ww["fn"] == _nid and ww["fp"] == "on_click":
                                    self._flow(ww["tn"], set())
                        btn.bind("<Button-1>", _click)
                    put("flow", True)

            elif ntype == "ui_label":
                self._ui_kept = getattr(self, "_ui_kept", {})
                txt = str(inp("text") or "")
                if nid in self._ui_kept and self._ui_kept[nid].winfo_exists():
                    # Update text on re-run (state-driven label refresh)
                    self._ui_kept[nid].config(text=txt)
                    put("label", self._ui_kept[nid])
                else:
                    parent = inp("window")
                    if parent is not None:
                        fs = int(float(p.get("font_size", 11)))
                        lbl = tk.Label(parent, text=txt, bg="#1a1a2e", fg="white",
                                       font=("Segoe UI", fs))
                        lbl.pack(pady=4)
                        self._ui_kept[nid] = lbl
                        put("label", lbl)
                put("flow", True)

            elif ntype == "ui_input":
                self._ui_kept = getattr(self, "_ui_kept", {})
                if nid in self._ui_kept and self._ui_kept[nid][0].winfo_exists():
                    en, var = self._ui_kept[nid]
                    put("entry", en); put("value", var.get())
                else:
                    parent = inp("window")
                    if parent is not None:
                        var = tk.StringVar()
                        en = tk.Entry(parent, textvariable=var, bg="#222244",
                                      fg="white", insertbackground="white",
                                      relief="flat", bd=8, font=("Segoe UI", 11))
                        en.pack(pady=4, padx=8, fill="x")
                        if p.get("placeholder"): en.insert(0, p["placeholder"])
                        self._ui_kept[nid] = (en, var)
                        put("entry", en); put("value", var.get())
                put("flow", True)

            elif ntype == "ui_slider":
                self._ui_kept = getattr(self, "_ui_kept", {})
                if nid in self._ui_kept and self._ui_kept[nid][0].winfo_exists():
                    sc, var = self._ui_kept[nid]
                    put("value", var.get())  # always fresh!
                else:
                    parent = inp("window")
                    if parent is not None:
                        mn = float(p.get("min", 0)); mx = float(p.get("max", 100))
                        dv = float(p.get("default", 50))
                        var = tk.DoubleVar(value=dv)
                        sc = tk.Scale(parent, from_=mn, to=mx, orient="horizontal",
                                      variable=var, bg="#1a1a2e", fg="white",
                                      troughcolor="#333355", highlightthickness=0,
                                      bd=0, sliderrelief="flat")
                        sc.pack(pady=4, padx=8, fill="x")
                        self._ui_kept[nid] = (sc, var)
                        put("value", var.get())
                put("flow", True)

            elif ntype == "ui_color":
                # Color picker REUSES last picked value if re-run from event.
                # User explicitly clicks a "Pick color" button to reopen dialog.
                self._color_state = getattr(self, "_color_state", {})
                default = p.get("default", "#ff0000")
                if nid in self._color_state:
                    put("color", self._color_state[nid])
                else:
                    from tkinter import colorchooser
                    col = colorchooser.askcolor(default)[1] or default
                    self._color_state[nid] = col
                    put("color", col)
                    self.out(f"🎨  Color: {col}", "sys")
                put("flow", True)

            elif ntype == "ui_panel":
                self._ui_kept = getattr(self, "_ui_kept", {})
                if nid in self._ui_kept and self._ui_kept[nid].winfo_exists():
                    put("panel", self._ui_kept[nid])
                else:
                    parent = inp("window")
                    if parent is not None:
                        direction = p.get("direction", "vertical").lower()
                        side = p.get("side", "top").lower()
                        pn = tk.Frame(parent, bg=p.get("bg", "#222"),
                                      bd=1, relief="solid")
                        # Stamp direction so child widgets (button/label/etc.)
                        # auto-pick the right pack side.
                        pn._pack_dir = "horizontal" if direction.startswith("h") else "vertical"
                        w2 = p.get("w", None)
                        # Side panels (left/right) → fixed width, fill y only
                        if side in ("left", "right"):
                            panel_w = int(float(w2)) if w2 else 240
                            pn.config(width=panel_w)
                            pn.pack(side=side, fill="y")
                            pn.pack_propagate(False)
                        elif pn._pack_dir == "horizontal":
                            pn.pack(side=side, fill="x", padx=0, pady=0)
                        else:
                            pn.pack(side=side, fill="both", expand=True)
                        self._ui_kept[nid] = pn
                        put("panel", pn)
                put("flow", True)

            elif ntype == "ui_image":
                # Display a PIL image in a Tk Label. Idempotent — reuses
                # the same Label on re-run and updates its image, so the
                # Luna render preview refreshes live without flicker.
                self._ui_kept   = getattr(self, "_ui_kept", {})
                self._photo_refs = getattr(self, "_photo_refs", {})
                img = inp("image")
                try:
                    from PIL import ImageTk
                except ImportError:
                    self.out("❌  PIL needed for ui_image", "err")
                    put("flow", True)
                else:
                    if (nid in self._ui_kept
                            and self._ui_kept[nid].winfo_exists()):
                        lbl = self._ui_kept[nid]
                        if img is not None:
                            photo = ImageTk.PhotoImage(img)
                            self._photo_refs[nid] = photo  # keep alive
                            lbl.config(image=photo)
                        put("label", lbl)
                    else:
                        parent = inp("window")
                        if parent is None: parent = tk.Toplevel()
                        photo = None
                        if img is not None:
                            photo = ImageTk.PhotoImage(img)
                            self._photo_refs[nid] = photo
                        lbl = tk.Label(parent, image=photo,
                                       bg="#0a0a18", bd=0)
                        lbl.pack(padx=4, pady=4)
                        self._ui_kept[nid] = lbl
                        put("label", lbl)
                    put("flow", True)

            # ── Graphics nodes (PIL-based, optional) ──────────────────────
            elif ntype == "img_load":
                try:
                    from PIL import Image as _Img
                    path = str(inp("path") or "")
                    if os.path.isfile(path):
                        im = _Img.open(path)
                        put("image", im); put("w", float(im.width))
                        put("h", float(im.height))
                        self.out(f"📂  Loaded {os.path.basename(path)} "
                                 f"({im.width}x{im.height})", "sys")
                    else:
                        self.out(f"❌  File not found: {path}", "err")
                except ImportError:
                    self.out("❌  PIL not available — pip install Pillow", "err")
                put("flow", True)

            elif ntype == "img_save":
                try:
                    im = inp("image"); path = str(inp("path") or "")
                    if im is not None and path:
                        os.makedirs(os.path.dirname(os.path.abspath(path)) or ".",
                                    exist_ok=True)
                        im.save(path)
                        self.out(f"💾  Saved: {os.path.basename(path)}", "sys")
                except Exception as ex:
                    self.out(f"❌  img_save: {ex}", "err")
                put("flow", True)

            elif ntype == "gfx_crop":
                im = inp("image")
                if im is not None:
                    x = int(float(inp("x") or 0)); y = int(float(inp("y") or 0))
                    w = int(float(inp("w") or 100)); h = int(float(inp("h") or 100))
                    put("image", im.crop((x, y, x+w, y+h)))
                put("flow", True)

            elif ntype == "gfx_resize":
                im = inp("image")
                if im is not None:
                    try:
                        from PIL import Image as _Img
                        w = int(float(inp("w") or im.width))
                        h = int(float(inp("h") or im.height))
                        put("image", im.resize((w, h), _Img.LANCZOS))
                    except Exception:
                        pass
                put("flow", True)

            elif ntype == "gfx_blur":
                im = inp("image")
                if im is not None:
                    try:
                        from PIL import ImageFilter as _F
                        r = float(p.get("radius", 4))
                        put("image", im.filter(_F.GaussianBlur(radius=r)))
                    except Exception:
                        pass
                put("flow", True)

            elif ntype == "gfx_stroke":
                # Draw a brush dot at (x, y) on the canvas — used inside
                # event handlers (bound to <Motion> / <B1-Motion>).
                cv_w = inp("canvas")
                if cv_w is not None:
                    bx = float(inp("x") or 0); by = float(inp("y") or 0)
                    col = str(inp("color") or "#000000")
                    sz  = float(inp("size") or 6)
                    cv_w.create_oval(bx-sz/2, by-sz/2, bx+sz/2, by+sz/2,
                                     fill=col, outline="")
                put("flow", True)

            elif ntype == "gfx_clear":
                cv_w = inp("canvas")
                if cv_w is not None:
                    cv_w.delete("all")
                    self.out("⊟  Canvas cleared", "sys")
                put("flow", True)

            elif ntype == "gfx_cv_save":
                cv_w = inp("canvas")
                path = str(inp("path") or "")
                if cv_w is not None and path:
                    try:
                        # Use Windows-friendly screen capture of the canvas
                        # region. PIL.ImageGrab is the most reliable way to
                        # turn a Tk Canvas into a PNG without postscript.
                        from PIL import ImageGrab
                        cv_w.update_idletasks()
                        x0 = cv_w.winfo_rootx(); y0 = cv_w.winfo_rooty()
                        x1 = x0 + cv_w.winfo_width()
                        y1 = y0 + cv_w.winfo_height()
                        os.makedirs(os.path.dirname(os.path.abspath(path))
                                    or ".", exist_ok=True)
                        ImageGrab.grab(bbox=(x0, y0, x1, y1)).save(path)
                        self.out(f"💾  Saved canvas → {os.path.basename(path)}",
                                 "sys")
                    except Exception as ex:
                        self.out(f"❌  canvas save: {ex}", "err")
                put("flow", True)

            # ── Simulation: simple particle emitter on a Canvas ───────────
            elif ntype == "sim_emit":
                cv_w = inp("canvas")
                if cv_w is None:
                    self.out("⚠  sim_emit is a 2D-CANVAS node — wire a "
                             "ui_canvas into its 'canvas' input. For 3D scene "
                             "particles (Donut3D) use  pt_emit_3d -> pt_fire  "
                             "instead.", "err")
                else:
                    import random as _rnd
                    count = int(float(p.get("count", 80)))
                    color = p.get("color", "#ffaa44")
                    speed = float(p.get("speed", 2.0))
                    cw = cv_w.winfo_width() or 400
                    ch = cv_w.winfo_height() or 300
                    parts = []
                    for _ in range(count):
                        x = _rnd.uniform(0, cw); y = _rnd.uniform(0, ch)
                        vx = _rnd.uniform(-speed, speed)
                        vy = _rnd.uniform(-speed, speed)
                        r = _rnd.uniform(2, 5)
                        oid = cv_w.create_oval(x-r, y-r, x+r, y+r,
                                               fill=color, outline="")
                        parts.append([oid, x, y, vx, vy, r])
                    def _tick():
                        if not cv_w.winfo_exists(): return
                        for pt in parts:
                            pt[1] += pt[3]; pt[2] += pt[4]
                            # Bounce off edges
                            if pt[1] < 0 or pt[1] > cw: pt[3] *= -1
                            if pt[2] < 0 or pt[2] > ch: pt[4] *= -1
                            cv_w.coords(pt[0], pt[1]-pt[5], pt[2]-pt[5],
                                                pt[1]+pt[5], pt[2]+pt[5])
                        cv_w.after(33, _tick)
                    cv_w.after(33, _tick)
                    self.out(f"✦  Spawned {count} particles", "sys")
                put("flow", True)

            # ── Pro Logic: state, event, map/filter/reduce ────────────────
            elif ntype == "state":
                # State stores in executor's _state dict (alive during run)
                self._state = getattr(self, "_state", {})
                name = p.get("name", "x")
                if (nid, "set") in self._cache:
                    self._state[name] = self._cache[(nid, "set")]
                elif inp("set") is not None:
                    self._state[name] = inp("set")
                elif name not in self._state:
                    self._state[name] = p.get("default", "")
                put("value", self._state[name]); put("flow", True)

            elif ntype == "event":
                # REAL event binding — handler stays alive for the lifetime
                # of the target widget. Exposes mouse x/y as outputs that
                # get freshly written into cache before downstream re-flows.
                self._ui_kept = getattr(self, "_ui_kept", {})
                target = inp("target")
                ev = p.get("event", "<Button-1>")
                # Bind only once per (event-node, target) pair
                bind_key = f"_bound_{nid}"
                if bind_key not in self._ui_kept and target is not None:
                    def _handler(e=None, _nid=nid):
                        # Inject fresh mouse coords into cache
                        if e is not None:
                            self._cache[(_nid, "x")] = float(getattr(e, "x", 0))
                            self._cache[(_nid, "y")] = float(getattr(e, "y", 0))
                        self._cache[(_nid, "on_event")] = True
                        # Re-flow downstream (UI nodes are idempotent)
                        for ww in self.wires:
                            if ww["fn"] == _nid and ww["fp"] == "on_event":
                                self._flow(ww["tn"], set())
                    target.bind(ev, _handler, add="+")
                    self._ui_kept[bind_key] = True
                    self.out(f"⚡  Bound: {ev}", "sys")
                # During the initial graph run, just init outputs to defaults
                self._cache.setdefault((nid, "x"), 0.0)
                self._cache.setdefault((nid, "y"), 0.0)
                put("flow", True)

            elif ntype == "map_node":
                lst = inp("list") or []
                expr = p.get("expr", "x")
                try:
                    fn = eval(f"lambda x: ({expr})")
                    put("result", [fn(x) for x in lst])
                except Exception as ex:
                    self.out(f"❌  map: {ex}", "err"); put("result", [])
                put("flow", True)

            elif ntype == "filter_node":
                lst = inp("list") or []
                expr = p.get("expr", "True")
                try:
                    fn = eval(f"lambda x: ({expr})")
                    put("result", [x for x in lst if fn(x)])
                except Exception as ex:
                    self.out(f"❌  filter: {ex}", "err"); put("result", [])
                put("flow", True)

            elif ntype == "reduce_node":
                lst = inp("list") or []
                expr = p.get("expr", "acc + x")
                start_str = p.get("start", "0")
                try:
                    start = eval(start_str)
                    fn = eval(f"lambda acc, x: ({expr})")
                    acc = start
                    for x in lst: acc = fn(acc, x)
                    put("result", acc)
                except Exception as ex:
                    self.out(f"❌  reduce: {ex}", "err"); put("result", None)
                put("flow", True)

            # ── App / file system ─────────────────────────────────────────
            elif ntype == "asset":
                path = p.get("path", "")
                # Resolve relative to graph dir
                if path and not os.path.isabs(path):
                    path = os.path.join(_GRAPH_DIR, path)
                put("path", path); put("flow", True)

            elif ntype == "save_state":
                key = str(inp("key") or "default")
                data = inp("data")
                try:
                    state_dir = os.path.join(_GRAPH_DIR, "_state")
                    os.makedirs(state_dir, exist_ok=True)
                    fp = os.path.join(state_dir, f"{key}.json")
                    json.dump({"value": data}, open(fp, "w", encoding="utf-8"))
                    self.out(f"💾  Saved state: {key}", "sys")
                except Exception as ex:
                    self.out(f"❌  save_state: {ex}", "err")
                put("flow", True)

            elif ntype == "load_state":
                key = str(inp("key") or "default")
                try:
                    fp = os.path.join(_GRAPH_DIR, "_state", f"{key}.json")
                    if os.path.isfile(fp):
                        d = json.load(open(fp, encoding="utf-8"))
                        put("data", d.get("value"))
                        self.out(f"📂  Loaded state: {key}", "sys")
                    else:
                        put("data", None)
                except Exception as ex:
                    self.out(f"❌  load_state: {ex}", "err"); put("data", None)
                put("flow", True)

            elif ntype == "plugin":
                modname = p.get("name", "")
                try:
                    import importlib
                    mod = importlib.import_module(modname)
                    put("module", mod)
                    self.out(f"🔌  Plugin loaded: {modname}", "sys")
                except Exception as ex:
                    self.out(f"❌  plugin {modname}: {ex}", "err")
                    put("module", None)
                put("flow", True)

            elif ntype == "export_app":
                name = str(inp("name") or "MyApp").strip()
                safe = re.sub(r'[^\w\-]', '_', name)[:40] or "MyApp"
                # .run = NodeBase runtime app bundle (short, unused extension)
                app_dir = os.path.join(_GRAPH_DIR, f"{safe}.run")
                try:
                    os.makedirs(app_dir, exist_ok=True)
                    os.makedirs(os.path.join(app_dir, "assets"), exist_ok=True)
                    # Save the current graph alongside the manifest so the
                    # .run bundle is self-contained.
                    try:
                        json.dump({"nodes": list(self.nodes.values()),
                                   "wires": self.wires},
                                  open(os.path.join(app_dir, "graph.nbg"),
                                       "w", encoding="utf-8"), indent=2)
                    except Exception:
                        pass
                    # manifest.json
                    manifest = {
                        "name":    name,
                        "icon":    p.get("icon", "📦"),
                        "version": "1.0",
                        "engine":  "nbg/1.0",
                        "entry":   "main.vx",
                        "graph":   "graph.nbg",
                    }
                    json.dump(manifest,
                              open(os.path.join(app_dir, "manifest.json"),
                                   "w", encoding="utf-8"), indent=2)
                    # ── REAL main.vx — loads NodeBase runtime + runs graph
                    main_src = (
                        f"# VX:name={name}\n"
                        f"# VX:icon={p.get('icon','📦')}\n"
                        f"# VX:version=1.0\n"
                        f"# VX:author=Vincent Ilagan\n"
                        f'"""\n'
                        f"  {name} — generated by NodeBase\n"
                        f"  This .run bundle hosts a .nbg graph + assets.\n"
                        f'"""\n\n'
                        f"import os, json, sys\n"
                        f"from importlib.machinery import SourceFileLoader\n\n"
                        f"def main(desktop):\n"
                        f"    here = os.path.dirname(os.path.abspath(__file__))\n"
                        f"    # Locate NodeBase runtime in Luci/programfiles\n"
                        f"    prog = os.path.dirname(os.path.dirname(here))\n"
                        f"    # If .run is nested deeper, walk up until we find programfiles\n"
                        f"    walk = here\n"
                        f"    nb_path = None\n"
                        f"    for _ in range(6):\n"
                        f"        cand = os.path.join(walk, 'programfiles',"
                        f" 'nodebase.vx')\n"
                        f"        if os.path.isfile(cand):\n"
                        f"            nb_path = cand; break\n"
                        f"        walk = os.path.dirname(walk)\n"
                        f"    if not nb_path:\n"
                        f"        from tkinter import messagebox\n"
                        f"        messagebox.showerror('{name}',\n"
                        f"            'NodeBase runtime not found — install Luci.')\n"
                        f"        return\n"
                        f"    # Load NodeBase as module + execute graph\n"
                        f"    nb = SourceFileLoader('nodebase_runtime',"
                        f" nb_path).load_module()\n"
                        f"    graph = json.load(open(os.path.join(here,"
                        f" 'graph.nbg'), encoding='utf-8'))\n"
                        f"    def _log(text, tag='out'):\n"
                        f"        print(f'[{name}] ' + str(text))\n"
                        f"    ex = nb.run_graph_standalone(graph, _log)\n"
                        f"    # Pin to desktop so executor + bindings persist\n"
                        f"    if not hasattr(desktop, '_nbg_apps'):\n"
                        f"        desktop._nbg_apps = []\n"
                        f"    desktop._nbg_apps.append(ex)\n"
                    )
                    open(os.path.join(app_dir, "main.vx"),
                         "w", encoding="utf-8").write(main_src)
                    put("path", app_dir)
                    self.out(f"📦  App exported: {os.path.basename(app_dir)}",
                             "sys")
                except Exception as ex:
                    self.out(f"❌  export_app: {ex}", "err")
                    put("path", "")
                put("flow", True)

            elif ntype == "noise_gen":
                import random as _rnd
                seed = int(float(p.get("seed", 42)))
                _rnd.seed(seed)
                put("value", _rnd.random()); put("flow", True)

            # ╔═══════════════════════════════════════════════════════════════╗
            # ║  3D SUBSYSTEM EXECUTORS — software-rendered, no GPU needed   ║
            # ║  Scene = dict of {meshes: [], lights: [], particles: []}     ║
            # ╚═══════════════════════════════════════════════════════════════╝

            elif ntype == "3d_camera":
                # Add a real camera to the scene + wire orbit controls to the
                # viewport so dragging rotates the view and scroll zooms in/out.
                # Mutates scene.camera and triggers a re-render via the
                # scene["_render_fn"] callback that luna_render installs.
                scene = inp("scene")
                if scene is None:
                    self.out("⚠  3d_camera needs a scene", "err")
                else:
                    import math as _m
                    cam = scene.setdefault("camera", {})
                    cam.setdefault("yaw",      0.0)
                    cam.setdefault("pitch",    0.2)
                    cam.setdefault("distance", 6.0)
                    cam.setdefault("target_x", 0.0)
                    cam.setdefault("target_y", 0.0)
                    cam.setdefault("target_z", 0.0)
                    cam["fov"] = float(p.get("fov", 50))

                    def _update_cam_xyz():
                        d  = cam["distance"]
                        cy = _m.cos(cam["pitch"])
                        cam["x"] = cam["target_x"] + d * _m.sin(cam["yaw"]) * cy
                        cam["y"] = cam["target_y"] + d * _m.sin(cam["pitch"])
                        cam["z"] = cam["target_z"] - d * _m.cos(cam["yaw"]) * cy
                    _update_cam_xyz()

                    vp_cv = scene.get("viewport")
                    bind_key = f"_cam_bound_{nid}"
                    if (vp_cv is not None
                            and not getattr(self, bind_key, False)):
                        setattr(self, bind_key, True)
                        _drag = {"x": 0, "y": 0, "active": False,
                                 "down_x": 0, "down_y": 0, "moved": False}
                        _pan  = {"x": 0, "y": 0, "active": False}

                        def _refresh(fast=False):
                            # fast=True  -> wireframe render (smooth dragging)
                            # fast=False -> full shaded render (on release)
                            rf = ((scene.get("_render_fast_fn") if fast else None)
                                  or scene.get("_render_fn"))
                            if rf:
                                try: rf()
                                except Exception: pass

                        def _try_select(sx, sy):
                            """Project meshes AND lights to screen; pick the
                            closest one within tolerance. Screen-space picking,
                            no raycast required."""
                            cam_pos = (cam["x"], cam["y"], cam["z"])
                            cam_tgt = (cam["target_x"], cam["target_y"],
                                       cam["target_z"])
                            forward = _vec_norm(_vec_sub(cam_tgt, cam_pos))
                            world_up = (0, 1, 0)
                            right = _vec_norm(_vec_cross(forward, world_up))
                            if abs(_vec_dot(right, right)) < 0.001:
                                right = (1, 0, 0)
                            up_ = _vec_norm(_vec_cross(right, forward))
                            cw = vp_cv.winfo_width() or 800
                            ch = vp_cv.winfo_height() or 600
                            f_ = (ch / 2) / _m.tan(_m.radians(cam["fov"]/2))
                            best_kind, best_i, best_d = None, -1, 60

                            def _screen_xy(world_pt):
                                d = _vec_sub(world_pt, cam_pos)
                                cz = _vec_dot(d, forward)
                                if cz < 0.05: return None
                                cx_ = _vec_dot(d, right)
                                cy_ = _vec_dot(d, up_)
                                return (cw/2 + cx_ * f_ / cz,
                                        ch/2 - cy_ * f_ / cz)

                            # Meshes — hit-test against the projected
                            # bounding box of the mesh's verts (not just
                            # the center point). This way clicking ANY
                            # visible part of a mesh selects it. Picking
                            # priority: smallest depth wins (frontmost),
                            # tiebreak by smaller bbox diagonal.
                            best_mesh_depth = 1e9
                            for i, m in enumerate(scene.get("meshes", [])):
                                verts_w, _ = _build_mesh_trs(m)
                                if not verts_w: continue
                                minx, miny = 1e9, 1e9
                                maxx, maxy = -1e9, -1e9
                                avg_z = 0.0; n_v = 0
                                for v in verts_w:
                                    pp = _screen_xy(v)
                                    if pp is None: continue
                                    px_, py_ = pp
                                    if px_ < minx: minx = px_
                                    if px_ > maxx: maxx = px_
                                    if py_ < miny: miny = py_
                                    if py_ > maxy: maxy = py_
                                    # depth of this vert in cam space
                                    d = _vec_sub(v, cam_pos)
                                    avg_z += _vec_dot(d, forward); n_v += 1
                                if n_v == 0: continue
                                avg_z /= n_v
                                # Click inside bbox?
                                if (minx <= sx <= maxx
                                        and miny <= sy <= maxy):
                                    # Frontmost mesh wins
                                    if avg_z < best_mesh_depth:
                                        best_mesh_depth = avg_z
                                        best_d, best_kind, best_i = 0, "mesh", i

                            # Lights — only if handles are visible
                            if scene.get("show_light_handles", False):
                                for i, L in enumerate(scene.get("lights", [])):
                                    if L.get("type") == "sun":
                                        # Sun gizmo drawn opposite to its dir
                                        wp = (cam_tgt[0] - L["dir_x"]*4,
                                              cam_tgt[1] - L["dir_y"]*4,
                                              cam_tgt[2] - L["dir_z"]*4)
                                    else:
                                        wp = (L.get("x", 0), L.get("y", 0),
                                              L.get("z", 0))
                                    p2 = _screen_xy(wp)
                                    if p2 is None: continue
                                    dist = ((sx-p2[0])**2
                                            + (sy-p2[1])**2) ** 0.5
                                    if dist < best_d:
                                        best_d  = dist
                                        best_kind, best_i = "light", i

                            # Camera (only when edit mode active)
                            if scene.get("camera_mode") == "edit":
                                cm = scene.get("camera", {})
                                p2 = _screen_xy((cm.get("x", 0),
                                                 cm.get("y", 0),
                                                 cm.get("z", -5)))
                                if p2 is not None:
                                    dist = ((sx-p2[0])**2
                                            + (sy-p2[1])**2) ** 0.5
                                    if dist < best_d:
                                        best_d = dist
                                        best_kind, best_i = "camera", 0

                            # Apply selection
                            scene.pop("selected_mesh", None)
                            scene.pop("selected_light", None)
                            scene.pop("selected_camera", None)
                            if best_kind == "mesh":
                                scene["selected_mesh"] = best_i
                                self.out(
                                    f"🎯  Mesh: "
                                    f"{scene['meshes'][best_i].get('name','?')}",
                                    "sys")
                            elif best_kind == "light":
                                scene["selected_light"] = best_i
                                self.out(
                                    f"💡  Light: "
                                    f"{scene['lights'][best_i].get('type','?')} #{best_i}",
                                    "sys")
                            elif best_kind == "camera":
                                scene["selected_camera"] = True
                                self.out("📷  Selected camera — drag arrows "
                                         "to reposition", "sys")
                            _refresh()

                        # ── Gizmo drag state ─────────────────────────────
                        _giz = {"active": False, "axis": None,
                                "start_xy": (0, 0), "start_world": (0,0,0),
                                "axis_screen": (1, 0), "axis_scale": 1.0,
                                "kind": None, "target": None}

                        def _dist_to_segment(px, py, ax, ay, bx, by):
                            """Closest distance from point to segment."""
                            dx, dy = bx - ax, by - ay
                            L2 = dx*dx + dy*dy
                            if L2 < 1: return ((px-ax)**2+(py-ay)**2)**0.5
                            t = max(0, min(1, ((px-ax)*dx + (py-ay)*dy)/L2))
                            qx, qy = ax + t*dx, ay + t*dy
                            return ((px-qx)**2 + (py-qy)**2)**0.5

                        def _hit_gizmo(sx, sy):
                            """If click hit a gizmo arrow, set up _giz and
                            return True; else False."""
                            gz = scene.get("_gizmo")
                            if not gz: return False
                            ox, oy = gz["origin"]
                            # Larger tolerance + tip-bias: clicking near
                            # the arrow head (further from origin) still
                            # registers as an axis grab.
                            for axis, ekey in (("x", "x_end"),
                                                ("y", "y_end"),
                                                ("z", "z_end")):
                                ex_, ey_ = gz[ekey]
                                d = _dist_to_segment(sx, sy, ox, oy, ex_, ey_)
                                # Also test distance to the tip directly
                                tip_d = ((sx-ex_)**2 + (sy-ey_)**2) ** 0.5
                                hit = (d < 18) or (tip_d < 14)
                                if hit:
                                    dx, dy = ex_ - ox, ey_ - oy
                                    L = (dx*dx + dy*dy) ** 0.5
                                    if L < 1: continue
                                    tgt2 = gz["target"]
                                    _giz.update(
                                        active=True, axis=axis,
                                        start_xy=(sx, sy),
                                        start_world=tuple(gz["world"]),
                                        axis_screen=(dx/L, dy/L),
                                        axis_scale=gz["size"] / L,
                                        kind=gz["kind"],
                                        target=tgt2,
                                        gizmo_mode=gz.get("mode","translate"),
                                        start_rx=tgt2.get("rx", 0.0),
                                        start_ry=tgt2.get("ry", 0.0),
                                        start_rz=tgt2.get("rz", 0.0),
                                        start_scale=tgt2.get("scale", 1.0),
                                    )
                                    self.out(
                                        f"🎯  Gizmo grab: {axis.upper()} axis "
                                        f"({gz['kind']})",
                                        "sys")
                                    return True
                            return False

                        # ── LEFT mouse: gizmo drag, orbit (drag), or select (tap)
                        def _down(e):
                            if _hit_gizmo(e.x, e.y):
                                return   # gizmo absorbed the click
                            _drag.update(x=e.x, y=e.y, down_x=e.x,
                                         down_y=e.y, active=True, moved=False)
                        def _drag_move(e):
                            # Gizmo drag has priority
                            if _giz["active"]:
                                import math as _gm2
                                dx = e.x - _giz["start_xy"][0]
                                dy = e.y - _giz["start_xy"][1]
                                ax_, ay_ = _giz["axis_screen"]
                                world_delta = (dx*ax_ + dy*ay_) * _giz["axis_scale"]
                                tgt  = _giz["target"]
                                axis = _giz["axis"]
                                gm   = _giz.get("gizmo_mode", "translate")

                                if gm == "translate":
                                    wx, wy, wz = _giz["start_world"]
                                    if axis == "x": wx += world_delta
                                    elif axis == "y": wy -= world_delta
                                    elif axis == "z": wz += world_delta
                                    if _giz["kind"] == "mesh":
                                        tgt["tx"], tgt["ty"], tgt["tz"] = wx, wy, wz
                                    else:
                                        tgt["x"], tgt["y"], tgt["z"] = wx, wy, wz

                                elif gm == "rotate":
                                    angle = world_delta * 1.5   # radians
                                    tgt.setdefault("rx", 0.0)
                                    tgt.setdefault("ry", 0.0)
                                    tgt.setdefault("rz", 0.0)
                                    base_rx = _giz.get("start_rx", tgt["rx"])
                                    base_ry = _giz.get("start_ry", tgt["ry"])
                                    base_rz = _giz.get("start_rz", tgt["rz"])
                                    if axis == "x": tgt["rx"] = base_rx + angle
                                    elif axis == "y": tgt["ry"] = base_ry + angle
                                    elif axis == "z": tgt["rz"] = base_rz + angle

                                elif gm == "scale":
                                    factor = 1.0 + world_delta * 0.5
                                    factor = max(0.01, factor)
                                    base_s = _giz.get("start_scale", tgt.get("scale", 1.0))
                                    if axis in ("x", "y", "z"):
                                        # Uniform scale on any axis drag
                                        tgt["scale"] = base_s * factor

                                _refresh(True)   # wireframe while dragging gizmo
                                return
                            if not _drag["active"]: return
                            dx = e.x - _drag["x"]; dy = e.y - _drag["y"]
                            _drag["x"], _drag["y"] = e.x, e.y
                            if (abs(e.x - _drag["down_x"]) > 4
                                    or abs(e.y - _drag["down_y"]) > 4):
                                _drag["moved"] = True
                            if _drag["moved"]:
                                cam["yaw"]   -= dx * 0.01
                                cam["pitch"] += dy * 0.01
                                cam["pitch"] = max(-1.5, min(1.5,
                                                             cam["pitch"]))
                                _update_cam_xyz()
                                _refresh(True)   # wireframe while orbiting
                        def _up(e):
                            if _giz["active"]:
                                _giz["active"] = False
                                _refresh()       # full render on gizmo release
                                return
                            was_click = (_drag["active"]
                                         and not _drag["moved"])
                            moved = _drag["moved"]
                            _drag["active"] = False
                            if was_click:
                                _try_select(e.x, e.y)
                            elif moved:
                                _refresh()       # full render after orbit

                        # ── MIDDLE mouse: pan (drag the target around) ───
                        def _pan_down(e):
                            _pan.update(x=e.x, y=e.y, active=True)
                        def _pan_move(e):
                            if not _pan["active"]: return
                            dx = e.x - _pan["x"]; dy = e.y - _pan["y"]
                            _pan["x"], _pan["y"] = e.x, e.y
                            # Pan in camera basis (right + up vectors)
                            cam_pos = (cam["x"], cam["y"], cam["z"])
                            cam_tgt = (cam["target_x"], cam["target_y"],
                                       cam["target_z"])
                            forward = _vec_norm(_vec_sub(cam_tgt, cam_pos))
                            right = _vec_norm(_vec_cross(forward, (0,1,0)))
                            up_   = _vec_norm(_vec_cross(right, forward))
                            speed = cam["distance"] * 0.003
                            for axis_xyz, sign, vec in (
                                ("x", -dx, right), ("x", dy, up_),
                            ):
                                pass
                            cam["target_x"] += -dx * speed * right[0] + dy * speed * up_[0]
                            cam["target_y"] += -dx * speed * right[1] + dy * speed * up_[1]
                            cam["target_z"] += -dx * speed * right[2] + dy * speed * up_[2]
                            _update_cam_xyz()
                            _refresh(True)       # wireframe while panning
                        def _pan_up(e):
                            _pan["active"] = False
                            _refresh()           # full render after pan

                        def _wheel(e):
                            delta = -1 if e.delta > 0 else 1
                            cam["distance"] = max(1.0, min(50.0,
                                cam["distance"] + delta * 0.6))
                            _update_cam_xyz()
                            _refresh()

                        vp_cv.bind("<ButtonPress-1>",   _down)
                        vp_cv.bind("<B1-Motion>",      _drag_move)
                        vp_cv.bind("<ButtonRelease-1>", _up)
                        vp_cv.bind("<ButtonPress-2>",   _pan_down)
                        vp_cv.bind("<B2-Motion>",      _pan_move)
                        vp_cv.bind("<ButtonRelease-2>", _pan_up)
                        vp_cv.bind("<MouseWheel>",     _wheel)
                        self.out("📷  Camera: drag=orbit · mid-drag=pan · "
                                 "wheel=zoom · click=select", "sys")
                    put("camera", cam)
                put("flow", True)

            elif ntype == "viewport_3d":
                # 3D Viewport = Tk Canvas + a "scene" dict that other 3D
                # nodes mutate. Idempotent like other UI nodes.
                self._ui_kept = getattr(self, "_ui_kept", {})
                if (nid in self._ui_kept
                        and self._ui_kept[nid][0].winfo_exists()):
                    cv3d, scene = self._ui_kept[nid]
                    put("viewport", cv3d); put("scene", scene)
                else:
                    parent = inp("window")
                    if parent is None: parent = tk.Toplevel()
                    vw = int(float(inp("w") or 640))
                    vh = int(float(inp("h") or 480))
                    cv3d = tk.Canvas(parent, width=vw, height=vh,
                                     bg=p.get("bg", "#0a0a18"),
                                     highlightthickness=0)
                    cv3d.pack(fill="both", expand=True)
                    scene = {
                        "meshes":    [],
                        "lights":    [],
                        "particles": [],
                        "camera":    {"x":0, "y":0, "z":-5,
                                      "fov": float(p.get("fov", 50))},
                        "viewport":  cv3d, "w": vw, "h": vh,
                    }
                    self._ui_kept[nid] = (cv3d, scene)
                    put("viewport", cv3d); put("scene", scene)
                put("flow", True)

            elif ntype in ("prim_cube", "prim_sphere", "prim_plane",
                           "prim_cyl", "prim_torus", "prim_cone", "prim_grid"):
                # Primitives = dict descriptors added to the scene.
                # Actual triangulation happens at render time (Luna).
                # Rotation params are radians; the .nbg can also pass
                # *_deg which is converted automatically.
                import math as _m
                scene = inp("scene")
                def _deg(k, d=0.0):
                    v = p.get(k + "_deg")
                    if v is not None:
                        try: return float(v) * _m.pi / 180.0
                        except Exception: pass
                    try: return float(p.get(k, d))
                    except Exception: return d
                mesh = {
                    "kind":     ntype.replace("prim_", ""),
                    "params":   dict(p),
                    # translation
                    "tx":       float(p.get("x", 0)),
                    "ty":       float(p.get("y", 0)),
                    "tz":       float(p.get("z", 0)),
                    # rotation (radians; *_deg in .nbg auto-converts)
                    "rx":       _deg("rx", 0.0),
                    "ry":       _deg("ry", 0.0),
                    "rz":       _deg("rz", 0.0),
                    # scale (defaults to 1)
                    "sx":       float(p.get("sx", 1.0)),
                    "sy":       float(p.get("sy", 1.0)),
                    "sz":       float(p.get("sz", 1.0)),
                    "name":     f"{ntype.replace('prim_','')}_{uuid.uuid4().hex[:4]}",
                    "material": {"color": p.get("color", "#aaccee")},
                }
                if scene is not None:
                    scene["meshes"].append(mesh)
                put("mesh", mesh); put("flow", True)

            elif ntype == "floor_grid":
                scene = inp("scene")
                floor = {
                    "size":      float(p.get("size", 10)),
                    "divisions": int(float(p.get("divisions", 20))),
                    "y":         float(p.get("y", -1.0)),
                    "color":     p.get("color", "#2a3a55"),
                }
                if scene is not None:
                    scene.setdefault("floors", []).append(floor)
                put("floor", floor); put("flow", True)

            elif ntype == "light_omni":
                scene = inp("scene")
                light = {"type": "omni",
                         "x": float(p.get("x", 3)),
                         "y": float(p.get("y", 4)),
                         "z": float(p.get("z", 3)),
                         "intensity": float(p.get("intensity", 1.0)),
                         "color": p.get("color", "#ffffff")}
                if scene is not None:
                    scene.setdefault("lights", []).append(light)
                put("light", light); put("flow", True)

            elif ntype == "light_sun":
                scene = inp("scene")
                light = {"type": "sun",
                         "dir_x": float(p.get("dir_x", -0.5)),
                         "dir_y": float(p.get("dir_y", -1.0)),
                         "dir_z": float(p.get("dir_z", -0.3)),
                         "intensity": float(p.get("intensity", 1.0)),
                         "color": p.get("color", "#fff8dd")}
                if scene is not None:
                    scene.setdefault("lights", []).append(light)
                put("light", light); put("flow", True)

            elif ntype == "light_spot":
                scene = inp("scene")
                light = {"type": "spot",
                         "x": float(p.get("x", 0)),
                         "y": float(p.get("y", 5)),
                         "z": float(p.get("z", 0)),
                         "angle": float(p.get("angle", 45)),
                         "intensity": float(p.get("intensity", 1.5)),
                         "color": p.get("color", "#ffffff")}
                if scene is not None:
                    scene.setdefault("lights", []).append(light)
                put("light", light); put("flow", True)

            elif ntype == "light_area":
                scene = inp("scene")
                light = {"type": "area",
                         "x": float(p.get("x", 2)),
                         "y": float(p.get("y", 3)),
                         "z": float(p.get("z", 0)),
                         "size": float(p.get("size", 2.0)),
                         "intensity": float(p.get("intensity", 2.0)),
                         "color": p.get("color", "#ffffff")}
                if scene is not None:
                    scene.setdefault("lights", []).append(light)
                put("light", light); put("flow", True)

            elif ntype == "set_mode":
                scene = inp("scene")
                if scene is not None:
                    scene["mode"] = p.get("mode", "wireframe")
                    rf = scene.get("_render_fn")
                    if rf:
                        try: rf()
                        except Exception: pass
                put("flow", True)

            elif ntype == "shadow_settings":
                scene = inp("scene")
                if scene is not None:
                    scene["shadows"] = {
                        "enabled":  p.get("enable", "on") == "on",
                        "darkness": float(p.get("darkness", 0.45)),
                        "softness": float(p.get("softness", 0.0)),
                    }
                    rf = scene.get("_render_fn")
                    if rf:
                        try: rf()
                        except Exception: pass
                    self.out(
                        f"🌑  Shadows {scene['shadows']['enabled'] and 'on' or 'off'}",
                        "sys")
                put("flow", True)

            elif ntype == "light_handles":
                scene = inp("scene")
                if scene is not None:
                    scene["show_light_handles"] = (p.get("show", "on") == "on")
                    scene["light_handle_size"]  = float(p.get("size", 0.3))
                    rf = scene.get("_render_fn")
                    if rf:
                        try: rf()
                        except Exception: pass
                    self.out(
                        f"💡  Light handles "
                        f"{'on' if scene['show_light_handles'] else 'off'}",
                        "sys")
                put("flow", True)

            elif ntype == "camera_mode":
                # view = render through scene.camera (default)
                # edit = render through a free-orbit edit camera AND
                #        show the user's camera as a selectable 3D object
                scene = inp("scene")
                if scene is not None:
                    mode_v = p.get("mode", "view")
                    if mode_v == "edit":
                        if "edit_cam" not in scene:
                            # Clone current camera as the edit cam
                            scene["edit_cam"] = dict(scene["camera"])
                            # Pull edit cam back a bit so user can see their cam
                            scene["edit_cam"]["distance"] = max(
                                8.0, scene["edit_cam"].get("distance", 6))
                        scene["camera_mode"] = "edit"
                        self.out(
                            "📷  Camera mode: EDIT — camera now visible as "
                            "object (drag to reposition)", "sys")
                    else:
                        scene.pop("edit_cam", None)
                        scene["camera_mode"] = "view"
                        self.out("📷  Camera mode: VIEW — looking through "
                                 "the camera", "sys")
                    rf = scene.get("_render_fn")
                    if rf:
                        try: rf()
                        except Exception: pass
                put("flow", True)

            elif ntype == "gizmo_mode":
                scene = inp("scene")
                if scene is not None:
                    scene["gizmo_mode"] = p.get("mode", "translate")
                    rf = scene.get("_render_fn")
                    if rf:
                        try: rf()
                        except Exception: pass
                    self.out(f"⛓  Gizmo: {scene['gizmo_mode']}", "sys")
                put("flow", True)

            elif ntype == "pos":
                # Apply position to a mesh / light / camera (whatever is wired)
                tgt = inp("target")
                if tgt is not None:
                    if "tx" in tgt:    # mesh-style
                        tgt["tx"] = float(p.get("x", 0))
                        tgt["ty"] = float(p.get("y", 0))
                        tgt["tz"] = float(p.get("z", 0))
                    else:              # light / camera-style
                        tgt["x"] = float(p.get("x", 0))
                        tgt["y"] = float(p.get("y", 0))
                        tgt["z"] = float(p.get("z", 0))
                put("target", tgt); put("flow", True)

            elif ntype == "rotation":
                tgt = inp("target")
                if tgt is not None:
                    tgt["rx"] = float(p.get("rx", 0))
                    tgt["ry"] = float(p.get("ry", 0))
                    tgt["rz"] = float(p.get("rz", 0))
                put("target", tgt); put("flow", True)

            elif ntype == "scale":
                tgt = inp("target")
                if tgt is not None:
                    tgt["sx"] = float(p.get("sx", 1.0))
                    tgt["sy"] = float(p.get("sy", 1.0))
                    tgt["sz"] = float(p.get("sz", 1.0))
                put("target", tgt); put("flow", True)

            elif ntype == "object_mgr":
                # Sidebar panel listing all scene objects with X/Y/Z editors.
                # Idempotent: rebuilds list on re-run.
                self._ui_kept = getattr(self, "_ui_kept", {})
                scene = inp("scene")
                parent = inp("window")
                if parent is None or scene is None:
                    put("flow", True)
                else:
                    if (nid in self._ui_kept
                            and self._ui_kept[nid].winfo_exists()):
                        panel = self._ui_kept[nid]
                        for child in panel.winfo_children():
                            child.destroy()
                    else:
                        panel = tk.Frame(parent, bg="#0d0d20",
                                         bd=1, relief="solid", width=220)
                        panel.pack(side="right", fill="y", padx=2, pady=2)
                        panel.pack_propagate(False)
                        self._ui_kept[nid] = panel

                    tk.Label(panel, text="  ⊞  Object Manager",
                             bg="#1a1a3a", fg="#88ccff",
                             font=("Segoe UI", 10, "bold"),
                             anchor="w").pack(fill="x")

                    def _refresh_render():
                        rf = scene.get("_render_fn")
                        if rf:
                            try: rf()
                            except Exception: pass

                    # Meshes section
                    tk.Label(panel, text=f"  Meshes ({len(scene.get('meshes',[]))})",
                             bg="#0d0d20", fg="#5577aa",
                             font=("Segoe UI", 8, "bold"),
                             anchor="w").pack(fill="x", pady=(6, 0))
                    sel_idx = scene.get("selected_mesh", -1)
                    for idx, m in enumerate(scene.get("meshes", [])):
                        is_sel = (idx == sel_idx)
                        row_bg = "#2a2a44" if is_sel else "#10102a"
                        row = tk.Frame(panel, bg=row_bg, bd=1, relief="flat")
                        row.pack(fill="x", padx=4, pady=1)

                        # Header row: name + color swatch + delete X
                        hdr = tk.Frame(row, bg=row_bg)
                        hdr.pack(fill="x")
                        # Click name → select this mesh
                        def _select(_=None, ii=idx):
                            scene["selected_mesh"] = ii
                            _refresh_render()
                        name_lbl = tk.Label(hdr,
                            text=("●" if is_sel else "  ")
                                 + f" {m.get('name', m['kind'])[:14]}",
                            bg=row_bg,
                            fg="#ffee44" if is_sel else "#aaccee",
                            font=("Consolas", 8, "bold" if is_sel else "normal"),
                            anchor="w", cursor="hand2")
                        name_lbl.pack(side="left", fill="x", expand=True,
                                      padx=2)
                        name_lbl.bind("<Button-1>", _select)

                        # Color swatch — click to open color picker
                        col_str = m.get("material", {}).get("color", "#aaccee")
                        def _pick_color(_=None, mm=m):
                            from tkinter import colorchooser
                            new = colorchooser.askcolor(
                                mm.get("material", {}).get("color", "#aaccee"))[1]
                            if new:
                                mm.setdefault("material", {})["color"] = new
                                _refresh_render()
                        sw = tk.Button(hdr, text=" ", bg=col_str,
                                       width=2, relief="flat", bd=0,
                                       cursor="hand2",
                                       command=_pick_color)
                        sw.pack(side="left", padx=2)

                        # Delete button
                        def _del(_=None, ii=idx):
                            try:
                                del scene["meshes"][ii]
                                if scene.get("selected_mesh") == ii:
                                    scene.pop("selected_mesh", None)
                                _refresh_render()
                            except IndexError: pass
                        tk.Button(hdr, text="✕", bg=row_bg, fg="#cc4466",
                                  font=("Segoe UI", 7, "bold"),
                                  relief="flat", bd=0, padx=4,
                                  cursor="hand2", command=_del
                                  ).pack(side="right")

                        # X / Y / Z entry row
                        xyz = tk.Frame(row, bg=row_bg)
                        xyz.pack(fill="x", padx=6, pady=(2, 0))
                        for axis_lbl, axis in (("X","tx"),("Y","ty"),("Z","tz")):
                            tk.Label(xyz, text=axis_lbl, bg=row_bg,
                                     fg="#778899",
                                     font=("Consolas", 7)).pack(side="left")
                            v = tk.StringVar(value=str(round(m[axis], 2)))
                            e = tk.Entry(xyz, textvariable=v, width=5,
                                         bg="#0a0a18", fg="#ccffcc",
                                         insertbackground="#88ccff",
                                         relief="flat", bd=2,
                                         font=("Consolas", 8))
                            e.pack(side="left", padx=1)
                            def _on_change(_=None, mm=m, ax=axis, vv=v):
                                try:
                                    mm[ax] = float(vv.get())
                                    _refresh_render()
                                except ValueError: pass
                            e.bind("<Return>",  _on_change)
                            e.bind("<FocusOut>", _on_change)

                    # Lights section — editable position + selectable
                    tk.Label(panel, text=f"  Lights ({len(scene.get('lights',[]))})",
                             bg="#0d0d20", fg="#5577aa",
                             font=("Segoe UI", 8, "bold"),
                             anchor="w").pack(fill="x", pady=(8, 0))
                    sel_light = scene.get("selected_light", -1)
                    for li, L in enumerate(scene.get("lights", [])):
                        is_sel = (li == sel_light)
                        row_bg = "#3a3a22" if is_sel else "#10102a"
                        lrow = tk.Frame(panel, bg=row_bg, bd=1, relief="flat")
                        lrow.pack(fill="x", padx=4, pady=1)
                        # Header — type + click-to-select
                        def _sel_light(_=None, ii=li):
                            scene["selected_light"] = ii
                            scene.pop("selected_mesh", None)
                            _refresh_render()
                        hdr2 = tk.Label(lrow,
                            text=("💡" if is_sel else "  ")
                                 + f" {L['type']}  "
                                 + f"i={L.get('intensity',1):.1f}",
                            bg=row_bg,
                            fg="#ffee44" if is_sel else "#ffcc66",
                            font=("Consolas", 8, "bold" if is_sel else "normal"),
                            anchor="w", cursor="hand2")
                        hdr2.pack(fill="x", padx=2)
                        hdr2.bind("<Button-1>", _sel_light)
                        # X/Y/Z editors (for omni/spot/area) OR dir for sun
                        xyz2 = tk.Frame(lrow, bg=row_bg)
                        xyz2.pack(fill="x", padx=6, pady=(2, 0))
                        is_sun = (L["type"] == "sun")
                        keys = (("dx","dir_x"),("dy","dir_y"),("dz","dir_z")) \
                               if is_sun else \
                               (("X","x"),("Y","y"),("Z","z"))
                        for axis_lbl, axis in keys:
                            tk.Label(xyz2, text=axis_lbl, bg=row_bg,
                                     fg="#778899",
                                     font=("Consolas", 7)).pack(side="left")
                            v = tk.StringVar(value=str(round(L.get(axis, 0), 2)))
                            e = tk.Entry(xyz2, textvariable=v, width=5,
                                         bg="#0a0a18", fg="#ffeebb",
                                         insertbackground="#ffcc66",
                                         relief="flat", bd=2,
                                         font=("Consolas", 8))
                            e.pack(side="left", padx=1)
                            def _on_chg(_=None, LL=L, ax=axis, vv=v):
                                try:
                                    LL[ax] = float(vv.get())
                                    _refresh_render()
                                except ValueError: pass
                            e.bind("<Return>",  _on_chg)
                            e.bind("<FocusOut>", _on_chg)

                put("flow", True)

            elif ntype == "pt_emit_3d":
                # Particle emitter — adds a 3D particle system descriptor.
                scene = inp("scene")
                emitter = {
                    "x":     float(inp("x") or 0),
                    "y":     float(inp("y") or 0),
                    "z":     float(inp("z") or 0),
                    "count": int(float(p.get("count", 500))),
                    "rate":  float(p.get("rate", 60)),
                    "life":  float(p.get("life", 2.0)),
                    "kind":  "generic",
                    "particles": [],
                }
                if scene is not None:
                    scene["particles"].append(emitter)
                put("particles", emitter); put("flow", True)

            elif ntype == "pt_fire":
                # Fire = particle system with color gradient + buoyancy
                em = inp("emitter")
                if em is not None:
                    em["kind"]       = "fire"
                    em["color_hot"]  = p.get("color_hot", "#ffeebb")
                    em["color_cool"] = p.get("color_cool", "#ff4400")
                    em["buoyancy"]   = float(p.get("buoyancy", 1.5))
                    em["intensity"]  = float(p.get("intensity", 1.0))
                put("sim", em); put("flow", True)

            elif ntype == "pt_smoke":
                em = inp("emitter")
                if em is not None:
                    em["kind"] = "smoke"
                    em["density"]   = float(p.get("density", 0.6))
                    em["dissipate"] = float(p.get("dissipate", 0.04))
                put("sim", em); put("flow", True)

            elif ntype == "pt_water":
                em = inp("emitter")
                if em is not None: em["kind"] = "water"
                put("sim", em); put("flow", True)

            elif ntype == "pt_dust":
                em = inp("emitter")
                if em is not None: em["kind"] = "dust"
                put("sim", em); put("flow", True)

            elif ntype == "pt_force":
                # Attach a force to a particle sim (gravity/wind/etc.)
                sim = inp("sim")
                if sim is not None:
                    sim.setdefault("forces", []).append({
                        "type":     p.get("type", "gravity"),
                        "strength": float(p.get("strength", 1.0)),
                    })
                put("flow", True)

            elif ntype == "luna_render":
                # Luna = software renderer. Works on the scene dict.
                # Render AT canvas size so the image is 1:1 (no stretch).
                scene = inp("scene")
                render_p = dict(p)  # copy so we can override w/h
                if scene is not None:
                    vp_cv_pre = scene.get("viewport")
                    if vp_cv_pre is not None:
                        try:
                            _cw = vp_cv_pre.winfo_width()
                            _ch = vp_cv_pre.winfo_height()
                            if _cw > 4 and _ch > 4:
                                render_p["w"] = str(_cw)
                                render_p["h"] = str(_ch)
                        except Exception:
                            pass

                # ── Render + blit. fast=True → wireframe (cheap: no face
                # ── sort, no lighting, no fills) for smooth dragging. ──────
                def _luna_blit(fast=False, _scene=scene, _rp=render_p,
                               _nid=nid):
                    if _scene is None:
                        return None
                    saved_mode = _scene.get("mode")
                    if fast:
                        _scene["mode"] = "wireframe"
                    try:
                        img = _luna_render_scene(self, _scene, _rp)
                    finally:
                        if fast and saved_mode is not None:
                            _scene["mode"] = saved_mode
                    if img is None:
                        return None
                    vp = _scene.get("viewport")
                    if vp is not None:
                        try:
                            from PIL import ImageTk
                            cw = vp.winfo_width()  or img.width
                            ch = vp.winfo_height() or img.height
                            if ((img.width != cw or img.height != ch)
                                    and cw > 4 and ch > 4):
                                disp = img.resize((cw, ch), resample=1)
                            else:
                                disp = img
                            photo = ImageTk.PhotoImage(disp)
                            self._photo_refs = getattr(self, "_photo_refs", {})
                            self._photo_refs[_nid] = photo
                            vp.delete("luna")
                            vp.create_image(cw // 2, ch // 2,
                                            image=photo, tags="luna")
                        except Exception as _e:
                            self.out(f"viewport blit: {_e}", "err")
                    return img

                # ── Coalesced scheduler — at most ONE render in flight.
                # ── Mouse motion fires ~100x/sec; without this the renders
                # ── pile up faster than they finish = the lag. Here, extra
                # ── requests are dropped while one is pending. ─────────────
                _rstate = {"pending": False, "fast": False}
                def _schedule_render(fast=False, _scene=scene):
                    if _rstate["pending"]:
                        if not fast:
                            _rstate["fast"] = False   # full quality wins
                        return
                    _rstate["pending"] = True
                    _rstate["fast"]    = fast
                    def _fire():
                        _rstate["pending"] = False
                        _luna_blit(_rstate["fast"])
                    vp = _scene.get("viewport") if _scene else None
                    if vp is not None:
                        try: vp.after(16, _fire)
                        except Exception: _fire()
                    else:
                        _fire()

                # Initial render — synchronous, full quality.
                _luna_img = _luna_blit(False)
                if _luna_img is not None:
                    put("image", _luna_img)
                if scene is not None:
                    # Re-render re-rasterizes the SAME scene dict — it does
                    # NOT re-run the graph flow. Camera nodes mutate the scene
                    # in place, so a plain re-rasterize already shows the move.
                    scene["_render_fn"]      = lambda: _schedule_render(False)
                    scene["_render_fast_fn"] = lambda: _schedule_render(True)
                put("flow", True)

            elif ntype == "luna_pass":
                # Pass selection — for now just passes the image through
                im = inp("render")
                put("image", im); put("flow", True)

            elif ntype == "luna_denoise":
                im = inp("image")
                if im is not None:
                    try:
                        from PIL import ImageFilter as _F
                        s = float(p.get("strength", 0.5))
                        im = im.filter(_F.GaussianBlur(radius=s*2))
                    except Exception: pass
                put("image", im); put("flow", True)

            elif ntype == "luna_compose":
                a, b = inp("a"), inp("b")
                op = p.get("op", "over")
                try:
                    from PIL import Image
                    if a is not None and b is not None:
                        if a.size != b.size:
                            b = b.resize(a.size)
                        if op == "add":
                            from PIL import ImageChops
                            put("image", ImageChops.add(a, b))
                        elif op == "multiply":
                            from PIL import ImageChops
                            put("image", ImageChops.multiply(a, b))
                        elif op == "screen":
                            from PIL import ImageChops
                            put("image", ImageChops.screen(a, b))
                        elif op == "mix":
                            put("image", Image.blend(a, b, 0.5))
                        else:  # over
                            put("image", a)
                except Exception as ex:
                    self.out(f"❌  compose: {ex}", "err")
                put("flow", True)

            elif ntype == "mod_subdiv":
                # Bumps the resolution params on the input mesh. Only really
                # affects sphere/torus/cyl/cone (procedural-density meshes).
                m = inp("mesh")
                if m is not None:
                    levels = max(1, int(float(p.get("levels", 2))))
                    mp = m.get("params", {})
                    if m["kind"] in ("sphere",):
                        mp["rings"] = int(mp.get("rings", 8)) * levels
                        mp["segments"] = int(mp.get("segments", 12)) * levels
                    elif m["kind"] == "torus":
                        # Renderer reads _subdiv from mesh.params
                        mp["_subdiv"] = levels
                    elif m["kind"] in ("cyl", "cone"):
                        mp["segments"] = int(mp.get("segments", 16)) * levels
                    self.out(f"⊞  Subdivided ×{levels} on {m['kind']}", "sys")
                put("mesh", m); put("flow", True)

            elif ntype == "transform":
                m = inp("mesh")
                if m is not None:
                    m["tx"] = float(p.get("px", m.get("tx", 0))) + m.get("tx", 0) * 0
                    m["ty"] = float(p.get("py", m.get("ty", 0)))
                    m["tz"] = float(p.get("pz", m.get("tz", 0)))
                put("mesh", m); put("flow", True)

            elif ntype == "import_obj":
                # Wavefront OBJ parser — pure Python, no deps. Supports
                # vertices (v) + faces (f, with optional /uv/normal indices).
                scene = inp("scene"); path = str(inp("path") or "")
                if not os.path.isfile(path):
                    self.out(f"❌  OBJ not found: {path}", "err")
                    put("flow", True)
                else:
                    try:
                        verts, faces = [], []
                        with open(path, encoding="utf-8", errors="ignore") as f:
                            for line in f:
                                if line.startswith("v "):
                                    parts = line.split()
                                    verts.append((float(parts[1]),
                                                  float(parts[2]),
                                                  float(parts[3])))
                                elif line.startswith("f "):
                                    fidx = []
                                    for tok in line.split()[1:]:
                                        # Handle "v", "v/uv", "v/uv/n", "v//n"
                                        v_idx = int(tok.split("/")[0])
                                        # OBJ is 1-indexed; negative = relative
                                        if v_idx < 0: v_idx = len(verts) + v_idx + 1
                                        fidx.append(v_idx - 1)
                                    if len(fidx) >= 3:
                                        faces.append(tuple(fidx))
                        mesh = {
                            "kind":     "imported",
                            "params":   {"_verts": verts, "_faces": faces,
                                         "scale": float(p.get("scale", 1.0))},
                            "tx":       float(p.get("x", 0)),
                            "ty":       float(p.get("y", 0)),
                            "tz":       float(p.get("z", 0)),
                            "name":     os.path.basename(path)[:20],
                            "material": {"color": p.get("color", "#aaccee")},
                        }
                        if scene is not None:
                            scene["meshes"].append(mesh)
                        self.out(
                            f"📂  Loaded {os.path.basename(path)}: "
                            f"{len(verts)} verts, {len(faces)} faces", "sys")
                        put("mesh", mesh)
                    except Exception as ex:
                        self.out(f"❌  OBJ parse: {ex}", "err")
                    put("flow", True)

            elif ntype == "import_stl":
                # Binary STL parser — also pure Python.
                import struct
                scene = inp("scene"); path = str(inp("path") or "")
                if not os.path.isfile(path):
                    self.out(f"❌  STL not found: {path}", "err")
                    put("flow", True)
                else:
                    try:
                        verts, faces, vmap = [], [], {}
                        def _add(v):
                            key = (round(v[0],5), round(v[1],5), round(v[2],5))
                            if key not in vmap:
                                vmap[key] = len(verts); verts.append(v)
                            return vmap[key]
                        with open(path, "rb") as f:
                            head = f.read(80)
                            count_bytes = f.read(4)
                            if len(count_bytes) < 4:
                                # ASCII STL fallback
                                f.seek(0); txt = f.read().decode("ascii","ignore")
                                tri = []
                                for line in txt.splitlines():
                                    line = line.strip()
                                    if line.startswith("vertex"):
                                        parts = line.split()
                                        tri.append((float(parts[1]),
                                                    float(parts[2]),
                                                    float(parts[3])))
                                        if len(tri) == 3:
                                            faces.append((_add(tri[0]),
                                                          _add(tri[1]),
                                                          _add(tri[2])))
                                            tri = []
                            else:
                                n = struct.unpack("<I", count_bytes)[0]
                                for _ in range(n):
                                    data = f.read(50)
                                    if len(data) < 50: break
                                    nx,ny,nz, ax,ay,az, bx,by,bz, cx,cy,cz = \
                                        struct.unpack("<12f", data[:48])
                                    faces.append((
                                        _add((ax,ay,az)),
                                        _add((bx,by,bz)),
                                        _add((cx,cy,cz))))
                        mesh = {
                            "kind":     "imported",
                            "params":   {"_verts": verts, "_faces": faces,
                                         "scale": float(p.get("scale", 1.0))},
                            "tx": 0, "ty": 0, "tz": 0,
                            "name":     os.path.basename(path)[:20],
                            "material": {"color": "#aaccee"},
                        }
                        if scene is not None:
                            scene["meshes"].append(mesh)
                        self.out(
                            f"📂  STL: {len(verts)} verts, {len(faces)} tris",
                            "sys")
                        put("mesh", mesh)
                    except Exception as ex:
                        self.out(f"❌  STL parse: {ex}", "err")
                    put("flow", True)

            elif ntype == "import_fbx":
                # FBX requires Autodesk FBX SDK or third-party reader.
                # Try `pyassimp` first (BSD-licensed, supports FBX).
                scene = inp("scene"); path = str(inp("path") or "")
                try:
                    import pyassimp
                    with pyassimp.load(path) as ai_scene:
                        ai_mesh = ai_scene.meshes[0]
                        verts = [tuple(v) for v in ai_mesh.vertices]
                        faces = [tuple(int(i) for i in f)
                                 for f in ai_mesh.faces if len(f) >= 3]
                        mesh = {
                            "kind": "imported",
                            "params": {"_verts": verts, "_faces": faces,
                                       "scale": float(p.get("scale", 1.0))},
                            "tx": 0, "ty": 0, "tz": 0,
                            "name": os.path.basename(path)[:20],
                            "material": {"color": "#aaccee"},
                        }
                        if scene is not None:
                            scene["meshes"].append(mesh)
                        self.out(
                            f"📂  FBX via pyassimp: {len(verts)} verts",
                            "sys")
                        put("mesh", mesh)
                except ImportError:
                    self.out(
                        "🚧  FBX needs pyassimp — Gate: pip install pyassimp",
                        "err")
                except Exception as ex:
                    self.out(f"❌  FBX: {ex}", "err")
                put("flow", True)

            elif ntype == "import_usd":
                # USD = Pixar Universal Scene Description.
                # Needs `usd-core` (Apache 2.0 — safe to bundle).
                scene = inp("scene"); path = str(inp("path") or "")
                try:
                    from pxr import Usd, UsdGeom
                    stage = Usd.Stage.Open(path)
                    verts, faces = [], []
                    for prim in stage.Traverse():
                        if prim.IsA(UsdGeom.Mesh):
                            m = UsdGeom.Mesh(prim)
                            pts   = m.GetPointsAttr().Get() or []
                            counts= m.GetFaceVertexCountsAttr().Get() or []
                            inds  = m.GetFaceVertexIndicesAttr().Get() or []
                            base = len(verts)
                            verts.extend([tuple(p) for p in pts])
                            ofs = 0
                            for c in counts:
                                if c >= 3:
                                    faces.append(tuple(base + inds[ofs+i]
                                                       for i in range(c)))
                                ofs += c
                    mesh = {
                        "kind": "imported",
                        "params": {"_verts": verts, "_faces": faces,
                                   "scale": float(p.get("scale", 1.0))},
                        "tx": 0, "ty": 0, "tz": 0,
                        "name": os.path.basename(path)[:20],
                        "material": {"color": "#aaccee"},
                    }
                    if scene is not None:
                        scene["meshes"].append(mesh)
                    self.out(f"📂  USD: {len(verts)} verts", "sys")
                    put("mesh", mesh)
                except ImportError:
                    self.out(
                        "🚧  USD needs usd-core — Gate: pip install usd-core",
                        "err")
                except Exception as ex:
                    self.out(f"❌  USD: {ex}", "err")
                put("flow", True)

            elif ntype == "import_gltf":
                # glTF/GLB via pygltflib (MIT licensed)
                scene = inp("scene"); path = str(inp("path") or "")
                try:
                    import pygltflib, struct
                    gltf = pygltflib.GLTF2().load(path)
                    # Just grab first mesh's first primitive
                    mesh_obj = gltf.meshes[0]
                    prim = mesh_obj.primitives[0]
                    pos_acc = gltf.accessors[prim.attributes.POSITION]
                    bv = gltf.bufferViews[pos_acc.bufferView]
                    buf = gltf.binary_blob() or b""
                    data = buf[bv.byteOffset:bv.byteOffset + bv.byteLength]
                    verts = []
                    for i in range(pos_acc.count):
                        x,y,z = struct.unpack_from("<fff", data, i*12)
                        verts.append((x,y,z))
                    idx_acc = gltf.accessors[prim.indices]
                    bv2 = gltf.bufferViews[idx_acc.bufferView]
                    idata = buf[bv2.byteOffset:bv2.byteOffset + bv2.byteLength]
                    faces = []
                    for i in range(0, idx_acc.count, 3):
                        a,b,c = struct.unpack_from("<HHH", idata, i*2)
                        faces.append((a, b, c))
                    mesh = {
                        "kind": "imported",
                        "params": {"_verts": verts, "_faces": faces,
                                   "scale": 1.0},
                        "tx": 0, "ty": 0, "tz": 0,
                        "name": os.path.basename(path)[:20],
                        "material": {"color": "#aaccee"},
                    }
                    if scene is not None:
                        scene["meshes"].append(mesh)
                    self.out(f"📂  glTF: {len(verts)} verts", "sys")
                    put("mesh", mesh)
                except ImportError:
                    self.out(
                        "🚧  glTF needs pygltflib — Gate: pip install pygltflib",
                        "err")
                except Exception as ex:
                    self.out(f"❌  glTF: {ex}", "err")
                put("flow", True)

            elif ntype == "export_obj":
                # Write all scene meshes to a single OBJ file.
                scene = inp("scene"); path = str(inp("path") or "")
                if scene is None or not path:
                    self.out("⚠  export_obj needs scene + path", "err")
                else:
                    try:
                        os.makedirs(os.path.dirname(os.path.abspath(path))
                                    or ".", exist_ok=True)
                        with open(path, "w", encoding="utf-8") as f:
                            f.write("# Exported by NodeBase / Donut3D\n")
                            v_offset = 1
                            for mi, m in enumerate(scene.get("meshes", [])):
                                vs, fs = _build_mesh(
                                    m["kind"], m["params"],
                                    m.get("tx", 0), m.get("ty", 0),
                                    m.get("tz", 0))
                                f.write(f"o {m.get('name', 'mesh_'+str(mi))}\n")
                                for v in vs:
                                    f.write(f"v {v[0]:.6f} {v[1]:.6f} {v[2]:.6f}\n")
                                for fc in fs:
                                    line = "f " + " ".join(
                                        str(v_offset + i) for i in fc)
                                    f.write(line + "\n")
                                v_offset += len(vs)
                        self.out(
                            f"💾  OBJ exported: {os.path.basename(path)}",
                            "sys")
                    except Exception as ex:
                        self.out(f"❌  export_obj: {ex}", "err")
                put("flow", True)

            # ── GFX stubs — image processing nodes ───────────────────────
            elif ntype == "gfx_brush":
                cv = inp("canvas"); x = float(inp("x") or 0); y = float(inp("y") or 0)
                r = float(p.get("radius", 8)); color = p.get("color", "#ff0000")
                if cv is not None:
                    try: cv.create_oval(x-r, y-r, x+r, y+r, fill=color, outline="")
                    except Exception: pass
                put("flow", True)

            elif ntype == "gfx_erase":
                cv = inp("canvas"); x = float(inp("x") or 0); y = float(inp("y") or 0)
                r = float(p.get("radius", 12)); bg = p.get("bg", "#ffffff")
                if cv is not None:
                    try: cv.create_oval(x-r, y-r, x+r, y+r, fill=bg, outline="")
                    except Exception: pass
                put("flow", True)

            elif ntype == "gfx_layer":
                try:
                    from PIL import Image
                    a = inp("a"); b = inp("b"); op = p.get("op", "over")
                    if a and b:
                        if a.mode != "RGBA": a = a.convert("RGBA")
                        if b.mode != "RGBA": b = b.convert("RGBA")
                        if a.size != b.size: b = b.resize(a.size)
                        result = Image.alpha_composite(a, b) if op == "over" else Image.blend(a.convert("RGB"), b.convert("RGB"), 0.5)
                        put("image", result)
                    else:
                        put("image", a or b)
                except Exception as ex:
                    self.out(f"❌  gfx_layer: {ex}", "err")
                put("flow", True)

            elif ntype == "gfx_blend":
                try:
                    from PIL import Image, ImageChops
                    a = inp("a"); b = inp("b"); mode = p.get("mode", "normal")
                    alpha = float(p.get("alpha", 1.0))
                    if a and b:
                        if a.size != b.size: b = b.resize(a.size)
                        ops = {"multiply": ImageChops.multiply, "screen": ImageChops.screen,
                               "add": ImageChops.add, "subtract": ImageChops.subtract,
                               "difference": ImageChops.difference}
                        if mode in ops:
                            out_img = ops[mode](a.convert("RGB"), b.convert("RGB"))
                        else:
                            out_img = Image.blend(a.convert("RGB"), b.convert("RGB"), alpha)
                        put("image", out_img)
                    else:
                        put("image", a or b)
                except Exception as ex:
                    self.out(f"❌  gfx_blend: {ex}", "err")
                put("flow", True)

            elif ntype == "gfx_mask":
                try:
                    from PIL import Image
                    base = inp("image"); mask = inp("mask")
                    if base and mask:
                        b = base.convert("RGBA")
                        m = mask.convert("L").resize(b.size)
                        r, g, gr, a_ = b.split()
                        out_img = Image.merge("RGBA", (r, g, gr, m))
                        put("image", out_img)
                    else:
                        put("image", base)
                except Exception as ex:
                    self.out(f"❌  gfx_mask: {ex}", "err")
                put("flow", True)

            elif ntype == "gfx_color":
                try:
                    from PIL import Image, ImageEnhance, ImageOps
                    im = inp("image")
                    if im is not None:
                        brightness = float(p.get("brightness", 1.0))
                        contrast   = float(p.get("contrast",   1.0))
                        saturation = float(p.get("saturation", 1.0))
                        hue_shift  = float(p.get("hue",        0))
                        im = ImageEnhance.Brightness(im).enhance(brightness)
                        im = ImageEnhance.Contrast(im).enhance(contrast)
                        im = ImageEnhance.Color(im).enhance(saturation)
                        put("image", im)
                        self.out(f"☼  Color adjust: b={brightness} c={contrast} s={saturation}", "sys")
                except Exception as ex:
                    self.out(f"❌  gfx_color: {ex}", "err")
                put("flow", True)

            elif ntype == "gfx_sharpen":
                try:
                    from PIL import ImageFilter
                    im = inp("image")
                    if im is not None:
                        s = float(p.get("strength", 1.0))
                        for _ in range(max(1, int(s))):
                            im = im.filter(ImageFilter.SHARPEN)
                        put("image", im)
                except Exception as ex:
                    self.out(f"❌  gfx_sharpen: {ex}", "err")
                put("flow", True)

            elif ntype == "gfx_select":
                # Returns a bounding-box tuple as a list for downstream use
                x = float(p.get("x", 0)); y = float(p.get("y", 0))
                w2 = float(p.get("w", 100)); h2 = float(p.get("h", 100))
                put("selection", [x, y, x+w2, y+h2])
                put("flow", True)

            elif ntype == "gfx_xform":
                try:
                    from PIL import Image
                    im = inp("image")
                    if im is not None:
                        angle  = float(p.get("angle", 0))
                        flip_h = p.get("flip_h", "False") == "True"
                        flip_v = p.get("flip_v", "False") == "True"
                        sx = float(p.get("sx", 1.0)); sy = float(p.get("sy", 1.0))
                        if angle: im = im.rotate(-angle, expand=True)
                        if flip_h: im = im.transpose(Image.FLIP_LEFT_RIGHT)
                        if flip_v: im = im.transpose(Image.FLIP_TOP_BOTTOM)
                        if sx != 1.0 or sy != 1.0:
                            nw = int(im.width * sx); nh = int(im.height * sy)
                            if nw > 0 and nh > 0: im = im.resize((nw, nh))
                        put("image", im)
                except Exception as ex:
                    self.out(f"❌  gfx_xform: {ex}", "err")
                put("flow", True)

            elif ntype == "gfx_text":
                try:
                    from PIL import ImageDraw, ImageFont, Image
                    im = inp("image") or Image.new("RGB", (400, 200), "#ffffff")
                    draw = ImageDraw.Draw(im)
                    text = str(inp("text") or p.get("text", "Hello"))
                    x = float(p.get("x", 10)); y = float(p.get("y", 10))
                    color = p.get("color", "#000000")
                    size = int(float(p.get("size", 24)))
                    try:
                        font = ImageFont.truetype("arial.ttf", size)
                    except Exception:
                        font = ImageFont.load_default()
                    draw.text((x, y), text, fill=color, font=font)
                    put("image", im)
                except Exception as ex:
                    self.out(f"❌  gfx_text: {ex}", "err")
                put("flow", True)

            elif ntype == "gfx_filter":
                try:
                    from PIL import ImageFilter, Image
                    im = inp("image")
                    if im is not None:
                        flt = p.get("filter", "EDGE_ENHANCE")
                        fmap = {
                            "EDGE_ENHANCE": ImageFilter.EDGE_ENHANCE,
                            "EMBOSS": ImageFilter.EMBOSS,
                            "FIND_EDGES": ImageFilter.FIND_EDGES,
                            "SMOOTH": ImageFilter.SMOOTH,
                            "DETAIL": ImageFilter.DETAIL,
                            "CONTOUR": ImageFilter.CONTOUR,
                        }
                        if flt in fmap:
                            im = im.filter(fmap[flt])
                        put("image", im)
                except Exception as ex:
                    self.out(f"❌  gfx_filter: {ex}", "err")
                put("flow", True)

            # ── UI stub implementations ───────────────────────────────────
            elif ntype == "ui_toolbar":
                self._ui_kept = getattr(self, "_ui_kept", {})
                if nid in self._ui_kept and self._ui_kept[nid].winfo_exists():
                    put("toolbar", self._ui_kept[nid]); put("flow", True)
                else:
                    parent = inp("window")
                    if parent is not None:
                        tb2 = tk.Frame(parent, bg=p.get("bg", "#0e1020"), height=36)
                        tb2.pack(fill="x", side=p.get("side", "top"))
                        tb2.pack_propagate(False)
                        tb2._pack_dir = "horizontal"   # buttons pack left→right
                        self._ui_kept[nid] = tb2
                        put("toolbar", tb2)
                    put("flow", True)

            elif ntype == "ui_menubar":
                self._ui_kept = getattr(self, "_ui_kept", {})
                if nid in self._ui_kept:
                    put("menubar", self._ui_kept[nid]); put("flow", True)
                else:
                    parent = inp("window")
                    if parent is not None:
                        try:
                            mb = tk.Menu(parent)
                            parent.config(menu=mb)
                            self._ui_kept[nid] = mb
                            put("menubar", mb)
                        except Exception: pass
                    put("flow", True)

            elif ntype == "ui_layers":
                self._ui_kept = getattr(self, "_ui_kept", {})
                if nid in self._ui_kept and self._ui_kept[nid].winfo_exists():
                    put("panel", self._ui_kept[nid]); put("flow", True)
                else:
                    parent = inp("window")
                    # Header label is configurable. Default is "Library"
                    # (was "Outliner") — Library is the hierarchical view
                    # of scene contents (Collection → Camera, Cube, Light).
                    hdr = p.get("label", "  ☰  Library")
                    if parent is not None:
                        pdir = getattr(parent, "_pack_dir", "root")
                        if pdir == "vertical":
                            fr = tk.Frame(parent, bg="#0e1220")
                            fr.pack(side="top", fill="x")
                            tk.Label(fr, text=hdr, bg="#131830",
                                     fg="#6699cc",
                                     font=("Segoe UI", 8, "bold")
                                     ).pack(fill="x", ipady=3)
                        else:
                            fr = tk.Frame(parent, bg="#0e1220", width=240)
                            fr.pack(side="right", fill="y")
                            fr.pack_propagate(False)
                            tk.Label(fr, text=hdr, bg="#131830",
                                     fg="#6699cc",
                                     font=("Segoe UI", 8, "bold")
                                     ).pack(fill="x", ipady=3)
                        self._ui_kept[nid] = fr
                        put("panel", fr)
                    put("flow", True)

            elif ntype == "ui_inspect":
                self._ui_kept = getattr(self, "_ui_kept", {})
                if nid in self._ui_kept and self._ui_kept[nid].winfo_exists():
                    put("panel", self._ui_kept[nid]); put("flow", True)
                else:
                    parent = inp("window")
                    if parent is not None:
                        pdir = getattr(parent, "_pack_dir", "root")
                        if pdir == "vertical":
                            # inside a side panel — fill remaining vertical space
                            fr = tk.Frame(parent, bg="#0a0e1a")
                            fr.pack(side="top", fill="both", expand=True)
                            tk.Label(fr, text="  🔎  Inspector", bg="#0f1428",
                                     fg="#6699cc", font=("Segoe UI", 8, "bold")).pack(fill="x", ipady=3)
                        else:
                            fr = tk.Frame(parent, bg="#0a0e1a", width=240)
                            fr.pack(side="right", fill="y")
                            fr.pack_propagate(False)
                            tk.Label(fr, text="  🔎  Inspector", bg="#0f1428",
                                     fg="#6699cc", font=("Segoe UI", 8, "bold")).pack(fill="x", ipady=3)
                        self._ui_kept[nid] = fr
                        put("panel", fr)
                    put("flow", True)

            elif ntype == "ui_timeline":
                self._ui_kept = getattr(self, "_ui_kept", {})
                if nid in self._ui_kept and self._ui_kept[nid].winfo_exists():
                    put("timeline", self._ui_kept[nid]); put("flow", True)
                else:
                    parent = inp("window")
                    if parent is not None:
                        h2 = int(float(p.get("h", 120)))
                        fr = tk.Frame(parent, bg="#0a0a18", height=h2)
                        fr.pack(fill="x", side="bottom")
                        fr.pack_propagate(False)
                        cv_tl = tk.Canvas(fr, bg="#0a0a18", height=h2,
                                          highlightthickness=0)
                        cv_tl.pack(fill="both", expand=True)
                        # Draw ruler lines
                        fps = int(float(p.get("fps", 30)))
                        dur = int(float(p.get("duration", 10)))
                        total_frames = fps * dur
                        for f2 in range(0, total_frames, fps):
                            x_pos = f2 * 4
                            cv_tl.create_line(x_pos, 0, x_pos, h2, fill="#334466", width=1)
                            cv_tl.create_text(x_pos+2, 4, text=f"{f2//fps}s",
                                              fill="#557799", font=("Consolas", 7), anchor="nw")
                        self._ui_kept[nid] = fr
                        put("timeline", fr)
                    put("flow", True)

            elif ntype in ("ui_mesh_menu", "ui_light_menu", "ui_add_menu"):
                self._ui_kept = getattr(self, "_ui_kept", {})
                if nid in self._ui_kept and self._ui_kept[nid].winfo_exists():
                    put("flow", True)
                else:
                    parent = inp("window")
                    scene  = inp("scene")
                    if parent is not None:
                        import math as _math

                        # ── shared primitive adder ──────────────────────────
                        def _add_mesh(shape, sc=scene, ex=self):
                            # Build a mesh dict in the format the Luna
                            # renderer expects: kind + params + tx/ty/tz.
                            # (The old format used type/x/y/z and crashed
                            #  the renderer with KeyError: 'params'.)
                            clr = {"plane":"#aaaaaa","cube":"#6688cc",
                                   "circle":"#88ccee","uv_sphere":"#88ccaa",
                                   "ico_sphere":"#aaccaa","cylinder":"#aaccff",
                                   "cone":"#cc66aa","torus":"#cc8866",
                                   "grid":"#668877","monkey":"#cc8844"}.get(shape,"#8899aa")
                            # shape -> (kind, params, spawn position)
                            prims = {
                                "plane":     ("plane",  {"size":2.0},                          (0,-0.99,0)),
                                "cube":      ("cube",   {"size":0.8},                          (1.5,0,0)),
                                "circle":    ("plane",  {"size":0.8},                          (0,0,0)),
                                "uv_sphere": ("sphere", {"radius":0.7},                        (-1.5,0,0)),
                                "ico_sphere":("sphere", {"radius":0.7},                        (1.5,0,1.5)),
                                "cylinder":  ("cyl",    {"radius":0.5,"height":1.5},           (0,0,-1.5)),
                                "cone":      ("cone",   {"radius":0.7,"height":1.5},           (0,0,1.5)),
                                "torus":     ("torus",  {"size":1.0,"major":1.0,"minor":0.35}, (0,0.5,0)),
                                "grid":      ("grid",   {"size":2.0,"divs":8},                 (0,-0.98,0)),
                                "monkey":    ("cube",   {"size":0.8},                          (0,0,0)),
                            }
                            kind, params, pos = prims.get(
                                shape, ("cube", {"size":0.8}, (0,0,0)))
                            if sc and hasattr(sc, "get") and "meshes" in sc:
                                import uuid as _uuid
                                mesh = {
                                    "kind":     kind,
                                    "params":   dict(params),
                                    "tx": pos[0], "ty": pos[1], "tz": pos[2],
                                    "name":     f"{shape}_{_uuid.uuid4().hex[:4]}",
                                    "material": {"color": clr},
                                }
                                sc["meshes"].append(mesh)
                                ex.out(f"⊞  Added {shape} to scene", "sys")

                        def _add_light(kind, sc=scene, ex=self):
                            # Lights MUST use float values + an x/y/z position,
                            # exactly like the light_* nodes — otherwise the
                            # gizmo can't grab/move them (string "3" + delta
                            # crashes). Every light here is selectable + movable;
                            # sun also carries a direction it can be rotated by.
                            lights = {
                                "sun":  {"type":"sun",
                                         "x": 0.0, "y": 6.0, "z": 0.0,
                                         "dir_x": -0.4, "dir_y": -1.0, "dir_z": -0.3,
                                         "rx": 0.0, "ry": 0.0, "rz": 0.0,
                                         "intensity": 1.0, "color": "#fff8dd"},
                                "omni": {"type":"omni",
                                         "x": 3.0, "y": 4.0, "z": 3.0,
                                         "intensity": 0.8, "color": "#aaccff"},
                                "spot": {"type":"spot",
                                         "x": 0.0, "y": 5.0, "z": 0.0,
                                         "rx": 0.0, "ry": 0.0, "rz": 0.0,
                                         "angle": 45.0,
                                         "intensity": 1.5, "color": "#ffffff"},
                                "area": {"type":"area",
                                         "x": 0.0, "y": 4.0, "z": 2.0,
                                         "rx": 0.0, "ry": 0.0, "rz": 0.0,
                                         "intensity": 2.0, "color": "#ffffee"},
                            }
                            cfg = dict(lights.get(kind, lights["omni"]))
                            if sc and hasattr(sc, "get") and "lights" in sc:
                                import uuid as _uuid
                                cfg["id"]   = f"{kind}_{_uuid.uuid4().hex[:4]}"
                                cfg["name"] = cfg["id"]
                                sc["lights"].append(cfg)
                                ex.out(f"☀  Added {kind} light — click it in "
                                       f"the viewport to move / rotate", "sys")

                        pack_dir = getattr(parent, "_pack_dir", "horizontal")
                        pack_s   = "left" if pack_dir == "horizontal" else "top"

                        if ntype == "ui_mesh_menu":
                            lbl = p.get("label", "⊞ Mesh ▾")
                            btn_m = tk.Button(parent, text=lbl,
                                              bg="#1e2a1e", fg="#88cc88",
                                              relief="flat", bd=0, padx=8, pady=4,
                                              font=("Segoe UI", 8, "bold"),
                                              activebackground="#2a3a2a",
                                              cursor="hand2")
                            btn_m.pack(side=pack_s, padx=2, pady=2)
                            menu_m = tk.Menu(parent, tearoff=0, bg="#1a1f2e",
                                             fg="white", activebackground="#3a7bd5",
                                             bd=0, relief="flat", font=("Segoe UI", 9))
                            mesh_items = [
                                ("⬚  Plane",      "plane"),
                                ("⬛  Cube",       "cube"),
                                ("○  Circle",      "circle"),
                                ("⬤  UV Sphere",   "uv_sphere"),
                                ("◈  Ico Sphere",  "ico_sphere"),
                                ("⊜  Cylinder",    "cylinder"),
                                ("△  Cone",        "cone"),
                                ("◯  Torus",       "torus"),
                                ("⊞  Grid",        "grid"),
                            ]
                            for item_lbl, item_key in mesh_items:
                                menu_m.add_command(label=f"  {item_lbl}",
                                                   command=lambda k=item_key: _add_mesh(k))
                            def _show_mesh(e=None, b=btn_m, m=menu_m):
                                m.tk_popup(b.winfo_rootx(), b.winfo_rooty() + b.winfo_height())
                            btn_m.config(command=lambda b=btn_m, m=menu_m: m.tk_popup(b.winfo_rootx(), b.winfo_rooty() + b.winfo_height()))
                            self._ui_kept[nid] = btn_m

                        elif ntype == "ui_light_menu":
                            lbl = p.get("label", "☀ Light ▾")
                            btn_l = tk.Button(parent, text=lbl,
                                              bg="#1e1a0e", fg="#ccaa44",
                                              relief="flat", bd=0, padx=8, pady=4,
                                              font=("Segoe UI", 8, "bold"),
                                              activebackground="#2e2a1e",
                                              cursor="hand2")
                            btn_l.pack(side=pack_s, padx=2, pady=2)
                            menu_l = tk.Menu(parent, tearoff=0, bg="#1a1f2e",
                                             fg="white", activebackground="#cc9922",
                                             bd=0, relief="flat", font=("Segoe UI", 9))
                            light_items = [
                                ("☀  Sun",   "sun"),
                                ("💡  Omni",  "omni"),
                                ("🔦  Spot",  "spot"),
                                ("▱  Area",   "area"),
                            ]
                            for item_lbl, item_key in light_items:
                                menu_l.add_command(label=f"  {item_lbl}",
                                                   command=lambda k=item_key: _add_light(k))
                            btn_l.config(command=lambda b=btn_l, m=menu_l: m.tk_popup(b.winfo_rootx(), b.winfo_rooty() + b.winfo_height()))
                            self._ui_kept[nid] = btn_l

                        elif ntype == "ui_add_menu":
                            # Combined Add menu (Blender-style Shift+A)
                            btn_a = tk.Button(parent, text="⊕ Add ▾",
                                              bg="#1a2030", fg="#88aaff",
                                              relief="flat", bd=0, padx=8, pady=4,
                                              font=("Segoe UI", 8, "bold"),
                                              activebackground="#2a3050",
                                              cursor="hand2")
                            btn_a.pack(side=pack_s, padx=2, pady=2)
                            menu_a = tk.Menu(parent, tearoff=0, bg="#1a1f2e",
                                             fg="white", activebackground="#3a7bd5",
                                             bd=0, relief="flat", font=("Segoe UI", 9))
                            sub_mesh = tk.Menu(menu_a, tearoff=0, bg="#1a1f2e",
                                               fg="white", activebackground="#3a7bd5",
                                               bd=0, relief="flat", font=("Segoe UI", 9))
                            for lbl2, key2 in [("⬚ Plane","plane"),("⬛ Cube","cube"),
                                               ("⬤ UV Sphere","uv_sphere"),
                                               ("◈ Ico Sphere","ico_sphere"),
                                               ("⊜ Cylinder","cylinder"),("△ Cone","cone"),
                                               ("◯ Torus","torus"),("⊞ Grid","grid")]:
                                sub_mesh.add_command(label=f"  {lbl2}",
                                                     command=lambda k=key2: _add_mesh(k))
                            sub_light = tk.Menu(menu_a, tearoff=0, bg="#1a1f2e",
                                                fg="white", activebackground="#cc9922",
                                                bd=0, relief="flat", font=("Segoe UI", 9))
                            for lbl3, key3 in [("☀ Sun","sun"),("💡 Omni","omni"),
                                               ("🔦 Spot","spot"),("▱ Area","area")]:
                                sub_light.add_command(label=f"  {lbl3}",
                                                      command=lambda k=key3: _add_light(k))
                            menu_a.add_cascade(label="  ⊞  Mesh  ▸",  menu=sub_mesh)
                            menu_a.add_cascade(label="  ☀  Light ▸",  menu=sub_light)
                            btn_a.config(command=lambda b=btn_a, m=menu_a: m.tk_popup(b.winfo_rootx(), b.winfo_rooty() + b.winfo_height()))
                            self._ui_kept[nid] = btn_a
                    put("flow", True)

            elif ntype == "ui_vp_2d":
                self._ui_kept = getattr(self, "_ui_kept", {})
                if nid in self._ui_kept and self._ui_kept[nid].winfo_exists():
                    put("canvas", self._ui_kept[nid]); put("flow", True)
                else:
                    parent = inp("window")
                    if parent is None: parent = tk.Toplevel()
                    vw = int(float(p.get("w", 640))); vh = int(float(p.get("h", 480)))
                    cv2 = tk.Canvas(parent, width=vw, height=vh,
                                    bg=p.get("bg", "#1a1a1a"),
                                    highlightthickness=0)
                    cv2.pack(fill="both", expand=True)
                    # Basic pan/zoom
                    _pan2 = {"x": 0, "y": 0, "dx": 0, "dy": 0}
                    cv2.bind("<ButtonPress-2>", lambda e: _pan2.update(dx=e.x, dy=e.y))
                    cv2.bind("<B2-Motion>", lambda e: (
                        _pan2.update(x=_pan2["x"]+(e.x-_pan2["dx"]),
                                     y=_pan2["y"]+(e.y-_pan2["dy"]),
                                     dx=e.x, dy=e.y)))
                    self._ui_kept[nid] = cv2
                    put("canvas", cv2)
                put("flow", True)

            # ── VIDEO nodes ──────────────────────────────────────────────
            elif ntype == "vid_load":
                path = str(inp("path") or p.get("path", ""))
                try:
                    import cv2 as _cv2
                    cap = _cv2.VideoCapture(path)
                    fps2 = cap.get(_cv2.CAP_PROP_FPS) or 30
                    frame_count = int(cap.get(_cv2.CAP_PROP_FRAME_COUNT))
                    duration = frame_count / fps2 if fps2 else 0
                    put("video", cap)
                    put("fps", float(fps2))
                    put("duration", float(duration))
                    put("frames", float(frame_count))
                    self.out(f"🎬  Loaded: {os.path.basename(path)} "
                             f"| {frame_count} frames @ {fps2:.1f}fps "
                             f"| {duration:.1f}s", "sys")
                except ImportError:
                    self.out("🚧  vid_load needs opencv-python — Gate: pip install opencv-python", "err")
                except Exception as ex:
                    self.out(f"❌  vid_load: {ex}", "err")
                put("flow", True)

            elif ntype == "vid_extract":
                try:
                    import cv2 as _cv2
                    from PIL import Image
                    cap = inp("video")
                    frame_n = int(float(inp("frame") or p.get("frame", 0)))
                    if cap is not None:
                        cap.set(_cv2.CAP_PROP_POS_FRAMES, frame_n)
                        ret, frame = cap.read()
                        if ret:
                            frame_rgb = _cv2.cvtColor(frame, _cv2.COLOR_BGR2RGB)
                            img = Image.fromarray(frame_rgb)
                            put("image", img)
                            put("frame_num", float(frame_n))
                            self.out(f"⊟  Frame {frame_n} extracted", "sys")
                        else:
                            self.out(f"❌  Could not read frame {frame_n}", "err")
                except ImportError:
                    self.out("🚧  vid_extract needs opencv-python", "err")
                except Exception as ex:
                    self.out(f"❌  vid_extract: {ex}", "err")
                put("flow", True)

            elif ntype == "vid_chroma":
                try:
                    import cv2 as _cv2
                    import numpy as np
                    from PIL import Image
                    im = inp("image")
                    if im is not None:
                        frame = np.array(im.convert("RGB"))
                        bgr = _cv2.cvtColor(frame, _cv2.COLOR_RGB2BGR)
                        hsv = _cv2.cvtColor(bgr, _cv2.COLOR_BGR2HSV)
                        key_color = p.get("color", "green")
                        color_ranges = {
                            "green":  ((35, 50, 50), (85, 255, 255)),
                            "blue":   ((100, 50, 50), (130, 255, 255)),
                            "red":    ((0, 50, 50), (10, 255, 255)),
                        }
                        lo, hi = color_ranges.get(key_color, color_ranges["green"])
                        mask2 = _cv2.inRange(hsv, np.array(lo), np.array(hi))
                        tol = int(float(p.get("tolerance", 30)))
                        kernel = np.ones((tol//5+1, tol//5+1), np.uint8)
                        mask2 = _cv2.morphologyEx(mask2, _cv2.MORPH_OPEN, kernel)
                        mask2 = _cv2.dilate(mask2, kernel, iterations=1)
                        result = _cv2.bitwise_and(bgr, bgr, mask=_cv2.bitwise_not(mask2))
                        result_rgba = _cv2.cvtColor(result, _cv2.COLOR_BGR2RGBA)
                        result_rgba[:, :, 3] = _cv2.bitwise_not(mask2)
                        img_out = Image.fromarray(result_rgba)
                        put("image", img_out)
                        put("mask", Image.fromarray(mask2))
                        self.out("🟢  Chroma key applied", "sys")
                except ImportError:
                    self.out("🚧  vid_chroma needs opencv-python + numpy", "err")
                except Exception as ex:
                    self.out(f"❌  vid_chroma: {ex}", "err")
                put("flow", True)

            elif ntype == "vid_range":
                try:
                    import cv2 as _cv2
                    import numpy as np
                    from PIL import Image
                    im = inp("image")
                    if im is not None:
                        frame = np.array(im.convert("RGB"))
                        bgr = _cv2.cvtColor(frame, _cv2.COLOR_RGB2BGR)
                        hsv = _cv2.cvtColor(bgr, _cv2.COLOR_BGR2HSV)
                        h_lo = int(float(p.get("h_lo", 35))); h_hi = int(float(p.get("h_hi", 85)))
                        s_lo = int(float(p.get("s_lo", 50)));  s_hi = int(float(p.get("s_hi", 255)))
                        v_lo = int(float(p.get("v_lo", 50)));  v_hi = int(float(p.get("v_hi", 255)))
                        mask2 = _cv2.inRange(hsv, np.array([h_lo, s_lo, v_lo]),
                                                   np.array([h_hi, s_hi, v_hi]))
                        result = _cv2.bitwise_and(bgr, bgr, mask=_cv2.bitwise_not(mask2))
                        rgba = _cv2.cvtColor(result, _cv2.COLOR_BGR2RGBA)
                        rgba[:, :, 3] = _cv2.bitwise_not(mask2)
                        put("image", Image.fromarray(rgba))
                        put("mask", Image.fromarray(mask2))
                except ImportError:
                    self.out("🚧  vid_range needs opencv-python + numpy", "err")
                except Exception as ex:
                    self.out(f"❌  vid_range: {ex}", "err")
                put("flow", True)

            elif ntype == "vid_refine":
                try:
                    import cv2 as _cv2
                    import numpy as np
                    from PIL import Image
                    mask_im = inp("mask")
                    if mask_im is not None:
                        m = np.array(mask_im.convert("L"))
                        blur_r = int(float(p.get("blur", 3))) | 1
                        m = _cv2.GaussianBlur(m, (blur_r, blur_r), 0)
                        _, m = _cv2.threshold(m, int(float(p.get("threshold", 127))), 255, _cv2.THRESH_BINARY)
                        put("mask", Image.fromarray(m))
                except Exception as ex:
                    self.out(f"❌  vid_refine: {ex}", "err")
                put("flow", True)

            elif ntype == "vid_feather":
                try:
                    from PIL import Image, ImageFilter
                    mask_im = inp("mask")
                    if mask_im is not None:
                        r2 = float(p.get("radius", 3))
                        m = mask_im.convert("L").filter(ImageFilter.GaussianBlur(radius=r2))
                        put("mask", m)
                except Exception as ex:
                    self.out(f"❌  vid_feather: {ex}", "err")
                put("flow", True)

            elif ntype == "vid_track_p":
                try:
                    import cv2 as _cv2
                    import numpy as np
                    from PIL import Image
                    im = inp("image")
                    if im is not None:
                        frame = np.array(im.convert("RGB"))
                        gray = _cv2.cvtColor(frame, _cv2.COLOR_RGB2GRAY)
                        x0 = int(float(p.get("x", 0))); y0 = int(float(p.get("y", 0)))
                        pts = _cv2.goodFeaturesToTrack(gray, maxCorners=1,
                              qualityLevel=0.3, minDistance=7) or np.array([[[x0, y0]]], dtype=np.float32)
                        px, py = float(pts[0][0][0]), float(pts[0][0][1])
                        put("x", px); put("y", py)
                        self.out(f"⊕  Track point: ({px:.0f}, {py:.0f})", "sys")
                except ImportError:
                    self.out("🚧  vid_track_p needs opencv-python", "err")
                except Exception as ex:
                    self.out(f"❌  vid_track_p: {ex}", "err")
                put("flow", True)

            elif ntype == "vid_track_o":
                try:
                    import cv2 as _cv2
                    import numpy as np
                    from PIL import Image
                    im = inp("image")
                    if im is not None:
                        frame = np.array(im.convert("RGB"))
                        bgr = _cv2.cvtColor(frame, _cv2.COLOR_RGB2BGR)
                        x0 = int(float(p.get("x", 0))); y0 = int(float(p.get("y", 0)))
                        w3 = int(float(p.get("w", 100))); h3 = int(float(p.get("h", 100)))
                        tracker = _cv2.TrackerCSRT_create()
                        tracker.init(bgr, (x0, y0, w3, h3))
                        put("tracker", tracker)
                        put("bbox", [float(x0), float(y0), float(w3), float(h3)])
                        self.out(f"◯  Object tracker initialized at ({x0},{y0})", "sys")
                except ImportError:
                    self.out("🚧  vid_track_o needs opencv-python", "err")
                except Exception as ex:
                    self.out(f"❌  vid_track_o: {ex}", "err")
                put("flow", True)

            elif ntype == "vid_stab":
                try:
                    import cv2 as _cv2
                    import numpy as np
                    from PIL import Image
                    im = inp("image")
                    if im is not None:
                        frame = np.array(im.convert("RGB"))
                        bgr = _cv2.cvtColor(frame, _cv2.COLOR_RGB2BGR)
                        strength = float(p.get("strength", 0.5))
                        # Basic stabilization via center crop + expand
                        h4, w4 = bgr.shape[:2]
                        margin = int(min(h4, w4) * strength * 0.05)
                        if margin > 0:
                            cropped = bgr[margin:h4-margin, margin:w4-margin]
                            stable = _cv2.resize(cropped, (w4, h4))
                        else:
                            stable = bgr
                        rgb2 = _cv2.cvtColor(stable, _cv2.COLOR_BGR2RGB)
                        put("image", Image.fromarray(rgb2))
                except ImportError:
                    self.out("🚧  vid_stab needs opencv-python", "err")
                except Exception as ex:
                    self.out(f"❌  vid_stab: {ex}", "err")
                put("flow", True)

            elif ntype == "vid_comp":
                try:
                    from PIL import Image
                    base = inp("base"); overlay = inp("overlay")
                    if base and overlay:
                        if overlay.size != base.size:
                            overlay = overlay.resize(base.size)
                        base_rgba = base.convert("RGBA")
                        over_rgba = overlay.convert("RGBA")
                        result = Image.alpha_composite(base_rgba, over_rgba)
                        put("image", result.convert("RGB"))
                    else:
                        put("image", base or overlay)
                except Exception as ex:
                    self.out(f"❌  vid_comp: {ex}", "err")
                put("flow", True)

            elif ntype == "vid_export":
                path = str(inp("path") or p.get("path", "output.mp4"))
                fps2 = float(inp("fps") or p.get("fps", 30))
                frames_list = inp("frames") or []
                try:
                    import cv2 as _cv2
                    import numpy as np
                    if frames_list:
                        first = frames_list[0]
                        if hasattr(first, "size"):
                            w5, h5 = first.size
                        else:
                            h5, w5 = first.shape[:2]
                        fourcc = _cv2.VideoWriter_fourcc(*"mp4v")
                        writer = _cv2.VideoWriter(path, fourcc, fps2, (w5, h5))
                        for fr2 in frames_list:
                            if hasattr(fr2, "size"):
                                arr2 = np.array(fr2.convert("RGB"))
                                bgr2 = _cv2.cvtColor(arr2, _cv2.COLOR_RGB2BGR)
                            else:
                                bgr2 = fr2
                            writer.write(bgr2)
                        writer.release()
                        self.out(f"⮕  Video exported: {os.path.basename(path)} "
                                 f"({len(frames_list)} frames)", "sys")
                        put("path", path)
                    else:
                        self.out("⚠  vid_export: no frames input", "err")
                except ImportError:
                    self.out("🚧  vid_export needs opencv-python", "err")
                except Exception as ex:
                    self.out(f"❌  vid_export: {ex}", "err")
                put("flow", True)

            # ── SIM nodes ────────────────────────────────────────────────
            elif ntype == "sim_emit":
                # Already implemented above (pt_emit_3d pattern for 2D sim)
                count2 = int(float(p.get("count", 200)))
                rate2 = float(p.get("rate", 60))
                emitter2 = {"count": count2, "rate": rate2, "particles": [],
                            "x": float(inp("x") or 0), "y": float(inp("y") or 0)}
                put("emitter", emitter2); put("flow", True)

            elif ntype == "sim_force":
                em2 = inp("emitter") or {}
                em2.setdefault("forces", []).append({
                    "type": p.get("type", "gravity"),
                    "x": float(p.get("fx", 0)),
                    "y": float(p.get("fy", 9.8)),
                    "strength": float(p.get("strength", 1.0)),
                })
                put("emitter", em2); put("flow", True)

            elif ntype == "sim_noise":
                em2 = inp("emitter") or {}
                em2["noise"] = {"scale": float(p.get("scale", 1.0)),
                                "strength": float(p.get("strength", 0.5)),
                                "speed": float(p.get("speed", 1.0))}
                put("emitter", em2); put("flow", True)

            elif ntype == "sim_collide":
                em2 = inp("emitter") or {}
                em2["collision"] = {"floor_y": float(p.get("floor_y", 0)),
                                    "restitution": float(p.get("restitution", 0.5)),
                                    "friction": float(p.get("friction", 0.1))}
                put("emitter", em2); put("flow", True)

            elif ntype == "sim_life":
                em2 = inp("emitter") or {}
                em2["lifetime"] = float(p.get("lifetime", 2.0))
                em2["fade"] = p.get("fade", "True") == "True"
                put("emitter", em2); put("flow", True)

            elif ntype == "sim_trail":
                em2 = inp("emitter") or {}
                em2["trail"] = {"length": int(float(p.get("length", 10))),
                                "fade": p.get("fade", "True") == "True",
                                "color": p.get("color", "#44aaff")}
                put("emitter", em2); put("flow", True)

            elif ntype == "sim_glow":
                em2 = inp("emitter") or {}
                em2["glow"] = {"radius": float(p.get("radius", 8)),
                               "intensity": float(p.get("intensity", 1.0)),
                               "color": p.get("color", "#ffcc44")}
                put("emitter", em2); put("flow", True)

            elif ntype == "sim_fluid":
                try:
                    import numpy as np
                    res = int(float(p.get("resolution", 64)))
                    domain = {"type": "fluid", "resolution": res,
                              "viscosity": float(p.get("viscosity", 0.01)),
                              "density": np.zeros((res, res), dtype=np.float32),
                              "vel_x": np.zeros((res, res), dtype=np.float32),
                              "vel_y": np.zeros((res, res), dtype=np.float32)}
                    put("domain", domain)
                    self.out(f"💧  Fluid domain: {res}×{res}", "sys")
                except ImportError:
                    put("domain", {"type": "fluid", "resolution": 64})
                    self.out("⚠  numpy not found — fluid domain created without arrays", "sys")
                put("flow", True)

            elif ntype == "sim_smoke":
                try:
                    import numpy as np
                    res = int(float(p.get("resolution", 64)))
                    domain = {"type": "smoke", "resolution": res,
                              "density": float(p.get("density", 0.8)),
                              "temperature": float(p.get("temperature", 1.0)),
                              "grid": np.zeros((res, res), dtype=np.float32)}
                    put("domain", domain)
                    self.out(f"☁  Smoke domain: {res}×{res}", "sys")
                except ImportError:
                    put("domain", {"type": "smoke", "resolution": 64})
                put("flow", True)

            elif ntype == "sim_rigid":
                # 3D Rigid Body simulation — pybullet replacement using numpy
                # Supports: gravity, ground plane, sphere/box objects, step integration
                try:
                    import numpy as np
                    grav    = float(inp("gravity") or p.get("gravity", -9.8))
                    steps   = int(float(inp("steps") or p.get("steps", 60)))
                    dt      = float(p.get("dt", 0.016))
                    ground  = p.get("ground", "True") == "True"
                    objects = inp("objects") or []
                    # Build or retrieve world state
                    world_key = f"rigid_{nid}"
                    world = self._vars.get(world_key) if hasattr(self, "_vars") else None
                    if world is None:
                        # Init world: each body = {pos, vel, mass, restitution, radius}
                        bodies = []
                        for obj in (objects if isinstance(objects, list) else [objects]):
                            if isinstance(obj, dict):
                                bodies.append({
                                    "pos":         np.array(obj.get("pos",   [0.0, 5.0, 0.0]), dtype=float),
                                    "vel":         np.array(obj.get("vel",   [0.0, 0.0, 0.0]), dtype=float),
                                    "mass":        float(obj.get("mass",        1.0)),
                                    "restitution": float(obj.get("restitution", 0.6)),
                                    "radius":      float(obj.get("radius",      0.5)),
                                    "shape":       obj.get("shape", "sphere"),
                                    "size":        np.array(obj.get("size", [1.0,1.0,1.0]), dtype=float),
                                })
                        if not bodies:
                            # Default: one sphere dropped from above
                            bodies = [{"pos": np.array([0.0, 5.0, 0.0]),
                                       "vel": np.array([0.0, 0.0, 0.0]),
                                       "mass": 1.0, "restitution": 0.6,
                                       "radius": 0.5, "shape": "sphere",
                                       "size": np.array([1.0,1.0,1.0])}]
                        world = {"bodies": bodies, "time": 0.0}
                        if hasattr(self, "_vars"):
                            self._vars[world_key] = world
                    # Step simulation
                    g_vec = np.array([0.0, grav, 0.0])
                    for _ in range(steps):
                        for b in world["bodies"]:
                            if b["mass"] > 0:
                                b["vel"] = b["vel"] + g_vec * dt
                                b["pos"] = b["pos"] + b["vel"] * dt
                                # Ground plane collision
                                if ground:
                                    floor_y = b["radius"] if b["shape"] == "sphere" else b["size"][1] * 0.5
                                    if b["pos"][1] < floor_y:
                                        b["pos"][1] = floor_y
                                        b["vel"][1] = -b["vel"][1] * b["restitution"]
                                        b["vel"][0] *= 0.98  # friction
                                        b["vel"][2] *= 0.98
                        world["time"] += dt
                    positions = [b["pos"].tolist() for b in world["bodies"]]
                    put("positions", positions)
                    put("world",     world)
                    self.out(f"🧱  Rigid sim: {len(world['bodies'])} bodies  t={world['time']:.2f}s", "sys")
                except Exception as e:
                    self.out(f"⚠  sim_rigid error: {e}", "err")
                    put("positions", [])
                    put("world", {})
                put("flow", True)

            # ── DOC nodes — Office suite ──────────────────────────────────
            elif ntype == "doc_page":
                self._ui_kept = getattr(self, "_ui_kept", {})
                if nid in self._ui_kept and self._ui_kept[nid].winfo_exists():
                    put("page", self._ui_kept[nid]); put("flow", True)
                else:
                    parent = inp("window")
                    if parent is None: parent = tk.Toplevel()
                    pg_w = int(float(p.get("w", 794)))  # A4 at 96dpi
                    pg_h = int(float(p.get("h", 1123)))
                    fr2 = tk.Frame(parent, bg="#ffffff", width=pg_w, height=pg_h,
                                   bd=1, relief="solid")
                    fr2.pack(padx=20, pady=20)
                    fr2.pack_propagate(False)
                    self._ui_kept[nid] = fr2
                    put("page", fr2)
                put("flow", True)

            elif ntype == "doc_richtxt":
                self._ui_kept = getattr(self, "_ui_kept", {})
                if nid in self._ui_kept and self._ui_kept[nid].winfo_exists():
                    put("editor", self._ui_kept[nid]); put("flow", True)
                else:
                    parent = inp("page") or inp("window")
                    if parent is None: parent = tk.Toplevel()
                    txt_w = tk.Text(parent, bg="#ffffff", fg="#111111",
                                    font=("Georgia", int(float(p.get("size", 12)))),
                                    wrap="word", relief="flat", bd=8,
                                    spacing1=4, spacing3=4,
                                    padx=int(float(p.get("margin", 40))),
                                    pady=20)
                    txt_w.pack(fill="both", expand=True)
                    content = inp("content") or p.get("text", "")
                    if content: txt_w.insert("1.0", content)
                    self._ui_kept[nid] = txt_w
                    put("editor", txt_w)
                put("flow", True)

            elif ntype == "doc_table":
                parent = inp("page") or inp("window")
                rows = int(float(p.get("rows", 3)))
                cols = int(float(p.get("cols", 3)))
                data = inp("data") or []
                if parent is not None:
                    fr2 = tk.Frame(parent, bg="#e8e8e8", bd=1, relief="solid")
                    fr2.pack(fill="x", padx=20, pady=4)
                    for r in range(rows):
                        for c in range(cols):
                            val = ""
                            if r < len(data) and c < len(data[r]): val = str(data[r][c])
                            e = tk.Entry(fr2, width=12, relief="solid", bd=1,
                                         font=("Segoe UI", 9),
                                         bg="#ffffff" if r > 0 else "#dde8ff")
                            e.insert(0, val)
                            e.grid(row=r, column=c, padx=1, pady=1)
                put("flow", True)

            elif ntype == "doc_sheet":
                self._ui_kept = getattr(self, "_ui_kept", {})
                if nid in self._ui_kept and self._ui_kept[nid].winfo_exists():
                    put("sheet", self._ui_kept[nid]); put("flow", True)
                else:
                    parent = inp("window")
                    if parent is None: parent = tk.Toplevel()
                    rows = int(float(p.get("rows", 20))); cols = int(float(p.get("cols", 10)))
                    fr2 = tk.Frame(parent, bg="#f5f5f5")
                    fr2.pack(fill="both", expand=True)
                    cells = {}
                    for r in range(rows):
                        for c in range(cols):
                            bg3 = "#e8eeff" if r == 0 or c == 0 else "#ffffff"
                            e = tk.Entry(fr2, width=10, relief="solid", bd=1,
                                         font=("Consolas", 9), bg=bg3)
                            if r == 0 and c > 0:
                                col_name = chr(64 + c)
                                e.insert(0, col_name)
                                e.config(state="readonly", disabledforeground="#444")
                            elif c == 0 and r > 0:
                                e.insert(0, str(r))
                                e.config(state="readonly", disabledforeground="#444")
                            e.grid(row=r, column=c, sticky="nsew", padx=0, pady=0)
                            cells[(r, c)] = e
                    self._ui_kept[nid] = fr2
                    put("sheet", cells)
                put("flow", True)

            elif ntype == "doc_formula":
                formula = str(inp("formula") or p.get("formula", "0"))
                sheet = inp("sheet") or {}
                try:
                    # Safe eval of simple formulas referencing cell dict
                    result = eval(formula, {"__builtins__": {}},
                                  {f"R{r}C{c}": float(sheet.get((r,c), {}).get("value", 0) if hasattr(sheet.get((r,c)), "get") else 0)
                                   for r, c in (sheet.keys() if hasattr(sheet, "keys") else [])})
                    put("result", result)
                except Exception:
                    try:
                        put("result", eval(formula))
                    except Exception:
                        put("result", 0)
                put("flow", True)

            elif ntype == "doc_chart":
                parent = inp("window")
                data3 = inp("data") or []
                if parent is not None:
                    try:
                        from PIL import Image, ImageDraw
                        cw2 = int(float(p.get("w", 400))); ch2 = int(float(p.get("h", 250)))
                        chart_img = Image.new("RGB", (cw2, ch2), "#ffffff")
                        draw2 = ImageDraw.Draw(chart_img)
                        chart_type = p.get("type", "bar")
                        if data3:
                            flat = [float(v) for v in data3 if v is not None]
                            max_v = max(flat) or 1
                            bar_w = cw2 // len(flat) if flat else cw2
                            colors = ["#4488cc", "#44aa66", "#cc4466",
                                      "#aacc22", "#cc8822", "#8844cc"]
                            for i2, v2 in enumerate(flat):
                                bh2 = int((v2 / max_v) * (ch2 - 30))
                                x1b = i2 * bar_w + 4
                                y1b = ch2 - bh2 - 20
                                x2b = x1b + bar_w - 8
                                y2b = ch2 - 20
                                c3 = colors[i2 % len(colors)]
                                draw2.rectangle([x1b, y1b, x2b, y2b], fill=c3)
                                draw2.text((x1b, y1b-12), f"{v2:.1f}",
                                           fill="#333333")
                            draw2.line([0, ch2-20, cw2, ch2-20], fill="#cccccc", width=1)
                        import tkinter as _tk
                        from PIL import ImageTk
                        img_tk = ImageTk.PhotoImage(chart_img)
                        lbl = _tk.Label(parent, image=img_tk, bg="#ffffff")
                        lbl.image = img_tk
                        lbl.pack(padx=10, pady=5)
                        put("image", chart_img)
                    except Exception as ex:
                        self.out(f"❌  doc_chart: {ex}", "err")
                put("flow", True)

            elif ntype == "doc_slide":
                self._ui_kept = getattr(self, "_ui_kept", {})
                if nid in self._ui_kept and self._ui_kept[nid].winfo_exists():
                    put("slide", self._ui_kept[nid]); put("flow", True)
                else:
                    parent = inp("window")
                    if parent is None: parent = tk.Toplevel()
                    fr2 = tk.Frame(parent,
                                   bg=p.get("bg", "#1a237e"),
                                   width=960, height=540)
                    fr2.pack(padx=10, pady=10)
                    fr2.pack_propagate(False)
                    title = p.get("title", "Slide Title")
                    tk.Label(fr2, text=title, bg=p.get("bg", "#1a237e"),
                             fg="#ffffff", font=("Segoe UI", 28, "bold")).pack(pady=40)
                    self._ui_kept[nid] = fr2
                    put("slide", fr2)
                put("flow", True)

            elif ntype == "doc_docx":
                path2 = str(inp("path") or p.get("path", "output.docx"))
                content2 = str(inp("content") or "")
                try:
                    import docx
                    doc2 = docx.Document()
                    title2 = p.get("title", "")
                    if title2: doc2.add_heading(title2, 0)
                    for para in content2.split("\n"):
                        if para.strip():
                            doc2.add_paragraph(para)
                    doc2.save(path2)
                    self.out(f"📘  DOCX saved: {os.path.basename(path2)}", "sys")
                    put("path", path2)
                except ImportError:
                    self.out("🚧  doc_docx needs python-docx — Gate: pip install python-docx", "err")
                except Exception as ex:
                    self.out(f"❌  doc_docx: {ex}", "err")
                put("flow", True)

            elif ntype == "doc_xlsx":
                path2 = str(inp("path") or p.get("path", "output.xlsx"))
                data4 = inp("data") or []
                try:
                    import openpyxl
                    wb = openpyxl.Workbook()
                    ws = wb.active
                    ws.title = p.get("sheet", "Sheet1")
                    if isinstance(data4, list):
                        for r, row2 in enumerate(data4, 1):
                            if isinstance(row2, list):
                                for c, val2 in enumerate(row2, 1):
                                    ws.cell(row=r, column=c, value=val2)
                            else:
                                ws.cell(row=r, column=1, value=row2)
                    wb.save(path2)
                    self.out(f"📗  XLSX saved: {os.path.basename(path2)}", "sys")
                    put("path", path2)
                except ImportError:
                    self.out("🚧  doc_xlsx needs openpyxl — Gate: pip install openpyxl", "err")
                except Exception as ex:
                    self.out(f"❌  doc_xlsx: {ex}", "err")
                put("flow", True)

            elif ntype == "doc_pdf":
                path2 = str(inp("path") or p.get("path", "output.pdf"))
                content2 = str(inp("content") or "")
                try:
                    from reportlab.pdfgen import canvas as rl_canvas
                    from reportlab.lib.pagesizes import A4
                    c2 = rl_canvas.Canvas(path2, pagesize=A4)
                    w_a4, h_a4 = A4
                    c2.setFont("Helvetica-Bold", 16)
                    c2.drawString(72, h_a4 - 72, p.get("title", "Document"))
                    c2.setFont("Helvetica", 11)
                    y_pos = h_a4 - 110
                    for line in content2.split("\n"):
                        if y_pos < 72:
                            c2.showPage()
                            c2.setFont("Helvetica", 11)
                            y_pos = h_a4 - 72
                        c2.drawString(72, y_pos, line[:100])
                        y_pos -= 16
                    c2.save()
                    self.out(f"📕  PDF saved: {os.path.basename(path2)}", "sys")
                    put("path", path2)
                except ImportError:
                    self.out("🚧  doc_pdf needs reportlab — Gate: pip install reportlab", "err")
                except Exception as ex:
                    self.out(f"❌  doc_pdf: {ex}", "err")
                put("flow", True)

            # ── LOGIC nodes ───────────────────────────────────────────────
            elif ntype == "function":
                # Store a reusable sub-graph callable in vars
                name5 = p.get("name", "my_fn")
                body = inp("body") or p.get("body", "")
                self._vars[f"__fn_{name5}"] = body
                put("fn", body); put("flow", True)

            elif ntype == "custom_node":
                code5 = str(inp("code") or p.get("code", ""))
                try:
                    ns = {"inp": inp, "put": put, "p": p, "self": self}
                    exec(code5, ns)
                except Exception as ex:
                    self.out(f"❌  custom_node: {ex}", "err")
                put("flow", True)

            elif ntype == "event":
                # Event node: wires a tkinter event to downstream flow
                widget = inp("widget")
                event_name = p.get("event", "<Button-1>")
                if widget is not None and hasattr(widget, "bind"):
                    def _on_event(e, _nid=nid):
                        self._flow(_nid, set())
                    widget.bind(event_name, _on_event)
                    self.out(f"⚡  Event '{event_name}' bound", "sys")
                put("flow", True)

            elif ntype == "state":
                key5 = p.get("key", "state")
                if inp("set") is not None:
                    self._vars[f"__state_{key5}"] = inp("set")
                put("value", self._vars.get(f"__state_{key5}")); put("flow", True)

            elif ntype == "signal":
                sig = p.get("name", "signal")
                val5 = inp("value")
                self._vars[f"__sig_{sig}"] = val5
                put("flow", True)

            elif ntype == "async_node":
                code5 = str(inp("code") or p.get("code", ""))
                def _run_async():
                    try:
                        exec(code5, {"inp": inp, "put": put, "p": p})
                    except Exception as ex:
                        self.out(f"❌  async: {ex}", "err")
                threading.Thread(target=_run_async, daemon=True).start()
                put("flow", True)

            elif ntype == "try_catch":
                try:
                    for w3 in self.wires:
                        if w3["fn"] == nid and w3["fp"] == "try":
                            self._flow(w3["tn"], set())
                    put("error", ""); put("ok", True)
                except Exception as ex:
                    put("error", str(ex)); put("ok", False)
                put("flow", True)

            elif ntype == "loop_break":
                raise _StopExec()

            elif ntype == "map_node":
                lst2 = inp("list") or []; fn5 = inp("fn")
                try:
                    if callable(fn5):
                        put("result", [fn5(x) for x in lst2])
                    else:
                        put("result", lst2)
                except Exception:
                    put("result", lst2)
                put("flow", True)

            elif ntype == "filter_node":
                lst2 = inp("list") or []; fn5 = inp("fn")
                try:
                    if callable(fn5):
                        put("result", [x for x in lst2 if fn5(x)])
                    else:
                        put("result", lst2)
                except Exception:
                    put("result", lst2)
                put("flow", True)

            elif ntype == "reduce_node":
                import functools
                lst2 = inp("list") or []; fn5 = inp("fn")
                init = inp("init")
                try:
                    if callable(fn5):
                        result5 = functools.reduce(fn5, lst2, init) if init is not None else functools.reduce(fn5, lst2)
                        put("result", result5)
                    else:
                        put("result", init)
                except Exception as ex:
                    self.out(f"❌  reduce: {ex}", "err")
                    put("result", init)
                put("flow", True)

            elif ntype == "switch":
                val5 = inp("value"); cases = p.get("cases", "").split(",")
                matched = False
                for i2, case in enumerate(cases):
                    if str(val5).strip() == case.strip():
                        put(f"case_{i2}", True)
                        matched = True
                if not matched: put("default", True)
                put("flow", True)

            elif ntype == "router":
                val5 = inp("value"); n5 = int(float(p.get("outputs", 2)))
                idx5 = int(float(val5 or 0)) % n5
                for i2 in range(n5): put(f"out_{i2}", i2 == idx5)
                put("flow", True)

            elif ntype == "cache":
                key5 = p.get("key", "cache_key")
                self._vars.setdefault("__cache", {})
                if inp("clear") or key5 not in self._vars["__cache"]:
                    self._vars["__cache"][key5] = inp("value")
                put("value", self._vars["__cache"].get(key5))
                put("flow", True)

            elif ntype == "database":
                import sqlite3
                db_path = str(inp("path") or p.get("path", ":memory:"))
                query5 = str(inp("query") or p.get("query", "SELECT 1"))
                try:
                    conn = sqlite3.connect(db_path)
                    cur = conn.cursor()
                    cur.execute(query5)
                    rows = cur.fetchall()
                    conn.commit(); conn.close()
                    put("rows", rows)
                    put("count", float(len(rows)))
                    self.out(f"⛃  DB: {len(rows)} rows", "sys")
                except Exception as ex:
                    self.out(f"❌  database: {ex}", "err")
                    put("rows", []); put("count", 0.0)
                put("flow", True)

            elif ntype == "history":
                key5 = p.get("key", "hist")
                max5 = int(float(p.get("max", 50)))
                val5 = inp("value")
                hist5 = self._vars.setdefault(f"__hist_{key5}", [])
                if val5 is not None:
                    hist5.append(val5)
                    if len(hist5) > max5: hist5.pop(0)
                put("history", list(hist5)); put("flow", True)

            # ── GPU nodes ─────────────────────────────────────────────────
            elif ntype in ("shader", "frag_shader", "vert_shader"):
                src = str(inp("source") or p.get("source", ""))
                try:
                    import moderngl
                    ctx = moderngl.create_standalone_context()
                    if ntype == "frag_shader":
                        prog = ctx.program(
                            vertex_shader="""
                            #version 330
                            in vec2 in_vert;
                            out vec2 uv;
                            void main() { gl_Position=vec4(in_vert,0,1); uv=(in_vert+1)/2; }
                            """,
                            fragment_shader=src or """
                            #version 330
                            in vec2 uv;
                            out vec4 color;
                            void main() { color=vec4(uv,0.5,1.0); }
                            """)
                    else:
                        prog = None
                    put("shader", prog)
                    self.out(f"⌬  {ntype} compiled", "sys")
                except ImportError:
                    self.out("🚧  GPU nodes need moderngl — Gate: pip install moderngl", "err")
                except Exception as ex:
                    self.out(f"❌  {ntype}: {ex}", "err")
                put("flow", True)

            elif ntype == "tex_buffer":
                try:
                    import moderngl
                    from PIL import Image
                    im = inp("image")
                    ctx = moderngl.create_standalone_context()
                    if im is not None:
                        img_data = im.convert("RGBA").tobytes()
                        tex = ctx.texture(im.size, 4, img_data)
                        put("texture", tex)
                        self.out(f"⛁  Texture buffer: {im.size}", "sys")
                except ImportError:
                    self.out("🚧  tex_buffer needs moderngl", "err")
                except Exception as ex:
                    self.out(f"❌  tex_buffer: {ex}", "err")
                put("flow", True)

            elif ntype == "noise_gen":
                try:
                    import numpy as np
                    from PIL import Image
                    w6 = int(float(p.get("w", 256))); h6 = int(float(p.get("h", 256)))
                    scale6 = float(p.get("scale", 4.0)); seed6 = int(float(p.get("seed", 0)))
                    rng = np.random.RandomState(seed6)
                    # Simple value noise
                    small = rng.rand(max(1, h6//int(scale6)), max(1, w6//int(scale6)))
                    big = np.array(Image.fromarray((small*255).astype(np.uint8)).resize((w6, h6), Image.BICUBIC))
                    img6 = Image.fromarray(big.astype(np.uint8))
                    put("image", img6.convert("RGB"))
                    self.out(f"≈  Noise {w6}×{h6} scale={scale6}", "sys")
                except ImportError:
                    self.out("🚧  noise_gen needs numpy", "err")
                except Exception as ex:
                    self.out(f"❌  noise_gen: {ex}", "err")
                put("flow", True)

            elif ntype in ("render_tgt", "compute", "post_proc", "displace"):
                # GPU pipeline nodes — pass through for now, log status
                val6 = inp("input") or inp("image") or inp("shader")
                put("output", val6)
                put("image", val6)
                self.out(f"⚙  {ntype}: GPU pipeline step (moderngl)", "sys")
                put("flow", True)

            # ── APP nodes ─────────────────────────────────────────────────
            elif ntype == "asset":
                path2 = str(inp("path") or p.get("path", ""))
                put("asset", path2); put("path", path2); put("flow", True)

            elif ntype == "asset_brws":
                self._ui_kept = getattr(self, "_ui_kept", {})
                if nid in self._ui_kept and self._ui_kept[nid].winfo_exists():
                    put("path", self._vars.get("__asset_sel")); put("flow", True)
                else:
                    folder = str(inp("folder") or p.get("folder", _GRAPH_DIR))
                    dlg2 = tk.Toplevel()
                    dlg2.title("Asset Browser")
                    dlg2.geometry("480x360")
                    dlg2.configure(bg="#0d0d20")
                    lb = tk.Listbox(dlg2, bg="#080818", fg="#88aacc",
                                    font=("Consolas", 10), selectbackground="#223366")
                    lb.pack(fill="both", expand=True, padx=8, pady=8)
                    try:
                        files7 = sorted(os.listdir(folder))
                        for f7 in files7: lb.insert("end", f7)
                    except Exception: pass
                    def _sel_asset():
                        sel7 = lb.curselection()
                        if sel7:
                            chosen = os.path.join(folder, lb.get(sel7[0]))
                            self._vars["__asset_sel"] = chosen
                            put("path", chosen)
                        dlg2.destroy()
                    tk.Button(dlg2, text="Select", bg="#3366aa", fg="white",
                              relief="flat", bd=0, padx=16, pady=6,
                              command=_sel_asset).pack(pady=4)
                    self._ui_kept[nid] = dlg2
                    put("flow", True)

            elif ntype == "import_ast":
                path2 = str(inp("path") or "")
                if os.path.isfile(path2):
                    put("asset", path2)
                    self.out(f"⮕  Asset imported: {os.path.basename(path2)}", "sys")
                put("flow", True)

            elif ntype == "export_app":
                # Already implemented in the app packaging logic
                put("flow", True)
                self.out("📦  export_app: use NodeBase Export toolbar button", "sys")

            elif ntype in ("install_app", "manifest", "perms"):
                put("flow", True)

            # ── AUDIO nodes (new) ─────────────────────────────────────────
            elif ntype == "aud_load":
                path2 = str(inp("path") or p.get("path", ""))
                try:
                    import soundfile as sf
                    data_a, sr_a = sf.read(path2, always_2d=False)
                    duration_a = len(data_a) / sr_a
                    put("audio", data_a)
                    put("sr", float(sr_a))
                    put("duration", float(duration_a))
                    self.out(f"🎵  Loaded: {os.path.basename(path2)} "
                             f"| {duration_a:.2f}s @ {sr_a}Hz", "sys")
                except ImportError:
                    self.out("🚧  aud_load needs soundfile — Gate: pip install soundfile", "err")
                except Exception as ex:
                    self.out(f"❌  aud_load: {ex}", "err")
                put("flow", True)

            elif ntype == "aud_save":
                path2 = str(inp("path") or p.get("path", "output.wav"))
                data_a = inp("audio"); sr_a = int(float(inp("sr") or 44100))
                try:
                    import soundfile as sf
                    import numpy as np
                    if data_a is not None:
                        sf.write(path2, np.array(data_a), sr_a)
                        self.out(f"💾  Audio saved: {os.path.basename(path2)}", "sys")
                        put("path", path2)
                except ImportError:
                    self.out("🚧  aud_save needs soundfile", "err")
                except Exception as ex:
                    self.out(f"❌  aud_save: {ex}", "err")
                put("flow", True)

            elif ntype == "aud_play":
                data_a = inp("audio"); sr_a = int(float(inp("sr") or 44100))
                blocking = p.get("blocking", "False") == "True"
                try:
                    import sounddevice as sd
                    import numpy as np
                    if data_a is not None:
                        arr = np.array(data_a, dtype=np.float32)
                        if arr.max() > 1.0: arr = arr / arr.max()
                        sd.play(arr, sr_a)
                        if blocking: sd.wait()
                        self.out(f"▶  Playing audio ({len(arr)/sr_a:.1f}s)", "sys")
                except ImportError:
                    self.out("🚧  aud_play needs sounddevice — Gate: pip install sounddevice", "err")
                except Exception as ex:
                    self.out(f"❌  aud_play: {ex}", "err")
                put("flow", True)

            elif ntype == "aud_record":
                sec_a = float(p.get("seconds", 5))
                sr_a = int(float(p.get("sr", 44100)))
                try:
                    import sounddevice as sd
                    import numpy as np
                    self.out(f"⏺  Recording {sec_a}s at {sr_a}Hz...", "sys")
                    rec = sd.rec(int(sec_a * sr_a), samplerate=sr_a,
                                 channels=1, dtype="float32")
                    sd.wait()
                    put("audio", rec.flatten())
                    put("sr", float(sr_a))
                    self.out("⏺  Recording done.", "sys")
                except ImportError:
                    self.out("🚧  aud_record needs sounddevice", "err")
                except Exception as ex:
                    self.out(f"❌  aud_record: {ex}", "err")
                put("flow", True)

            elif ntype == "aud_cut":
                data_a = inp("audio"); sr_a = int(float(inp("sr") or 44100))
                start_a = float(p.get("start", 0)); end_a = float(p.get("end", 5))
                try:
                    import numpy as np
                    arr = np.array(data_a)
                    s_idx = int(start_a * sr_a); e_idx = int(end_a * sr_a)
                    put("audio", arr[s_idx:e_idx])
                    self.out(f"✂  Cut: {start_a}s → {end_a}s", "sys")
                except Exception as ex:
                    self.out(f"❌  aud_cut: {ex}", "err")
                put("flow", True)

            elif ntype == "aud_fade":
                data_a = inp("audio"); sr_a = int(float(inp("sr") or 44100))
                fade_in = float(p.get("fade_in", 0.5))
                fade_out = float(p.get("fade_out", 0.5))
                try:
                    import numpy as np
                    arr = np.array(data_a, dtype=np.float32)
                    fi = int(fade_in * sr_a); fo = int(fade_out * sr_a)
                    if fi > 0 and fi <= len(arr):
                        arr[:fi] *= np.linspace(0, 1, fi)
                    if fo > 0 and fo <= len(arr):
                        arr[-fo:] *= np.linspace(1, 0, fo)
                    put("audio", arr)
                except Exception as ex:
                    self.out(f"❌  aud_fade: {ex}", "err")
                put("flow", True)

            elif ntype == "aud_normalize":
                data_a = inp("audio")
                target_db = float(p.get("target_db", -3))
                try:
                    import numpy as np
                    arr = np.array(data_a, dtype=np.float32)
                    peak = np.max(np.abs(arr)) or 1.0
                    target_peak = 10 ** (target_db / 20)
                    arr = arr * (target_peak / peak)
                    put("audio", arr)
                    self.out(f"⊟  Normalized to {target_db}dB", "sys")
                except Exception as ex:
                    self.out(f"❌  aud_normalize: {ex}", "err")
                put("flow", True)

            elif ntype == "aud_eq":
                data_a = inp("audio"); sr_a = int(float(inp("sr") or 44100))
                try:
                    import numpy as np
                    from scipy import signal as _sig
                    arr = np.array(data_a, dtype=np.float32)
                    low_gain  = float(p.get("low_gain",  0))
                    mid_gain  = float(p.get("mid_gain",  0))
                    high_gain = float(p.get("high_gain", 0))
                    def _apply_gain(arr2, low, high, gain_db):
                        gain = 10 ** (gain_db / 20)
                        if abs(gain - 1.0) < 0.01: return arr2
                        nyq = sr_a / 2
                        lo_n = low / nyq; hi_n = high / nyq
                        lo_n = max(0.001, min(0.999, lo_n))
                        hi_n = max(0.001, min(0.999, hi_n))
                        if lo_n >= hi_n: return arr2
                        b, a = _sig.butter(2, [lo_n, hi_n], btype="band")
                        band = _sig.filtfilt(b, a, arr2)
                        return arr2 + band * (gain - 1)
                    result_a = _apply_gain(arr, 20, 250, low_gain)
                    result_a = _apply_gain(result_a, 250, 4000, mid_gain)
                    result_a = _apply_gain(result_a, 4000, 16000, high_gain)
                    put("audio", result_a)
                    self.out(f"⋮  EQ: lo={low_gain}dB mid={mid_gain}dB hi={high_gain}dB", "sys")
                except ImportError:
                    self.out("🚧  aud_eq needs scipy — Gate: pip install scipy", "err")
                except Exception as ex:
                    self.out(f"❌  aud_eq: {ex}", "err")
                put("flow", True)

            elif ntype == "aud_pitch":
                data_a = inp("audio"); sr_a = int(float(inp("sr") or 44100))
                semitones = float(p.get("semitones", 0))
                try:
                    import librosa
                    import numpy as np
                    arr = np.array(data_a, dtype=np.float32)
                    shifted = librosa.effects.pitch_shift(arr, sr=sr_a, n_steps=semitones)
                    put("audio", shifted)
                    self.out(f"♪  Pitch shift: {semitones:+.1f} semitones", "sys")
                except ImportError:
                    self.out("🚧  aud_pitch needs librosa — Gate: pip install librosa", "err")
                except Exception as ex:
                    self.out(f"❌  aud_pitch: {ex}", "err")
                put("flow", True)

            elif ntype == "aud_tempo":
                data_a = inp("audio"); sr_a = int(float(inp("sr") or 44100))
                rate_a = float(p.get("rate", 1.0))
                try:
                    import librosa
                    import numpy as np
                    arr = np.array(data_a, dtype=np.float32)
                    stretched = librosa.effects.time_stretch(arr, rate=rate_a)
                    put("audio", stretched)
                    self.out(f"⏱  Tempo: ×{rate_a}", "sys")
                except ImportError:
                    self.out("🚧  aud_tempo needs librosa", "err")
                except Exception as ex:
                    self.out(f"❌  aud_tempo: {ex}", "err")
                put("flow", True)

            elif ntype == "aud_mix":
                data_a = inp("a"); data_b = inp("b")
                sr_a = int(float(inp("sr") or 44100))
                wa = float(p.get("weight_a", 0.5)); wb2 = float(p.get("weight_b", 0.5))
                try:
                    import numpy as np
                    a_arr = np.array(data_a, dtype=np.float32)
                    b_arr = np.array(data_b, dtype=np.float32)
                    min_len = min(len(a_arr), len(b_arr))
                    mixed = a_arr[:min_len]*wa + b_arr[:min_len]*wb2
                    put("audio", mixed)
                    self.out(f"⊕  Mixed: a×{wa} + b×{wb2}", "sys")
                except Exception as ex:
                    self.out(f"❌  aud_mix: {ex}", "err")
                put("flow", True)

            elif ntype == "aud_waveform":
                data_a = inp("audio"); sr_a = int(float(inp("sr") or 44100))
                parent = inp("window")
                try:
                    import numpy as np
                    arr = np.array(data_a, dtype=np.float32)
                    wv_w = int(float(p.get("w", 600)))
                    wv_h = int(float(p.get("h", 120)))
                    color8 = p.get("color", "#44ccff")
                    bg8 = p.get("bg", "#0a0a18")
                    self._ui_kept = getattr(self, "_ui_kept", {})
                    if nid in self._ui_kept and self._ui_kept[nid].winfo_exists():
                        cv8 = self._ui_kept[nid]
                        cv8.delete("waveform")
                    else:
                        par8 = parent or tk.Toplevel()
                        cv8 = tk.Canvas(par8, width=wv_w, height=wv_h,
                                        bg=bg8, highlightthickness=0)
                        cv8.pack(fill="x", padx=4, pady=2)
                        self._ui_kept[nid] = cv8
                    # Downsample to canvas width
                    step8 = max(1, len(arr) // wv_w)
                    mid_y = wv_h // 2
                    pts8 = []
                    for i8 in range(wv_w):
                        chunk = arr[i8*step8:(i8+1)*step8]
                        val8 = float(np.mean(np.abs(chunk))) if len(chunk) else 0
                        y8 = mid_y - int(val8 * mid_y * 0.9)
                        pts8.extend([i8, y8])
                    if len(pts8) >= 4:
                        cv8.create_line(pts8, fill=color8, tags="waveform")
                        cv8.create_line(0, mid_y, wv_w, mid_y,
                                        fill="#223344", tags="waveform")
                except Exception as ex:
                    self.out(f"❌  aud_waveform: {ex}", "err")
                put("flow", True)

            elif ntype == "aud_spectrogram":
                data_a = inp("audio"); sr_a = int(float(inp("sr") or 44100))
                parent = inp("window")
                try:
                    import numpy as np
                    from PIL import Image, ImageTk
                    arr = np.array(data_a, dtype=np.float32)
                    n_fft = 512; hop = n_fft // 4
                    frames8 = [arr[i:i+n_fft] for i in range(0, max(1, len(arr)-n_fft), hop)]
                    if frames8:
                        specs = [np.abs(np.fft.rfft(f * np.hanning(len(f)), n=n_fft)) for f in frames8]
                        spec_arr = np.array(specs).T[::-1]
                        max_v8 = spec_arr.max() or 1
                        spec_norm = (spec_arr / max_v8 * 255).astype(np.uint8)
                        sw8 = int(float(p.get("w", 600))); sh8 = int(float(p.get("h", 200)))
                        img8 = Image.fromarray(spec_norm).resize((sw8, sh8))
                        # Colorize: map grayscale to blue→cyan→yellow→red
                        rgba8 = img8.convert("RGBA")
                        self._ui_kept = getattr(self, "_ui_kept", {})
                        par8 = parent or tk.Toplevel()
                        cv8 = tk.Canvas(par8, width=sw8, height=sh8,
                                        bg="#000000", highlightthickness=0)
                        cv8.pack(fill="x", padx=4, pady=2)
                        ph8 = ImageTk.PhotoImage(rgba8)
                        cv8.create_image(sw8//2, sh8//2, image=ph8)
                        cv8._photo = ph8
                        self._ui_kept[nid] = cv8
                except Exception as ex:
                    self.out(f"❌  aud_spectrogram: {ex}", "err")
                put("flow", True)

            elif ntype == "aud_export":
                data_a = inp("audio"); sr_a = int(float(inp("sr") or 44100))
                path2 = str(inp("path") or p.get("path", "export.wav"))
                fmt2 = p.get("format", "wav")
                try:
                    import soundfile as sf
                    import numpy as np
                    arr = np.array(data_a, dtype=np.float32)
                    sf.write(path2, arr, sr_a, format=fmt2.upper())
                    self.out(f"⮕  Audio exported: {os.path.basename(path2)}", "sys")
                    put("path", path2)
                except ImportError:
                    self.out("🚧  aud_export needs soundfile", "err")
                except Exception as ex:
                    self.out(f"❌  aud_export: {ex}", "err")
                put("flow", True)

            # ── CODE EDITOR nodes (new) ───────────────────────────────────
            elif ntype == "code_editor":
                self._ui_kept = getattr(self, "_ui_kept", {})
                if nid in self._ui_kept and self._ui_kept[nid].winfo_exists():
                    win9 = self._ui_kept[nid]
                    txt9 = getattr(win9, "_code_txt", None)
                    if txt9: put("code", txt9.get("1.0", "end-1c"))
                    put("window", win9); put("flow", True)
                else:
                    parent = inp("window")
                    init_code = str(inp("code") or p.get("code", "# Write code here\n"))
                    lang = p.get("language", "python")
                    font_sz = int(float(p.get("font_size", 11)))
                    ed_w = int(float(p.get("w", 800))); ed_h = int(float(p.get("h", 500)))
                    theme = p.get("theme", "dark")
                    themes = {
                        "dark":    {"bg":"#1e1e1e", "fg":"#d4d4d4", "sel":"#264f78",
                                    "gutter":"#252526", "gutter_fg":"#858585",
                                    "cursor":"#ffffff", "line":"#282828"},
                        "monokai": {"bg":"#272822", "fg":"#f8f8f2", "sel":"#49483e",
                                    "gutter":"#1e1e1e", "gutter_fg":"#75715e",
                                    "cursor":"#f8f8f2", "line":"#2e2e2e"},
                        "light":   {"bg":"#ffffff", "fg":"#000000", "sel":"#add6ff",
                                    "gutter":"#f0f0f0", "gutter_fg":"#999999",
                                    "cursor":"#000000", "line":"#f5f5f5"},
                    }
                    th = themes.get(theme, themes["dark"])
                    if parent is None:
                        win9 = tk.Toplevel()
                        win9.title(f"Code Editor — {lang}")
                        win9.geometry(f"{ed_w}x{ed_h}")
                        win9.configure(bg=th["bg"])
                    else:
                        win9 = parent

                    # ── Layout ────────────────────────────────
                    top9 = tk.Frame(win9, bg="#1a1a1a", height=28)
                    top9.pack(fill="x")
                    top9.pack_propagate(False)
                    tk.Label(top9, text=f"  📝 {lang.upper()} Editor",
                             bg="#1a1a1a", fg="#aaaaaa",
                             font=("Segoe UI", 9, "bold")).pack(side="left", fill="y")
                    lbl_pos = tk.Label(top9, text="Ln 1, Col 1",
                                       bg="#1a1a1a", fg="#666666",
                                       font=("Segoe UI", 8))
                    lbl_pos.pack(side="right", padx=8, fill="y")

                    body9 = tk.Frame(win9, bg=th["bg"])
                    body9.pack(fill="both", expand=True)

                    # Gutter (line numbers)
                    gut9 = tk.Text(body9, width=4, bg=th["gutter"],
                                   fg=th["gutter_fg"], font=("Consolas", font_sz),
                                   relief="flat", bd=0, state="disabled",
                                   wrap="none", padx=4, pady=2,
                                   highlightthickness=0, takefocus=0)
                    gut9.pack(side="left", fill="y")

                    sb9 = tk.Scrollbar(body9, bg=th["gutter"],
                                       troughcolor=th["bg"])
                    sb9.pack(side="right", fill="y")

                    sbh9 = tk.Scrollbar(body9, orient="horizontal",
                                        bg=th["gutter"], troughcolor=th["bg"])
                    sbh9.pack(side="bottom", fill="x")

                    txt9 = tk.Text(body9, bg=th["bg"], fg=th["fg"],
                                   font=("Consolas", font_sz),
                                   relief="flat", bd=0, wrap="none",
                                   undo=True, maxundo=100,
                                   insertbackground=th["cursor"],
                                   selectbackground=th["sel"],
                                   padx=8, pady=2,
                                   highlightthickness=0,
                                   yscrollcommand=sb9.set,
                                   xscrollcommand=sbh9.set)
                    txt9.pack(side="left", fill="both", expand=True)
                    sb9.config(command=txt9.yview)
                    sbh9.config(command=txt9.xview)

                    txt9.insert("1.0", init_code)

                    # ── Syntax highlighting (basic via pygments) ──
                    _hl_colors = {
                        "dark": {
                            "keyword":  "#569cd6",
                            "string":   "#ce9178",
                            "comment":  "#6a9955",
                            "number":   "#b5cea8",
                            "function": "#dcdcaa",
                            "class":    "#4ec9b0",
                            "builtin":  "#4fc1ff",
                        }
                    }
                    hlc = _hl_colors.get(theme, _hl_colors["dark"])
                    for tag_n, col_n in hlc.items():
                        txt9.tag_config(f"hl_{tag_n}", foreground=col_n)

                    def _highlight_syntax(_=None):
                        try:
                            from pygments import lex
                            from pygments.lexers import get_lexer_by_name
                            from pygments.token import Token
                            lexer = get_lexer_by_name(lang, stripall=False)
                            code9 = txt9.get("1.0", "end-1c")
                            for tag_n in hlc:
                                txt9.tag_remove(f"hl_{tag_n}", "1.0", "end")
                            line9 = 1; col9 = 0
                            for ttype, value in lex(code9, lexer):
                                start9 = f"{line9}.{col9}"
                                lines9 = value.split("\n")
                                if len(lines9) > 1:
                                    line9 += len(lines9) - 1
                                    col9 = len(lines9[-1])
                                else:
                                    col9 += len(value)
                                end9 = f"{line9}.{col9}"
                                tag_n = None
                                if ttype in Token.Keyword: tag_n = "hl_keyword"
                                elif ttype in Token.Literal.String: tag_n = "hl_string"
                                elif ttype in Token.Comment: tag_n = "hl_comment"
                                elif ttype in Token.Literal.Number: tag_n = "hl_number"
                                elif ttype in Token.Name.Function: tag_n = "hl_function"
                                elif ttype in Token.Name.Class: tag_n = "hl_class"
                                elif ttype in Token.Name.Builtin: tag_n = "hl_builtin"
                                if tag_n:
                                    txt9.tag_add(tag_n, start9, end9)
                        except ImportError:
                            pass  # pygments not installed
                        except Exception:
                            pass

                    def _update_gutter(_=None):
                        line_count = int(txt9.index("end-1c").split(".")[0])
                        gut9.config(state="normal")
                        gut9.delete("1.0", "end")
                        gut9.insert("1.0", "\n".join(str(i) for i in range(1, line_count+1)))
                        gut9.config(state="disabled")
                        # Sync scroll
                        gut9.yview_moveto(txt9.yview()[0])

                    def _update_pos(_=None):
                        pos9 = txt9.index("insert")
                        ln9, c9 = pos9.split(".")
                        lbl_pos.config(text=f"Ln {ln9}, Col {int(c9)+1}")

                    def _on_key(_=None):
                        _update_gutter()
                        _update_pos()
                        win9.after(200, _highlight_syntax)

                    # Tab → 4 spaces
                    def _tab(e):
                        txt9.insert("insert", "    ")
                        return "break"

                    # Auto-indent on Enter
                    def _enter(e):
                        line9 = txt9.get("insert linestart", "insert")
                        indent = len(line9) - len(line9.lstrip())
                        if line9.rstrip().endswith(":"):
                            indent += 4
                        txt9.insert("insert", "\n" + " " * indent)
                        _on_key()
                        return "break"

                    txt9.bind("<Key>",    _on_key)
                    txt9.bind("<Tab>",    _tab)
                    txt9.bind("<Return>", _enter)
                    txt9.bind("<ButtonRelease-1>", _update_pos)

                    # Bottom status bar
                    bot9 = tk.Frame(win9, bg="#007acc", height=20)
                    bot9.pack(fill="x", side="bottom")
                    bot9.pack_propagate(False)
                    tk.Label(bot9, text=f"  {lang.upper()} | UTF-8 | Spaces: 4",
                             bg="#007acc", fg="#ffffff",
                             font=("Segoe UI", 8)).pack(side="left", fill="y")

                    _update_gutter()
                    win9._code_txt = txt9
                    win9.after(100, _highlight_syntax)
                    self._ui_kept[nid] = win9
                    put("code", txt9.get("1.0", "end-1c"))
                    put("window", win9)
                put("flow", True)

            elif ntype == "code_run":
                code9 = str(inp("code") or p.get("code", ""))
                lang9 = p.get("language", "python")
                timeout9 = float(p.get("timeout", 10))
                out9 = ""; err9 = ""
                try:
                    if lang9 == "python":
                        import io, contextlib
                        buf = io.StringIO()
                        with contextlib.redirect_stdout(buf):
                            exec(code9, {"__builtins__": __builtins__})
                        out9 = buf.getvalue()
                    else:
                        ext = {"javascript": ".js", "bash": ".sh"}.get(lang9, ".txt")
                        import tempfile
                        with tempfile.NamedTemporaryFile(suffix=ext, delete=False, mode="w") as f9:
                            f9.write(code9); fname9 = f9.name
                        interp = {"javascript": "node", "bash": "bash"}.get(lang9, "")
                        res9 = subprocess.run([interp, fname9], capture_output=True,
                                              text=True, timeout=timeout9)
                        out9 = res9.stdout; err9 = res9.stderr
                        os.unlink(fname9)
                    self.out(out9 or "(no output)", "out")
                except Exception as ex:
                    err9 = str(ex)
                    self.out(f"❌  code_run: {err9}", "err")
                put("output", out9); put("error", err9)
                put("flow", True)

            elif ntype == "code_highlight":
                code9 = str(inp("code") or "")
                lang9 = p.get("language", "python")
                style9 = p.get("style", "monokai")
                try:
                    from pygments import highlight
                    from pygments.lexers import get_lexer_by_name
                    from pygments.formatters import HtmlFormatter
                    lexer9 = get_lexer_by_name(lang9)
                    fmt9 = HtmlFormatter(style=style9, full=True)
                    html9 = highlight(code9, lexer9, fmt9)
                    put("html", html9)
                except ImportError:
                    self.out("🚧  code_highlight needs pygments", "err")
                    put("html", f"<pre>{code9}</pre>")
                except Exception as ex:
                    self.out(f"❌  code_highlight: {ex}", "err")
                put("flow", True)

            # ── PLUGIN nodes (registered via register_node API) ──────────
            elif ntype in _PLUGIN_REGISTRY:
                try:
                    _PLUGIN_REGISTRY[ntype](self, node, inp, put, p)
                except Exception as ex:
                    self.out(f"❌  plugin [{ntype}]: {ex}", "err")

            # ── BETA stub for any remaining Pro node ──────────────────────
            elif ntype in DEFS:
                _def = DEFS[ntype]
                if _def.get("cat") in ("ui", "gfx", "video", "3d", "sim",
                                         "doc", "logic", "gpu", "app"):
                    self.out(f"🚧  [{ntype}] BETA — not yet implemented "
                             f"(node visible, executor pending)", "sys")
                    # Pass through any flow output so downstream still runs
                    for op in _def.get("outputs", []):
                        if op["t"] == "flow":
                            put(op["n"], True)

        except _StopExec: raise
        except Exception as e:
            self.out(f"❌  [{ntype}] {e}", "err")


class _StopExec(Exception): pass


# ╔══════════════════════════════════════════════════════════════════════╗
# ║  PUBLIC API — Run a .nbg graph headlessly (no editor UI).            ║
# ║  Used by .run app bundles when launched from Luci's FileManager.     ║
# ╚══════════════════════════════════════════════════════════════════════╝

# Keep executors alive at module level so event bindings outlive the
# launching call. List grows when .run apps launch, shrinks when their
# windows close (we sweep dead ones occasionally).
_LIVE_EXECUTORS = []

def run_graph_standalone(graph_dict, output_callback=None):
    """Execute a NodeBase graph without opening the editor canvas.
    The executor instance is returned AND held in _LIVE_EXECUTORS so that
    event bindings (mouse, click, keyboard) keep working after this
    function returns.

    graph_dict: parsed .nbg JSON ({"nodes": [...], "wires": [...]})
    output_callback(text, tag): optional logger; defaults to print().
    """
    if output_callback is None:
        output_callback = lambda text, tag="out": print(text)
    nodes = graph_dict.get("nodes", [])
    wires = graph_dict.get("wires", [])
    ex = _Executor(nodes, wires, output_callback,
                   glow_fn=lambda nid: None)
    ex.run()
    _LIVE_EXECUTORS.append(ex)
    # Sweep dead executors (their windows all closed)
    _LIVE_EXECUTORS[:] = [e for e in _LIVE_EXECUTORS
                          if any((w.winfo_exists() if hasattr(w, "winfo_exists")
                                  else False)
                                 for w in getattr(e, "_ui_kept", {}).values()
                                 if w is not None)]
    return ex


def run_graph_file(nbg_path, output_callback=None):
    """Convenience wrapper — load a .nbg file from disk and run it."""
    with open(nbg_path, encoding="utf-8") as f:
        graph = json.load(f)
    return run_graph_standalone(graph, output_callback)


# ── NodeBase canvas app ────────────────────────────────────────────────────────
def main(desktop):
    # Load any installed plugins BEFORE building the IDE so their nodes
    # appear in the add menu / search.
    try:
        loaded = load_plugins(verbose=False)
    except Exception as _e:
        loaded = []

    # Register the plugin-reload callback so nodebase_ai can auto-generate
    # new plugins when the AI requests an unknown node type, then refresh
    # the registry on the fly. This is the "school bag" pattern — graph
    # asks for missing tool, NodeBase writes it + drops it in the bag,
    # graph re-tries automatically.
    try:
        if _HAS_AI and hasattr(_nai, "set_plugin_reload_callback"):
            # On plugin (re)load: refresh plugins AND tell nodebase_ai the
            # live node-type set, so the AI validator knows plugin nodes.
            def _reload_plugins_and_types():
                load_plugins(verbose=False)
                if hasattr(_nai, "set_known_types"):
                    _nai.set_known_types(set(DEFS.keys()))
            _nai.set_plugin_reload_callback(_reload_plugins_and_types)
        # Initial sync — register every node type currently known
        # (built-ins + all loaded .nbgplugin nodes).
        if _HAS_AI and hasattr(_nai, "set_known_types"):
            _nai.set_known_types(set(DEFS.keys()))
    except Exception:
        pass

    win = tk.Toplevel(desktop.root)
    win.overrideredirect(True)
    win.configure(bg="#050508")
    sw, sh = desktop.root.winfo_screenwidth(), desktop.root.winfo_screenheight()
    W, H = min(1100, sw-40), min(720, sh-60)
    win.geometry(f"{W}x{H}+{(sw-W)//2}+{(sh-H)//2}")
    win.lift()

    # ── State ──────────────────────────────────────────────────────────────
    _nodes    = []          # list of node dicts
    _wires    = []          # list of {fn,fp,tn,tp}
    _sel      = [None]      # primary selected node id (for compat)
    _multi_sel = set()      # set of selected node ids (multi-select)
    _box_sel  = {"x0":0, "y0":0, "active":False}  # marquee selection box
    _drag     = [None]      # (node_id, dx, dy)
    _wire_src = [None]      # (node_id, port_name, is_output, cx, cy)
    _tmp_wire = [None]      # canvas item id for in-progress wire
    _pan      = [0, 0]      # canvas offset
    _zoom     = [1.0]       # zoom level
    _pan_drag = [None]      # (start_x, start_y, pan_x, pan_y)
    _undo     = []          # stack of (nodes_json, wires_json)
    _cur_file = [None]
    _glow     = set()       # node ids currently flashing
    _running  = [False]     # execution in progress
    _pulse_t  = [0.0]       # wire pulse animation phase

    # ── Title bar (global Luci chrome — red/yellow/blue dots) ─────────
    # Falls back to a minimal local title bar if desktop.apply_chrome is
    # missing (older Luci runtimes).
    _title_lbl = None
    if hasattr(desktop, "apply_chrome"):
        desktop.apply_chrome(win, title="NodeBase — untitled.nbg",
                              icon="⬡", include_body=False)
        # The chrome's own title Label is set once. We keep a reference
        # in case the file rename code wants to update it later.
        for ch in win.winfo_children():
            if isinstance(ch, tk.Frame):
                for sub in ch.winfo_children():
                    if isinstance(sub, tk.Label):
                        _title_lbl = sub
                        break
                if _title_lbl is not None:
                    break
    else:
        bar = tk.Frame(win, bg="#0a0a14", height=28)
        bar.pack(fill="x"); bar.pack_propagate(False)
        _title_lbl = tk.Label(bar, text="  ⬡  NodeBase — untitled.nbg",
                              bg="#0a0a14", fg="#6688cc", font=FONT_UB)
        _title_lbl.pack(side="left", fill="y")
        tk.Button(bar, text="✕", bg="#0a0a14", fg="#334",
                  font=FONT_UB, relief="flat", bd=0, padx=10,
                  command=win.destroy).pack(side="right", fill="y")
        drag_s = [None]
        bar.bind("<ButtonPress-1>",  lambda e: drag_s.__setitem__(0,(e.x_root-win.winfo_x(),e.y_root-win.winfo_y())))
        bar.bind("<B1-Motion>",      lambda e: win.geometry(f"+{e.x_root-drag_s[0][0]}+{e.y_root-drag_s[0][1]}") if drag_s[0] else None)

    # ── Toolbar — promoted to Luci's top menubar (Apple-style) ──────────
    # When the host desktop exposes a menubar with set_app_menu(), we hand
    # the whole toolbar over to the top bar instead of stealing a 30px
    # strip of the window. On older Luci builds without a menubar, we
    # fall back to the inline toolbar so nodebase still works.
    _menubar = getattr(desktop, "_menubar", None)
    if _menubar is not None and hasattr(_menubar, "set_app_menu"):
        def _activate_menu():
            try:
                _menubar.set_app_menu("NodeBase", [
                    ("▶  Run",    lambda: _run()),
                    ("⬡  Add",    lambda: _show_add_menu(None, None)),
                    ("💾  Save",   lambda: _save()),
                    ("📂  Load",   lambda: _load()),
                    ("🗑  Clear",  lambda: _clear()),
                    ("↩  Undo",   lambda: _undo_pop()),
                    ("↪  Redo",   lambda: _redo_pop()),
                    ("🔍  Check", lambda: _check_build()),
                    ("🔧  Fix",   lambda: _auto_fix()),
                    ("🤖  VinX",  lambda: _fix_with_vinx()),
                    ("🔌  Plug",  lambda: _show_plugins_dialog()),
                    ("⛶  Fit",    lambda: _fit_all()),
                    ("⊙  Center", lambda: _center_view()),
                    ("🗺  Map",   lambda: _toggle_minimap()),
                    ("📦  Export", lambda: _export_run()),
                ])
            except Exception:
                pass
        def _deactivate_menu(_e=None):
            try: _menubar.clear_app_menu()
            except Exception: pass
        # Activate on every click in the window; clear when window closed
        win.bind("<FocusIn>", lambda _e: _activate_menu(), add="+")
        win.bind("<Button-1>", lambda _e: _activate_menu(), add="+")
        win.bind("<Destroy>", _deactivate_menu, add="+")
        _activate_menu()
        # Tiny hint strip — drops the chunky 30px toolbar
        zoom_lbl = tk.Label(win, text="100%",
                             bg="#080812", fg="#334466", font=FONT_SM)
        zoom_lbl.place(relx=1.0, rely=0, anchor="ne", x=-12, y=4)
    else:
        # ── Legacy: keep the in-window toolbar (older Luci builds) ───────
        tb = tk.Frame(win, bg="#080812", height=30)
        tb.pack(fill="x"); tb.pack_propagate(False)

        def _tb_btn(text, cmd, tip=""):
            b = tk.Button(tb, text=text, bg="#080812", fg="#6688aa",
                          activebackground="#111122", activeforeground="#88aaff",
                          font=FONT_SM, relief="flat", bd=0, padx=8,
                          command=cmd)
            b.pack(side="left", fill="y")
            return b

        _tb_btn("▶  Run",    lambda: _run())
        _tb_btn("⬡  Add",    lambda: _show_add_menu(None, None))
        _tb_btn("💾  Save",   lambda: _save())
        _tb_btn("📂  Load",   lambda: _load())
        _tb_btn("🗑  Clear",  lambda: _clear())
        _tb_btn("↩  Undo",   lambda: _undo_pop())
        _tb_btn("↪  Redo",   lambda: _redo_pop())
        _tb_btn("🔍  Check", lambda: _check_build())
        _tb_btn("🔧  Fix",   lambda: _auto_fix())
        _tb_btn("🤖  VinX",  lambda: _fix_with_vinx())
        _tb_btn("🔌  Plug",  lambda: _show_plugins_dialog())
        _tb_btn("⛶  Fit",    lambda: _fit_all())
        _tb_btn("⊙  Center", lambda: _center_view())
        _tb_btn("🗺  Map",   lambda: _toggle_minimap())
        _tb_btn("📦  Export", lambda: _export_run())

        zoom_lbl = tk.Label(tb, text="100%", bg="#080812", fg="#334466",
                             font=FONT_SM)
        zoom_lbl.pack(side="right", padx=8)
        tk.Label(tb, text="  scroll=zoom  mid-drag=pan  dbl=add  rc=delete  ⛶=fit  🗺=minimap",
                 bg="#080812", fg="#223344", font=FONT_SM).pack(side="right")

    # ── AI Panel ───────────────────────────────────────────────────────────
    ai_bar = tk.Frame(win, bg="#06060e", height=30)
    ai_bar.pack(fill="x"); ai_bar.pack_propagate(False)

    # VinX connection status dot
    _vx_dot = tk.Label(ai_bar, text="●", bg="#06060e", fg="#331111",
                       font=("Consolas", 10))
    _vx_dot.pack(side="left", padx=(6, 0))
    _vx_lbl = tk.Label(ai_bar, text="VinX", bg="#06060e", fg="#223344",
                       font=FONT_SM)
    _vx_lbl.pack(side="left", padx=(1, 6))

    _NB_ASK  = os.path.join(os.path.dirname(os.path.dirname(ROOT_DIR)), ".nb_ask.json")
    _NB_RESP = os.path.join(os.path.dirname(os.path.dirname(ROOT_DIR)), ".nb_response.json")

    def _check_vinx():
        # VinX is "connected" if it is plugged into Luci's system port.
        # The socket bus is path-independent — it works wherever VinX lives
        # (USB, any drive). The old code checked a stale LLM/memory/vinx.pid
        # path, so it always showed "VinX X" even when VinX was running.
        ok = False
        try:
            bus = getattr(desktop, "_bus", None)
            if bus is not None:
                ok = bool(bus.is_alive("vinx"))
        except Exception:
            ok = False
        if ok:
            _vx_dot.config(fg="#44ff88")
            _vx_lbl.config(fg="#33aa66", text="VinX ✓")
            try: _vx_connect_btn.config(text="Connected",
                                          bg="#1a3a26", fg="#44ff88")
            except Exception: pass
        else:
            _vx_dot.config(fg="#ff4444")
            _vx_lbl.config(fg="#662222", text="VinX ✗")
            try: _vx_connect_btn.config(text="Connect",
                                          bg="#22335a", fg="#aaccff")
            except Exception: pass
        win.after(2000, _check_vinx)

    def _connect_vinx():
        """One-click connect to VinX. If VinX isn't running yet we
        spawn its floating_core process; the system-port bus then
        pings green on the next _check_vinx tick. No node-graph
        wiring required — NodeBase calls VinX directly through the
        bus once connected.

        Multi-spawn guard: TWO checks before spawning, since
        `bus.is_alive("vinx")` can lag for a few seconds after a
        fresh start (no client hello yet). Also probe the running
        process list via psutil-or-pgrep so a partially-booted VinX
        can't be re-launched and pile up duplicate processes — the
        user kept hitting Connect and ended up with 5 orbs."""
        # Bus check (fast path)
        try:
            bus = getattr(desktop, "_bus", None)
            if bus is not None and bus.is_alive("vinx"):
                return                              # already up
        except Exception:
            pass
        # Process check — if floating_core.py is already alive, do
        # nothing. Cross-platform via psutil if available, otherwise
        # `pgrep` (POSIX) / `tasklist` (Windows).
        try:
            try:
                import psutil
                for proc in psutil.process_iter(["cmdline"]):
                    try:
                        cmd = " ".join(proc.info["cmdline"] or [])
                        if "floating_core.py" in cmd:
                            return
                    except Exception: pass
            except ImportError:
                import subprocess as _sp, sys as _sys
                if _sys.platform.startswith("win"):
                    out = _sp.check_output(
                        ["tasklist", "/FI", "IMAGENAME eq python.exe"],
                        text=True, errors="ignore")
                    if "floating_core" in out:
                        return
                else:
                    r = _sp.run(["pgrep", "-f", "floating_core.py"],
                                 capture_output=True, text=True)
                    if r.stdout.strip():
                        return
        except Exception:
            pass
        # Try Luci's built-in launcher first
        launched = False
        try:
            if hasattr(desktop, "_launch_vinx"):
                desktop._launch_vinx()
                launched = True
        except Exception: launched = False
        if not launched:
            # Fallback: spawn floating_core.py directly from the
            # standard install location.
            try:
                import subprocess as _sp, sys as _sys, os as _os
                fc_candidates = [
                    "/usr/local/luci/Vinx-AI/floating_core.py",
                    _os.path.join(_os.path.dirname(__file__),
                                   "..", "..", "..",
                                   "Vinx-AI", "floating_core.py"),
                ]
                for fc in fc_candidates:
                    if _os.path.isfile(fc):
                        env = _os.environ.copy()
                        if not _sys.platform.startswith("win") and "DISPLAY" not in env:
                            env["DISPLAY"] = ":0"
                        _sp.Popen([_sys.executable, fc],
                                   cwd=_os.path.dirname(fc),
                                   env=env,
                                   start_new_session=(not _sys.platform.startswith("win")))
                        break
            except Exception: pass
        # Show a brief "connecting" state until next status tick
        try:
            _vx_connect_btn.config(text="Connecting…",
                                    bg="#3a3a14", fg="#ffd97a")
        except Exception: pass

    _vx_connect_btn = tk.Button(
        ai_bar, text="Connect", bg="#22335a", fg="#aaccff",
        font=("Segoe UI", 8, "bold"), relief="flat", bd=0,
        padx=10, pady=2, cursor="hand2",
        activebackground="#33446a", activeforeground="#ffffff",
        command=_connect_vinx)
    _vx_connect_btn.pack(side="left", padx=(4, 6))

    _check_vinx()

    tk.Label(ai_bar, text="🤖 ", bg="#06060e", fg="#3355aa",
             font=("Segoe UI Emoji", 9)).pack(side="left")

    _ai_entry = tk.Entry(ai_bar, bg="#09091a", fg="#5577aa", font=FONT_SM,
                         relief="flat", bd=0, insertbackground="#4488ff",
                         highlightthickness=1, highlightcolor="#223366",
                         highlightbackground="#111128")
    _ai_entry.pack(side="left", fill="both", expand=True, padx=4, ipady=3)
    _ai_placeholder = ("Ask the assistant — e.g. 'add preview', 'fix wires',"
                       " 'add color picker'    or describe an app to build")
    _ai_entry.insert(0, _ai_placeholder)
    _ai_entry.config(fg="#2a3a5a")

    def _ai_focus_in(e):
        if _ai_entry.get() == _ai_placeholder:
            _ai_entry.delete(0, "end")
            _ai_entry.config(fg="#6688cc")

    def _ai_focus_out(e):
        if not _ai_entry.get().strip():
            _ai_entry.insert(0, _ai_placeholder)
            _ai_entry.config(fg="#2a3a5a")

    def _ai_generate(e=None):
        task = _ai_entry.get().strip()
        if not task or task == _ai_placeholder: return
        if not _HAS_AI:
            _con_write("❌  nodebase_ai module not found — check LLM folder.", "err"); return

        # ── ASSISTANT MODE ────────────────────────────────────────────
        # If the graph already has nodes, treat this prompt as a REVISE
        # request (modify existing). If empty, generate from scratch.
        # If the user has selected nodes via box-drag, pass those IDs as
        # context so the AI knows what to focus on.
        has_existing = len(_nodes) > 0
        sel_ids = list(_multi_sel) if _multi_sel else (
                   [_sel[0]] if _sel[0] else [])

        if has_existing:
            mode_msg = ("Revising existing graph"
                        + (f" (focus on {len(sel_ids)} selected node(s))"
                           if sel_ids else " (whole graph)"))
        else:
            mode_msg = "Generating new graph from scratch"
        _con_write(f"🤖  {mode_msg}", "sys")
        _con_write(f"   Task: {task}", "sys")

        try:
            n = _nai.count_memory()
            _flash_learn("#44ddff", f"🧠 reading {n}…", duration=60000)
        except Exception: pass

        def _do():
            try:
                count_before = _nai.count_memory()
                if has_existing:
                    cur = {"nodes": list(_nodes), "wires": list(_wires)}
                    ok, graph, err = _nai.revise(task, cur, sel_ids,
                                                  timeout=90)
                else:
                    ok, graph, err = _nai.generate(task, timeout=90)
                count_after  = _nai.count_memory()
                if ok:
                    def _apply():
                        _push_undo()
                        _nodes.clear(); _nodes.extend(graph["nodes"])
                        _wires.clear(); _wires.extend(graph["wires"])
                        _draw_all()
                        _con_write(f"✅  Done — {len(graph['nodes'])} nodes, "
                                   f"{len(graph['wires'])} wires.", "sys")
                        # The AI may have used node types that don't exist —
                        # those were dropped so the graph still builds.
                        _dropped = graph.get("_dropped")
                        if _dropped:
                            _con_write(f"   ⚠  Dropped unknown node type(s): "
                                       f"{', '.join(_dropped)}", "err")
                            _con_write(f"      AI invented these — they are "
                                       f"not real nodes. Graph built from the "
                                       f"valid ones. Make a universal "
                                       f".nbgplugin if you truly need them.",
                                       "sys")
                        # Indicator pulse: green flash if memory grew
                        if count_after > count_before:
                            _flash_learn("#44ff66",
                                f"🧠 learned! +1 ({count_after})",
                                duration=2500)
                            _con_write(
                                f"   📚  Saved as training example "
                                f"({count_after} total in memory)",
                                "sys")
                        else:
                            _flash_learn("#88ccff",
                                f"🧠 used {count_after} examples",
                                duration=2000)
                        types = [n["type"] for n in graph["nodes"]]
                        if types:
                            sugg = _nai.suggest_next(types[-1])
                            _con_write(f"   Next suggestion: {', '.join(sugg[:4])}", "sys")
                    win.after(0, _apply)
                else:
                    win.after(0, _flash_learn, "#ff4466",
                              "🧠 fail", 2000)
                    win.after(0, _con_write, f"❌  Generate failed: {err}", "err")
                    # If still an Unknown node type after retries → suggest action
                    if "Unknown node type:" in (err or ""):
                        miss = err.split("Unknown node type:")[-1].strip()
                        win.after(0, _con_write,
                            f"   🪄  Tried to auto-generate plugin for "
                            f"'{miss}' but it failed. Check plugins/ folder.",
                            "sys")
                    else:
                        win.after(0, _con_write,
                            "   Tip: describe a programming task, e.g. "
                            "'read a file and print lines'", "sys")
            except Exception as ex2:
                win.after(0, _flash_learn, "#ff4466", "🧠 error", 2000)
                win.after(0, _con_write, f"❌  Exception: {ex2}", "err")
        threading.Thread(target=_do, daemon=True).start()

    def _ai_explain():
        if not _HAS_AI:
            _con_write("❌  nodebase_ai module not found.", "err"); return
        _con_write("📝  Explaining graph…", "sys")
        def _do():
            try:
                txt = _nai.explain({"nodes": list(_nodes), "wires": list(_wires)})
                win.after(0, _con_write, f"📝  {txt}", "sys")
            except Exception as ex2:
                win.after(0, _con_write, f"❌  {ex2}", "err")
        threading.Thread(target=_do, daemon=True).start()

    _ai_entry.bind("<FocusIn>",  _ai_focus_in)
    _ai_entry.bind("<FocusOut>", _ai_focus_out)
    _ai_entry.bind("<Return>",   _ai_generate)

    def _mk_ai_btn(text, cmd, fg="#336688"):
        return tk.Button(ai_bar, text=text, bg="#06060e", fg=fg,
                         activebackground="#0a0a1a", activeforeground="#88aaff",
                         font=FONT_SM, relief="flat", bd=0, padx=8,
                         command=cmd)

    _mk_ai_btn("Generate", _ai_generate, "#2255aa").pack(side="left", fill="y")
    _mk_ai_btn("Explain",  _ai_explain,  "#226655").pack(side="left", fill="y")
    _mk_ai_btn("⚙",        lambda: _show_ai_settings(), "#666688"
              ).pack(side="left", fill="y")

    # Provider indicator label (shows current AI provider in the AI bar)
    _provider_lbl = tk.Label(ai_bar, text="", bg="#06060e",
                             fg="#5577aa", font=("Consolas", 8))
    _provider_lbl.pack(side="left", padx=4)
    def _refresh_provider_lbl():
        try:
            s = _nai.load_settings()
            pname = _nai.PROVIDERS.get(s.get("provider","vinx"), {}).get("name","?")
            _provider_lbl.config(text=f"  via {pname}")
        except Exception:
            _provider_lbl.config(text="")
    if _HAS_AI: _refresh_provider_lbl()

    # ── Learning indicator (live training status) ──────────────────────
    # Shows: 🧠 N (where N = examples in memory)
    # Pulses cyan when AI is reading memory; green flash when a new
    # graph is saved into memory. Idle = dim.
    _learn_lbl = tk.Label(ai_bar, text="", bg="#06060e",
                          fg="#446", font=("Segoe UI", 9, "bold"))
    _learn_lbl.pack(side="left", padx=4)
    _learn_state = {"timer": None}

    def _update_learn_count():
        try:
            n = _nai.count_memory()
            base = f"🧠 {n}"
            cur = _learn_lbl.cget("text").lstrip()
            # Only refresh count text if not currently in flash mode
            if not cur or cur.startswith("🧠"):
                _learn_lbl.config(text=base)
        except Exception:
            pass

    def _flash_learn(color, text, duration=1500):
        """Flash the indicator with a temporary color + text, then restore."""
        if _learn_state.get("timer"):
            try: win.after_cancel(_learn_state["timer"])
            except Exception: pass
        _learn_lbl.config(fg=color, text=text)
        def _restore():
            _learn_lbl.config(fg="#446")
            _update_learn_count()
        _learn_state["timer"] = win.after(duration, _restore)

    if _HAS_AI: _update_learn_count()

    def _show_ai_settings():
        """Modal dialog to configure AI provider + API keys + memory."""
        if not _HAS_AI:
            _con_write("❌  nodebase_ai module not found", "err"); return
        s = _nai.load_settings()
        dlg = tk.Toplevel(win)
        dlg.overrideredirect(True)
        dlg.configure(bg="#0a0a18")
        dlg.attributes("-topmost", True)
        dw, dh = 540, 600
        sw_, sh_ = dlg.winfo_screenwidth(), dlg.winfo_screenheight()
        dlg.geometry(f"{dw}x{dh}+{(sw_-dw)//2}+{(sh_-dh)//2}")

        # Title bar
        bar = tk.Frame(dlg, bg="#1a1a3a", height=30)
        bar.pack(fill="x"); bar.pack_propagate(False)
        tk.Label(bar, text="  🤖  AI Provider Settings",
                 bg="#1a1a3a", fg="#88ccff",
                 font=("Segoe UI", 10, "bold")).pack(side="left")
        tk.Button(bar, text="✕", bg="#1a1a3a", fg="#446",
                  font=("Segoe UI", 10, "bold"), relief="flat",
                  bd=0, padx=10, command=dlg.destroy).pack(side="right")

        body = tk.Frame(dlg, bg="#0a0a18")
        body.pack(fill="both", expand=True, padx=12, pady=8)

        # ── Provider dropdown ──────────────────────────────────────────
        tk.Label(body, text="Active Provider:", bg="#0a0a18",
                 fg="#aaccee", font=("Segoe UI", 9, "bold"),
                 anchor="w").pack(fill="x", pady=(4, 2))
        prov_var = tk.StringVar(value=s.get("provider", "vinx"))
        provider_choices = [(pid, pinfo["name"])
                             for pid, pinfo in _nai.PROVIDERS.items()]
        prov_frame = tk.Frame(body, bg="#0a0a18")
        prov_frame.pack(fill="x", pady=(0, 4))
        for pid, pname in provider_choices:
            tk.Radiobutton(prov_frame, text=pname, variable=prov_var,
                           value=pid, bg="#0a0a18", fg="#ccddff",
                           selectcolor="#1a1a3a",
                           activebackground="#0a0a18",
                           activeforeground="#88ccff",
                           font=("Segoe UI", 9), anchor="w"
                           ).pack(fill="x", padx=8)

        # ── Model dropdown (updates when provider changes) ─────────────
        tk.Label(body, text="Model:", bg="#0a0a18",
                 fg="#aaccee", font=("Segoe UI", 9, "bold"),
                 anchor="w").pack(fill="x", pady=(8, 2))
        model_var = tk.StringVar(value=s.get("model", "vinX.gguf"))
        model_menu_holder = tk.Frame(body, bg="#0a0a18")
        model_menu_holder.pack(fill="x")
        _model_om = [None]

        def _rebuild_model_menu(*_):
            for w in model_menu_holder.winfo_children(): w.destroy()
            pid = prov_var.get()
            models = _nai.PROVIDERS.get(pid, {}).get("models", [])
            if models and model_var.get() not in models:
                model_var.set(models[0])
            om = tk.OptionMenu(model_menu_holder, model_var, *models)
            om.config(bg="#1a1a3a", fg="#ccddff", relief="flat", bd=0,
                      activebackground="#2a2a4a", font=("Consolas", 9),
                      highlightthickness=0)
            om["menu"].config(bg="#1a1a3a", fg="#ccddff",
                              activebackground="#2a2a4a")
            om.pack(fill="x", padx=8)
            _model_om[0] = om
        prov_var.trace_add("write", _rebuild_model_menu)
        _rebuild_model_menu()

        # ── API key inputs (one per cloud provider) ────────────────────
        tk.Label(body, text="API Keys (saved locally only):",
                 bg="#0a0a18", fg="#aaccee",
                 font=("Segoe UI", 9, "bold"), anchor="w"
                 ).pack(fill="x", pady=(10, 4))

        key_vars = {}
        for pid, pinfo in _nai.PROVIDERS.items():
            if not pinfo.get("needs_key"): continue
            row = tk.Frame(body, bg="#0a0a18")
            row.pack(fill="x", pady=2)
            tk.Label(row, text=f"  {pinfo['name'][:14]:<14}",
                     bg="#0a0a18", fg="#88aacc",
                     font=("Consolas", 8), width=18, anchor="w"
                     ).pack(side="left")
            kv = tk.StringVar(value=s.get("keys", {}).get(pid, ""))
            key_vars[pid] = kv
            ent = tk.Entry(row, textvariable=kv, show="•",
                           bg="#10102a", fg="#ccffcc",
                           insertbackground="#88ccff",
                           font=("Consolas", 9), relief="flat", bd=4)
            ent.pack(side="left", fill="x", expand=True, padx=4)

        # ── Knowledge / memory toggles ─────────────────────────────────
        tk.Label(body, text="Training & Memory:",
                 bg="#0a0a18", fg="#aaccee",
                 font=("Segoe UI", 9, "bold"), anchor="w"
                 ).pack(fill="x", pady=(12, 4))

        manual_var  = tk.BooleanVar(value=s.get("use_manual",  True))
        memory_var  = tk.BooleanVar(value=s.get("save_memory", True))
        examp_var   = tk.BooleanVar(value=s.get("use_examples", True))

        for var, label_text in (
            (manual_var, "Include vx_manual.txt as system context "
                         "(for cloud providers)"),
            (memory_var, "Save successful graphs to nodebase_memory/ "
                         "as few-shot examples"),
            (examp_var,  "Use saved examples as additional AI context")):
            tk.Checkbutton(body, text=label_text, variable=var,
                           bg="#0a0a18", fg="#ccddff",
                           selectcolor="#1a1a3a",
                           activebackground="#0a0a18",
                           activeforeground="#88ccff",
                           font=("Segoe UI", 8), anchor="w"
                           ).pack(fill="x", padx=8)

        # Memory folder info
        try:
            mem_dir = _nai._MEMORY_DIR
            count = (len([f for f in os.listdir(mem_dir)
                          if f.endswith(".nbg")])
                     if os.path.isdir(mem_dir) else 0)
        except Exception:
            count = 0
        tk.Label(body,
            text=f"  📂 {count} graphs saved in nodebase_memory/",
            bg="#0a0a18", fg="#778899", font=("Consolas", 8),
            anchor="w").pack(fill="x", padx=8, pady=(8, 0))

        # ── Test connection result line ────────────────────────────────
        test_lbl = tk.Label(body, text="", bg="#0a0a18",
                            fg="#778899", font=("Consolas", 8),
                            anchor="w", wraplength=500, justify="left")
        test_lbl.pack(fill="x", padx=8, pady=(8, 0))

        def _do_test():
            # Auto-reload nodebase_ai in case a hot-edit added new functions
            # (Python caches modules; without reload, new attrs like
            # test_provider would be missing on the cached object).
            global _nai
            if not hasattr(_nai, "test_provider"):
                try:
                    import importlib
                    _nai = importlib.reload(_nai)
                    _con_write("🔄  Reloaded nodebase_ai module", "sys")
                except Exception as ex:
                    _con_write(f"⚠  Reload failed: {ex}", "err")

            if not hasattr(_nai, "test_provider"):
                _con_write(
                    "❌  test_provider() not found even after reload. "
                    "Close + reopen NodeBase to pick up the new code.",
                    "err")
                test_lbl.config(fg="#ff4466",
                    text="  ✗  Outdated module — restart NodeBase")
                return

            pid = prov_var.get()
            model = model_var.get()
            api_key = (key_vars[pid].get().strip()
                       if pid in key_vars else "")
            test_lbl.config(fg="#ffcc44",
                text=f"  ⏳  Testing {_nai.PROVIDERS[pid]['name']} "
                     f"({model})… (max 30s)")
            dlg.update_idletasks()
            _con_write(f"🔌  Testing {pid} / {model} "
                       f"(key len = {len(api_key)})…", "sys")
            done = [False]

            def _safe_update(color, text):
                try:
                    if test_lbl.winfo_exists():
                        test_lbl.config(fg=color, text=text)
                except Exception:
                    pass

            def _do():
                ok, msg = False, "(no response yet)"
                try:
                    ok, msg = _nai.test_provider(pid, model, api_key,
                                                 timeout=25)
                except Exception as ex:
                    ok, msg = False, f"crashed: {ex}"
                done[0] = True
                color = "#44ff66" if ok else "#ff4466"
                icon  = "✓" if ok else "✗"
                win.after(0, _safe_update, color,
                          f"  {icon}  {str(msg)[:140]}")
                tag = "sys" if ok else "err"
                win.after(0, _con_write,
                          f"   {icon} Test result: {str(msg)[:200]}", tag)

            def _watchdog():
                if not done[0]:
                    _safe_update("#ff8844",
                        "  ⚠  Test timed out (30s) — check network / key / model name")
                    _con_write(
                        "   ⚠  Test watchdog fired — request never returned",
                        "err")

            threading.Thread(target=_do, daemon=True).start()
            win.after(30000, _watchdog)

        # ── Bottom buttons ─────────────────────────────────────────────
        bot = tk.Frame(dlg, bg="#0a0a18")
        bot.pack(fill="x", padx=12, pady=10)
        def _save_and_close():
            new_s = _nai.load_settings()
            new_s["provider"]     = prov_var.get()
            new_s["model"]        = model_var.get()
            new_s["use_manual"]   = manual_var.get()
            new_s["save_memory"]  = memory_var.get()
            new_s["use_examples"] = examp_var.get()
            new_s.setdefault("keys", {})
            for pid, var in key_vars.items():
                v = var.get().strip()
                if v: new_s["keys"][pid] = v
                elif pid in new_s["keys"]: del new_s["keys"][pid]
            if _nai.save_settings(new_s):
                _con_write(
                    f"⚙  AI provider set to "
                    f"{_nai.PROVIDERS[prov_var.get()]['name']}",
                    "sys")
                _refresh_provider_lbl()
            dlg.destroy()

        tk.Button(bot, text="Cancel", bg="#10102a", fg="#778899",
                  font=("Segoe UI", 9), relief="flat", bd=0,
                  padx=14, pady=4, command=dlg.destroy
                  ).pack(side="right", padx=2)
        tk.Button(bot, text="💾 Save", bg="#2255aa", fg="white",
                  font=("Segoe UI", 9, "bold"), relief="flat", bd=0,
                  padx=18, pady=4, command=_save_and_close
                  ).pack(side="right", padx=2)
        tk.Button(bot, text="🔌 Test Connection", bg="#226655",
                  fg="white", font=("Segoe UI", 9, "bold"),
                  relief="flat", bd=0, padx=14, pady=4,
                  command=_do_test).pack(side="left", padx=2)
        dlg.bind("<Escape>", lambda e: dlg.destroy())

    if not _HAS_AI:
        tk.Label(ai_bar, text="  (nodebase_ai not found)", bg="#06060e",
                 fg="#442222", font=FONT_SM).pack(side="left")

    # ── Main canvas ────────────────────────────────────────────────────────
    cv = tk.Canvas(win, bg=BG, highlightthickness=0, cursor="crosshair")
    cv.pack(fill="both", expand=True)

    # ── Output console ─────────────────────────────────────────────────────
    con_frame = tk.Frame(win, bg="#050508")
    con_frame.pack(fill="x")
    con_hdr = tk.Frame(con_frame, bg="#08080f", height=18)
    con_hdr.pack(fill="x"); con_hdr.pack_propagate(False)
    _con_open = [True]
    tk.Label(con_hdr, text="  ▼  Output", bg="#08080f",
             fg="#334466", font=FONT_SM).pack(side="left", fill="y")
    tk.Button(con_hdr, text="✕ Clear", bg="#08080f", fg="#223344",
              font=FONT_SM, relief="flat", bd=0, padx=6,
              command=lambda: (con_txt.config(state="normal"),
                               con_txt.delete("1.0","end"),
                               con_txt.config(state="disabled"))).pack(side="right")

    con_txt = tk.Text(con_frame, bg="#04040a", fg="#44cc88", font=("Consolas",8),
                      height=5, relief="flat", bd=0, state="disabled",
                      selectbackground="#223344", insertbackground="#44cc88",
                      highlightthickness=0)
    con_txt.pack(fill="x", padx=0, pady=0)
    con_txt.tag_config("out", foreground="#44cc88")
    con_txt.tag_config("err", foreground="#ff5544")
    con_txt.tag_config("sys", foreground="#336688")

    def _con_write(text, tag="out"):
        con_txt.config(state="normal")
        # Break very long lines so the error is readable
        for chunk in [text[i:i+120] for i in range(0, max(len(text),1), 120)]:
            con_txt.insert("end", chunk + "\n", tag)
        con_txt.see("end")
        con_txt.config(state="disabled")

    def _glow_node(nid):
        _glow.add(nid)
        _draw_all()
        win.after(380, lambda: (_glow.discard(nid), _draw_all()))
        # The executor now runs on the MAIN thread (Python 3.11 forbids
        # Tk widget creation off the main thread, so the old worker
        # thread approach broke). Without yielding, the main thread is
        # locked inside the executor's _flow loop for the whole graph
        # run — meaning the dashed wire-pulse + node glow can't redraw
        # until the graph finishes (looks frozen). Calling
        # update_idletasks() per node lets the scheduled _pulse_tick +
        # the glow's after() animation tick fire between nodes, so the
        # "running" feedback animates live.
        try:
            win.update_idletasks()
        except Exception:
            pass

    def _pulse_tick():
        if not _running[0]: return
        _pulse_t[0] = (_pulse_t[0] + 0.045) % 1.0
        _draw_wires()
        win.after(40, _pulse_tick)

    # ── World ↔ screen transforms ──────────────────────────────────────────
    def _w2s(wx, wy):
        z = _zoom[0]
        return wx * z + _pan[0], wy * z + _pan[1]

    def _s2w(sx, sy):
        z = _zoom[0]
        return (sx - _pan[0]) / z, (sy - _pan[1]) / z

    # ── Grid drawing ───────────────────────────────────────────────────────
    def _draw_grid():
        cv.delete("grid")
        z = _zoom[0]
        step = max(20, int(40 * z))
        ox = _pan[0] % step; oy = _pan[1] % step
        cw = cv.winfo_width()  or 900
        ch = cv.winfo_height() or 600
        for x in range(int(ox), cw, step):
            cv.create_line(x,0,x,ch, fill=GRID_C, tags="grid", width=1)
        for y in range(int(oy), ch, step):
            cv.create_line(0,y,cw,y, fill=GRID_C, tags="grid", width=1)
        cv.tag_lower("grid")

    # ── Node geometry helpers ──────────────────────────────────────────────
    def _node_height(ntype):
        d   = DEFS[ntype]
        rows = max(len(d["inputs"]), len(d["outputs"]))
        return TH + max(rows, 1) * PH + len(d["params"]) * PARAMH + 6

    def _port_pos(node, port_name, is_out):
        """Return screen (cx, cy) of a port circle."""
        ntype = node["type"]
        d = DEFS[ntype]
        ports = d["outputs"] if is_out else d["inputs"]
        idx = next((i for i,p in enumerate(ports) if p["n"]==port_name), 0)
        nx, ny = _w2s(node["x"], node["y"])
        z = _zoom[0]
        nw = NW * z
        x = nx + nw if is_out else nx
        y = ny + TH * z + (idx + 0.5) * PH * z
        return x, y

    def _node_at(sx, sy):
        """Return node under screen point, or None."""
        wx, wy = _s2w(sx, sy)
        z = _zoom[0]
        for n in reversed(_nodes):
            nh = _node_height(n["type"])
            if n["x"] <= wx <= n["x"]+NW and n["y"] <= wy <= n["y"]+nh:
                return n
        return None

    def _port_at(sx, sy, radius=10):
        """Return (node, port_name, is_output) of port near screen point."""
        for n in _nodes:
            d = DEFS[n["type"]]
            for p in d["outputs"]:
                cx, cy = _port_pos(n, p["n"], True)
                if math.hypot(sx-cx, sy-cy) < radius:
                    return n, p["n"], True
            for p in d["inputs"]:
                cx, cy = _port_pos(n, p["n"], False)
                if math.hypot(sx-cx, sy-cy) < radius:
                    return n, p["n"], False
        return None, None, None

    # ── Rendering ──────────────────────────────────────────────────────────
    # ── Scalable canvas helpers (Fit / Center / Minimap) ─────────────────
    _minimap_on = [True]   # visible by default
    _MM_W, _MM_H = 200, 140   # minimap size in screen pixels

    def _graph_bounds():
        """Return (min_x, min_y, max_x, max_y) in WORLD coords for all nodes."""
        if not _nodes:
            return (0, 0, 800, 600)
        xs = [n["x"] for n in _nodes]
        ys = [n["y"] for n in _nodes]
        return (min(xs), min(ys),
                max(xs) + NW, max(ys) + 80)

    def _fit_all():
        """Zoom + pan so all nodes fit nicely in the visible canvas."""
        cv.update_idletasks()
        cw = cv.winfo_width()  or 900
        ch = cv.winfo_height() or 600
        if not _nodes:
            _zoom[0] = 1.0; _pan[0] = 0; _pan[1] = 0
            zoom_lbl.config(text="100%")
            _draw_all(); return
        x0, y0, x1, y1 = _graph_bounds()
        gw = max(1, x1 - x0); gh = max(1, y1 - y0)
        # Add 60px padding around the graph in screen pixels
        pad = 60
        zx = (cw - 2*pad) / gw
        zy = (ch - 2*pad) / gh
        _zoom[0] = max(0.3, min(3.0, min(zx, zy)))
        # Centre the graph in the viewport
        cx_world = (x0 + x1) / 2
        cy_world = (y0 + y1) / 2
        _pan[0] = cw/2 - cx_world * _zoom[0]
        _pan[1] = ch/2 - cy_world * _zoom[0]
        zoom_lbl.config(text=f"{int(_zoom[0]*100)}%")
        _draw_all()

    def _center_view():
        """Reset zoom to 100%, centre on origin (start_0)."""
        cv.update_idletasks()
        cw = cv.winfo_width()  or 900
        ch = cv.winfo_height() or 600
        _zoom[0] = 1.0
        # Center on start node if exists, else origin
        start = next((n for n in _nodes if n["type"] == "start"), None)
        if start:
            _pan[0] = cw/2 - (start["x"] + NW/2)
            _pan[1] = ch/2 - (start["y"] + 40)
        else:
            _pan[0] = cw/2; _pan[1] = ch/2
        zoom_lbl.config(text="100%")
        _draw_all()

    def _toggle_minimap():
        _minimap_on[0] = not _minimap_on[0]
        _draw_all()

    def _draw_minimap():
        """Render a small overview map in the bottom-right corner.
        Shows all nodes as colored dots + the current viewport rectangle.
        Click on the minimap pans the canvas to that point.
        """
        if not _minimap_on[0] or not _nodes:
            return
        cv.update_idletasks()
        cw = cv.winfo_width()  or 900
        ch = cv.winfo_height() or 600
        # Position in bottom-right with 12px margin
        mx = cw - _MM_W - 12
        my = ch - _MM_H - 12

        # Background panel
        cv.create_rectangle(mx, my, mx + _MM_W, my + _MM_H,
                            fill="#0a0a18", outline="#2a2a44",
                            width=1, tags="minimap")
        cv.create_text(mx + 6, my + 8, text="🗺  Map",
                       fill="#5577aa", font=("Segoe UI", 7, "bold"),
                       anchor="w", tags="minimap")

        # Compute world bounds → minimap coords mapping
        x0, y0, x1, y1 = _graph_bounds()
        gw = max(1, x1 - x0); gh = max(1, y1 - y0)
        pad = 8
        scale = min((_MM_W - 2*pad) / gw,
                    (_MM_H - 2*pad - 14) / gh)
        ox = mx + pad + (_MM_W - 2*pad - gw*scale) / 2
        oy = my + pad + 14 + (_MM_H - 2*pad - 14 - gh*scale) / 2

        def _w2m(wx, wy):
            return (ox + (wx - x0) * scale,
                    oy + (wy - y0) * scale)

        # Draw each node as a tiny colored dot (category color)
        for n in _nodes:
            d = DEFS.get(n["type"], {})
            col = CAT_ACCENT.get(d.get("cat", "util"), "#446")
            nx, ny = _w2m(n["x"], n["y"])
            nw = max(2, NW * scale)
            nh = max(2, 60 * scale)
            cv.create_rectangle(nx, ny, nx + nw, ny + nh,
                                fill=col, outline="", tags="minimap")

        # Draw the viewport rectangle (where you're looking now)
        # World coords visible: invert _w2s
        z = _zoom[0]
        vx0 = -_pan[0] / z; vy0 = -_pan[1] / z
        vx1 = vx0 + cw / z; vy1 = vy0 + ch / z
        rx0, ry0 = _w2m(vx0, vy0)
        rx1, ry1 = _w2m(vx1, vy1)
        # Clamp to minimap area
        rx0 = max(mx, min(mx+_MM_W, rx0))
        ry0 = max(my, min(my+_MM_H, ry0))
        rx1 = max(mx, min(mx+_MM_W, rx1))
        ry1 = max(my, min(my+_MM_H, ry1))
        cv.create_rectangle(rx0, ry0, rx1, ry1,
                            fill="", outline="#88ccff",
                            width=1, tags="minimap")

    def _on_minimap_click(e):
        """If user clicks inside the minimap, pan canvas to that location."""
        if not _minimap_on[0] or not _nodes: return False
        cv.update_idletasks()
        cw = cv.winfo_width()  or 900
        ch = cv.winfo_height() or 600
        mx = cw - _MM_W - 12; my = ch - _MM_H - 12
        if not (mx <= e.x <= mx+_MM_W and my <= e.y <= my+_MM_H):
            return False  # not on the minimap
        # Reverse-map click → world coords
        x0, y0, x1, y1 = _graph_bounds()
        gw = max(1, x1 - x0); gh = max(1, y1 - y0)
        pad = 8
        scale = min((_MM_W - 2*pad) / gw,
                    (_MM_H - 2*pad - 14) / gh)
        ox = mx + pad + (_MM_W - 2*pad - gw*scale) / 2
        oy = my + pad + 14 + (_MM_H - 2*pad - 14 - gh*scale) / 2
        wx = (e.x - ox) / scale + x0
        wy = (e.y - oy) / scale + y0
        # Center the canvas on (wx, wy)
        z = _zoom[0]
        _pan[0] = cw/2 - wx * z
        _pan[1] = ch/2 - wy * z
        _draw_all()
        return True

    def _draw_all():
        cv.delete("node"); cv.delete("wire"); cv.delete("tmp_wire")
        cv.delete("minimap")
        _draw_grid()
        _draw_wires()
        for n in _nodes:
            _draw_node(n)
        _draw_minimap()

    def _draw_node(node):
        nid   = node["id"]
        ntype = node["type"]
        d     = DEFS[ntype]
        z     = _zoom[0]
        nx, ny = _w2s(node["x"], node["y"])
        nw    = NW * z
        nh    = _node_height(ntype) * z
        tag   = f"node_{nid}"
        is_sel = _sel[0] == nid

        bg_c   = CAT_COLOR.get(d["cat"], "#0a0a0a")
        ac_c   = CAT_ACCENT.get(d["cat"], "#334455")
        is_glow = nid in _glow
        has_err = nid in _node_errors
        is_multi = nid in _multi_sel
        bd_c   = ("#ff4466" if has_err else
                  ("#ffee44" if is_glow else
                   ("#88ddff" if is_multi else
                    (SEL_C if is_sel else ac_c))))

        # Glow halo during execution
        if is_glow:
            cv.create_rectangle(nx-4, ny-4, nx+nw+4, ny+nh+4,
                                fill="", outline="#ffee22",
                                width=3, tags=("node", tag))

        # Error ring — pulsing red around problem nodes
        if has_err:
            cv.create_rectangle(nx-3, ny-3, nx+nw+3, ny+nh+3,
                                fill="", outline="#ff4466",
                                width=2, tags=("node", tag))

        # Body
        cv.create_rectangle(nx, ny, nx+nw, ny+nh,
                            fill=bg_c, outline=bd_c,
                            width=2 if (is_sel or is_glow or has_err) else 1,
                            tags=("node", tag))

        # Warning icon on title bar if error
        if has_err:
            cv.create_text(nx + nw - 12*z, ny + TH*z/2,
                           text="⚠", fill="#ff4466",
                           font=("Segoe UI", max(8, int(11*z)), "bold"),
                           tags=("node", tag))
        # Title bar
        cv.create_rectangle(nx, ny, nx+nw, ny+TH*z,
                            fill=ac_c, outline="", tags=("node", tag))
        cv.create_text(nx + 8*z, ny + TH*z/2,
                       text=d["label"], fill="#dde0ff",
                       font=(FONT_T[0], max(6, int(FONT_T[1]*z))),
                       anchor="w", tags=("node", tag))

        # Ports
        rows = max(len(d["inputs"]), len(d["outputs"]))
        for i, p in enumerate(d["inputs"]):
            cx, cy = _port_pos(node, p["n"], False)
            pc = PORT_COLOR.get(p["t"], "#666")
            cv.create_oval(cx-PR*z, cy-PR*z, cx+PR*z, cy+PR*z,
                          fill=pc, outline="#000", tags=("node", tag))
            cv.create_text(cx+PR*z+3*z, cy, text=p["n"],
                          fill="#778899", font=(FONT_N[0], max(5,int(FONT_N[1]*z))),
                          anchor="w", tags=("node", tag))

        for i, p in enumerate(d["outputs"]):
            cx, cy = _port_pos(node, p["n"], True)
            pc = PORT_COLOR.get(p["t"], "#666")
            cv.create_oval(cx-PR*z, cy-PR*z, cx+PR*z, cy+PR*z,
                          fill=pc, outline="#000", tags=("node", tag))
            cv.create_text(cx-PR*z-3*z, cy, text=p["n"],
                          fill="#778899", font=(FONT_N[0], max(5,int(FONT_N[1]*z))),
                          anchor="e", tags=("node", tag))

        # Params
        param_y = ny + (TH + max(len(d["inputs"]),len(d["outputs"]),1)*PH) * z + 3*z
        for pm in d["params"]:
            val = node["params"].get(pm["n"], pm.get("d",""))
            cv.create_text(nx + 8*z, param_y + PARAMH*z/2,
                          text=f"{pm['n']}: {val}",
                          fill="#556677",
                          font=(FONT_N[0], max(5, int(FONT_N[1]*z))),
                          anchor="w", tags=("node", tag))
            param_y += PARAMH * z

    def _bezier(x1, y1, x2, y2, color, tag):
        cx1 = x1 + abs(x2-x1)*0.5
        cx2 = x2 - abs(x2-x1)*0.5
        pts = []
        for t in [i/12 for i in range(13)]:
            bx = (1-t)**3*x1 + 3*(1-t)**2*t*cx1 + 3*(1-t)*t**2*cx2 + t**3*x2
            by = (1-t)**3*y1 + 3*(1-t)**2*t*y1  + 3*(1-t)*t**2*y2  + t**3*y2
            pts += [bx, by]
        cv.create_line(*pts, fill=color, width=max(1, int(1.5*_zoom[0])),
                       smooth=True, tags=tag)

    def _draw_wires():
        cv.delete("wire")
        for w in _wires:
            src = next((n for n in _nodes if n["id"]==w["fn"]), None)
            dst = next((n for n in _nodes if n["id"]==w["tn"]), None)
            if not src or not dst: continue
            x1,y1 = _port_pos(src, w["fp"], True)
            x2,y2 = _port_pos(dst, w["tp"], False)
            src_def = DEFS[src["type"]]
            pc = next((PORT_COLOR.get(p["t"],"#666") for p in src_def["outputs"]
                       if p["n"]==w["fp"]), "#666")
            _bezier(x1,y1,x2,y2, pc, "wire")
            # Pulse dot along wire during execution
            if _running[0]:
                t = _pulse_t[0]
                cx1 = x1 + abs(x2-x1)*0.5; cx2 = x2 - abs(x2-x1)*0.5
                bx = (1-t)**3*x1+3*(1-t)**2*t*cx1+3*(1-t)*t**2*cx2+t**3*x2
                by = (1-t)**3*y1+3*(1-t)**2*t*y1 +3*(1-t)*t**2*y2 +t**3*y2
                r = max(3, int(4*_zoom[0]))
                cv.create_oval(bx-r,by-r,bx+r,by+r,
                               fill="#ffffff", outline=pc, width=1, tags="wire")

    # ── Add node menu ──────────────────────────────────────────────────────
    def _show_add_menu(sx, sy):
        mx = sx or win.winfo_pointerx() - win.winfo_rootx()
        my = sy or win.winfo_pointery() - win.winfo_rooty()
        popup = tk.Toplevel(win)
        popup.overrideredirect(True)
        popup.configure(bg="#08080f")
        popup.attributes("-topmost", True)

        # ── SEARCH bar at the top ─────────────────────────────────────────
        search_var = tk.StringVar()
        search_frame = tk.Frame(popup, bg="#0a0a18")
        search_frame.pack(fill="x", padx=2, pady=(2, 0))
        tk.Label(search_frame, text="🔍", bg="#0a0a18",
                 fg="#5577aa", font=("Segoe UI", 9)).pack(side="left", padx=(4, 0))
        entry = tk.Entry(search_frame, textvariable=search_var,
                         bg="#0a0a18", fg="#88aaff",
                         font=("Consolas", 9), relief="flat", bd=4,
                         insertbackground="#88aaff", width=24)
        entry.pack(side="left", fill="x", expand=True, padx=2, pady=2, ipady=2)
        entry.focus_set()

        # ── Scrollable results area ──────────────────────────────────────
        body = tk.Frame(popup, bg="#08080f")
        body.pack(fill="both", expand=True)
        canvas = tk.Canvas(body, bg="#08080f", highlightthickness=0,
                           width=320, height=420)
        sb = tk.Scrollbar(body, orient="vertical", command=canvas.yview,
                          bg="#1a1a28", troughcolor="#08080f", width=8)
        sb.pack(side="right", fill="y")
        canvas.pack(side="left", fill="both", expand=True)
        canvas.configure(yscrollcommand=sb.set)
        results_frame = tk.Frame(canvas, bg="#08080f")
        canvas.create_window((0, 0), window=results_frame, anchor="nw")
        results_frame.bind("<Configure>",
            lambda e: canvas.configure(scrollregion=canvas.bbox("all")))
        canvas.bind("<MouseWheel>",
            lambda e: canvas.yview_scroll(-1*(e.delta//120), "units"))

        def _add(ntype):
            _push_undo()
            wx, wy = _s2w(mx, my)
            nid = str(uuid.uuid4())[:8]
            d = DEFS[ntype]
            node = {"id":nid, "type":ntype,
                    "x":wx-NW//2, "y":wy-20,
                    "params":{pm["n"]:pm.get("d","") for pm in d["params"]}}
            _nodes.append(node)
            _draw_all()
            popup.destroy()
            # ── Auto-suggest follow-up nodes (NEW!) ──────────────────────
            try:
                _show_suggest_popup(node, mx, my)
            except Exception:
                pass

        def _render(query=""):
            for w in results_frame.winfo_children(): w.destroy()
            q = query.lower().strip()
            cats = {}
            match_count = 0
            for k, v in DEFS.items():
                # Match by node type id, label text, OR category
                label_l = v["label"].lower()
                cat_l = v["cat"].lower()
                if (not q or q in k.lower() or q in label_l or q in cat_l):
                    cats.setdefault(v["cat"], []).append(k)
                    match_count += 1

            if not cats:
                tk.Label(results_frame, text="  No nodes match.",
                         bg="#08080f", fg="#446", font=("Consolas", 9)
                         ).pack(pady=20)
                return

            row = 0
            for cat in sorted(cats.keys()):
                types = cats[cat]
                # Category header
                tk.Label(results_frame,
                         text=f"  {cat.upper()}  ({len(types)})",
                         bg="#0a0a18",
                         fg=CAT_ACCENT.get(cat, "#446"),
                         font=("Segoe UI", 7, "bold"), anchor="w"
                         ).grid(row=row, column=0, columnspan=2,
                                sticky="ew", padx=1, pady=(4, 0))
                row += 1
                for i, ntype in enumerate(sorted(types)):
                    lbl = DEFS[ntype]["label"]
                    # Highlight matched substring with brighter color
                    fg = "#88ddff" if q and q in lbl.lower() else "#5577aa"
                    def _mk(t=ntype): return lambda: _add(t)
                    b = tk.Button(results_frame, text=lbl,
                                  bg="#08080f", fg=fg,
                                  activebackground="#111128",
                                  activeforeground="#88aaff",
                                  font=("Consolas", 8), relief="flat", bd=0,
                                  padx=8, pady=2, anchor="w", width=18,
                                  command=_mk())
                    b.grid(row=row, column=i%2, sticky="ew", padx=1, pady=1)
                    if i%2 == 1: row += 1
                if len(types) % 2 == 1: row += 1

            # If only one match left, Enter triggers it
            if match_count == 1:
                only_type = next(iter(cats.values()))[0]
                entry.bind("<Return>", lambda e, t=only_type: _add(t))
            else:
                entry.unbind("<Return>")

        # Update results live as user types
        search_var.trace_add("write", lambda *a: _render(search_var.get()))
        _render("")

        popup.update_idletasks()
        pw, ph = popup.winfo_reqwidth(), popup.winfo_reqheight()
        px = min(mx + win.winfo_rootx(),
                 win.winfo_screenwidth() - pw - 4)
        py = min(my + win.winfo_rooty(),
                 win.winfo_screenheight() - ph - 4)
        popup.geometry(f"360x460+{px}+{py}")
        popup.bind("<Escape>", lambda e: popup.destroy())
        popup.bind("<FocusOut>", lambda e: popup.destroy())

    # ── SUGGESTION popup — appears after a node is added ──────────────────
    # Reads suggested next nodes from nodebase_ai.suggest_next() and shows
    # them as inline chips so user can extend the graph fluidly.
    def _show_suggest_popup(just_added_node, near_x, near_y):
        if not _HAS_AI: return
        try:
            ntype = just_added_node["type"]
            sugg = _nai.suggest_next(ntype)[:5]
            if not sugg: return
        except Exception:
            return

        sp = tk.Toplevel(win)
        sp.overrideredirect(True)
        sp.configure(bg="#0d0d20")
        sp.attributes("-topmost", True)
        # Position to the right of the cursor, just below the new node
        sp_x = win.winfo_rootx() + near_x + 30
        sp_y = win.winfo_rooty() + near_y + 30

        # Header
        hdr = tk.Frame(sp, bg="#1a1a3a")
        hdr.pack(fill="x")
        tk.Label(hdr, text="  ✨  Suggested next:",
                 bg="#1a1a3a", fg="#88bbff",
                 font=("Segoe UI", 8, "bold")).pack(side="left", padx=4, pady=2)
        tk.Button(hdr, text="✕", bg="#1a1a3a", fg="#446",
                  font=("Segoe UI", 8, "bold"), relief="flat", bd=0, padx=6,
                  command=sp.destroy).pack(side="right")

        def _add_and_wire(next_type):
            """Add suggested node + auto-wire flow output → flow input."""
            _push_undo()
            nid = str(uuid.uuid4())[:8]
            d = DEFS.get(next_type)
            if not d: return
            # Place to the right of the just-added node
            new_x = just_added_node["x"] + NW + 60
            new_y = just_added_node["y"]
            node = {"id": nid, "type": next_type,
                    "x": new_x, "y": new_y,
                    "params": {pm["n"]: pm.get("d", "") for pm in d["params"]}}
            _nodes.append(node)

            # Try to auto-wire: source's flow output → new node's flow input
            src_def = DEFS.get(ntype, {})
            src_flow_out = next((p["n"] for p in src_def.get("outputs", [])
                                 if p["t"] == "flow"), None)
            dst_flow_in = next((p["n"] for p in d.get("inputs", [])
                                if p["t"] == "flow"), None)
            if src_flow_out and dst_flow_in:
                _wires.append({
                    "fn": just_added_node["id"], "fp": src_flow_out,
                    "tn": nid,                  "tp": dst_flow_in,
                })
            _draw_all()
            sp.destroy()

        # Suggestion chips
        for ntype_next in sugg:
            d = DEFS.get(ntype_next)
            if not d: continue
            color = CAT_ACCENT.get(d["cat"], "#446")
            chip = tk.Button(sp, text=f"  ➜  {d['label']}",
                             bg="#0d0d20", fg=color,
                             activebackground="#1a1a3a",
                             activeforeground="#88ccff",
                             font=("Consolas", 9), relief="flat", bd=0,
                             padx=10, pady=3, anchor="w",
                             command=lambda t=ntype_next: _add_and_wire(t))
            chip.pack(fill="x", padx=2, pady=1)

        sp.update_idletasks()
        sw_, sh_ = sp.winfo_screenwidth(), sp.winfo_screenheight()
        sp_x = min(sp_x, sw_ - sp.winfo_reqwidth() - 4)
        sp_y = min(sp_y, sh_ - sp.winfo_reqheight() - 4)
        sp.geometry(f"+{sp_x}+{sp_y}")
        sp.bind("<Escape>", lambda e: sp.destroy())
        # Auto-dismiss after 8 seconds if user doesn't engage
        sp.after(8000, lambda: sp.winfo_exists() and sp.destroy())

    # ── QUICK-ADD popup — instant search at cursor (Spotlight-style) ──────
    # Triggered by: Spacebar press, OR dragging a wire to empty space.
    # Compact UI: search box + top 7 matches, all keyboard-driven.
    # If `from_type` is given, results are pre-filtered to nodes that have
    # a compatible input port AND auto-wire on pick.
    def _show_quick_add(sx, sy, from_node=None, from_port=None,
                         from_type=None):
        qp = tk.Toplevel(win)
        qp.overrideredirect(True)
        qp.configure(bg="#0a0a18")
        qp.attributes("-topmost", True)

        # Header strip — shows wire context if present
        if from_node and from_type:
            tk.Label(qp,
                text=f"  ⤳  Wire from  {DEFS[from_node['type']]['label']}"
                     f" · {from_port}  ({from_type})",
                bg="#1a1a3a", fg="#88bbff", anchor="w",
                font=("Segoe UI", 8, "bold")
                ).pack(fill="x", padx=1, pady=(1, 0))
        else:
            tk.Label(qp, text="  ⚡  Quick Add — type to filter, ↵ to insert",
                     bg="#1a1a3a", fg="#88bbff", anchor="w",
                     font=("Segoe UI", 8, "bold")
                     ).pack(fill="x", padx=1, pady=(1, 0))

        var = tk.StringVar()
        entry = tk.Entry(qp, textvariable=var, bg="#0a0a18",
                         fg="#88ccff", font=("Consolas", 11),
                         relief="flat", bd=8,
                         insertbackground="#88ccff", width=28)
        entry.pack(fill="x", padx=2, pady=2, ipady=4)
        entry.focus_set()

        results_frame = tk.Frame(qp, bg="#0a0a18")
        results_frame.pack(fill="x", padx=1, pady=(0, 1))
        _matches = [None]   # store current top match for Enter

        def _wire_compatible(ntype):
            """Does ntype have an input port matching from_type?"""
            if not from_type: return True
            d = DEFS.get(ntype, {})
            for ip in d.get("inputs", []):
                if ip["t"] == from_type or "any" in (ip["t"], from_type):
                    return True
            return False

        def _matching_input_port(ntype):
            """Return the FIRST input port name matching from_type."""
            if not from_type: return None
            d = DEFS.get(ntype, {})
            for ip in d.get("inputs", []):
                if ip["t"] == from_type or "any" in (ip["t"], from_type):
                    return ip["n"]
            return None

        def _add_at(ntype):
            """Place node at cursor + auto-wire if from_node given."""
            _push_undo()
            wx, wy = _s2w(sx, sy)
            nid = str(uuid.uuid4())[:8]
            d = DEFS[ntype]
            node = {"id": nid, "type": ntype,
                    "x": wx - NW//2, "y": wy - 20,
                    "params": {pm["n"]: pm.get("d", "")
                               for pm in d["params"]}}
            _nodes.append(node)
            # Auto-wire if dragged from a port
            if from_node and from_port:
                tp = _matching_input_port(ntype)
                if tp:
                    _wires.append({
                        "fn": from_node["id"], "fp": from_port,
                        "tn": nid,             "tp": tp,
                    })
            _draw_all()
            qp.destroy()
            # Show suggestions for the new node too
            try:
                _show_suggest_popup(node, sx, sy + 100)
            except Exception:
                pass

        def _render(query=""):
            for w in results_frame.winfo_children(): w.destroy()
            q = query.lower().strip()
            # Score + filter: must match query AND be wire-compatible
            scored = []
            for k, v in DEFS.items():
                if not _wire_compatible(k):
                    continue
                lbl = v["label"].lower()
                cat = v["cat"].lower()
                # Higher score for prefix matches on the type id
                if not q:
                    score = 0
                elif k.lower().startswith(q):       score = 3
                elif q in k.lower():                score = 2
                elif q in lbl:                      score = 1
                elif q in cat:                      score = 1
                else:                               continue
                scored.append((score, k))
            scored.sort(key=lambda t: (-t[0], t[1]))
            top = scored[:7]
            _matches[0] = top[0][1] if top else None

            if not top:
                tk.Label(results_frame,
                    text="  (no matches — try different keywords)",
                    bg="#0a0a18", fg="#446",
                    font=("Consolas", 9)).pack(pady=4)
                return

            for i, (sc, ntype) in enumerate(top):
                d = DEFS[ntype]
                col = CAT_ACCENT.get(d["cat"], "#446")
                # First match highlighted (will be picked on Enter)
                bg = "#1a1a3a" if i == 0 else "#0a0a18"
                fg = "#88ccff" if i == 0 else col
                row = tk.Frame(results_frame, bg=bg)
                row.pack(fill="x", padx=1, pady=0)
                tk.Label(row, text=" ◆ ", bg=bg, fg=col,
                         font=("Consolas", 9)).pack(side="left")
                tk.Label(row, text=d["label"], bg=bg, fg=fg,
                         anchor="w", font=("Consolas", 9)
                         ).pack(side="left", fill="x", expand=True)
                tk.Label(row, text=f"  {d['cat']}  ", bg=bg, fg="#446",
                         font=("Segoe UI", 7, "italic")).pack(side="right")
                # Click to add
                def _mk(t=ntype): return lambda e: _add_at(t)
                row.bind("<Button-1>", _mk())
                for child in row.winfo_children():
                    child.bind("<Button-1>", _mk())

        var.trace_add("write", lambda *a: _render(var.get()))
        _render("")

        def _on_enter(_=None):
            if _matches[0]:
                _add_at(_matches[0])
        entry.bind("<Return>", _on_enter)
        qp.bind("<Escape>", lambda e: qp.destroy())
        qp.bind("<FocusOut>", lambda e: qp.destroy())

        qp.update_idletasks()
        # Position near cursor — clamp to screen
        qx = win.winfo_rootx() + sx + 6
        qy = win.winfo_rooty() + sy + 6
        qx = min(qx, win.winfo_screenwidth()  - qp.winfo_reqwidth()  - 4)
        qy = min(qy, win.winfo_screenheight() - qp.winfo_reqheight() - 4)
        qp.geometry(f"320x260+{qx}+{qy}")

    # ── Param edit dialog ──────────────────────────────────────────────────
    def _edit_params(node):
        d = DEFS[node["type"]]
        if not d["params"]: return
        dlg = tk.Toplevel(win)
        dlg.overrideredirect(True)
        dlg.configure(bg="#0a0a18")
        dlg.attributes("-topmost", True)
        nx, ny = _w2s(node["x"], node["y"])
        dlg.geometry(f"+{int(nx)+win.winfo_rootx()}+{int(ny)+win.winfo_rooty()}")

        tk.Label(dlg, text=f" {d['label']} ", bg="#0a0a18", fg="#6688cc",
                 font=FONT_UB).pack(fill="x")

        vars_ = {}
        for pm in d["params"]:
            f = tk.Frame(dlg, bg="#0a0a18"); f.pack(fill="x", padx=6, pady=2)
            tk.Label(f, text=pm["n"], bg="#0a0a18", fg="#446688",
                     font=FONT_SM, width=10, anchor="w").pack(side="left")
            cur = str(node["params"].get(pm["n"], pm.get("d","")))
            if pm["t"] == "choice":
                v = tk.StringVar(value=cur)
                vars_[pm["n"]] = v
                om = tk.OptionMenu(f, v, *pm["choices"])
                om.config(bg="#080814", fg="#6688aa", activebackground="#111128",
                          font=FONT_SM, relief="flat", bd=0, width=10)
                om["menu"].config(bg="#080814", fg="#6688aa")
                om.pack(side="left")
            else:
                v = tk.StringVar(value=cur)
                vars_[pm["n"]] = v
                e = tk.Entry(f, textvariable=v, bg="#080814", fg="#aaccee",
                             font=FONT_SM, relief="flat", bd=0, width=16,
                             insertbackground="#4488ff", highlightthickness=1,
                             highlightcolor="#224466", highlightbackground="#111122")
                e.pack(side="left", ipady=3)
                e.bind("<Return>", lambda e: _ok())

        def _ok():
            _push_undo()
            for pn, v in vars_.items():
                node["params"][pn] = v.get()
            _draw_all(); dlg.destroy()
        def _cancel(): dlg.destroy()

        bf = tk.Frame(dlg, bg="#0a0a18"); bf.pack(fill="x", pady=4)
        tk.Button(bf, text="OK", bg="#1a2a4a", fg="#88aaff",
                  font=FONT_SM, relief="flat", bd=0, padx=10,
                  command=_ok).pack(side="left", padx=6)
        tk.Button(bf, text="Cancel", bg="#0a0a18", fg="#446688",
                  font=FONT_SM, relief="flat", bd=0, padx=10,
                  command=_cancel).pack(side="left")
        dlg.bind("<Escape>", lambda e: _cancel())
        dlg.focus_set()

    # ── Canvas mouse events ────────────────────────────────────────────────
    def _on_press(e):
        # Minimap click takes priority — pans canvas to clicked location
        if _on_minimap_click(e):
            return
        # Shift toggles add-to-selection mode (modifier check)
        shift_held = bool(e.state & 0x0001) if hasattr(e, "state") else False
        pn, pp, is_out = _port_at(e.x, e.y)
        if pn:
            if is_out:
                _wire_src[0] = (pn["id"], pp, True, e.x, e.y)
            else:
                # Clicking input — detach existing wire if any
                existing = [w for w in _wires if w["tn"]==pn["id"] and w["tp"]==pp]
                if existing:
                    w = existing[0]; _push_undo(); _wires.remove(w)
                    src = next((n for n in _nodes if n["id"]==w["fn"]), None)
                    if src:
                        cx, cy = _port_pos(src, w["fp"], True)
                        _wire_src[0] = (w["fn"], w["fp"], True, cx, cy)
                    _draw_all()
            return

        node = _node_at(e.x, e.y)
        if node:
            # If clicked node isn't already in the multi-selection, replace
            # the selection (unless shift held, then add to it).
            if node["id"] not in _multi_sel:
                if not shift_held:
                    _multi_sel.clear()
                _multi_sel.add(node["id"])
            _sel[0] = node["id"]
            wx, wy = _s2w(e.x, e.y)
            # Remember original positions of EVERY selected node so we can
            # apply the drag delta to all of them in _on_motion.
            _drag[0] = {
                "anchor":  node["id"],
                "anchor_offset": (wx - node["x"], wy - node["y"]),
                "starts": {n["id"]: (n["x"], n["y"])
                           for n in _nodes if n["id"] in _multi_sel},
            }
            _draw_all()
        else:
            # Empty area click — start a marquee box select
            if not shift_held:
                _multi_sel.clear()
                _sel[0] = None
            _box_sel.update(x0=e.x, y0=e.y, active=True)
            _draw_all()

    def _on_motion(e):
        if _drag[0]:
            d = _drag[0]
            wx, wy = _s2w(e.x, e.y)
            # Compute anchor delta
            anchor_id = d["anchor"]
            anchor_start = d["starts"].get(anchor_id, (0, 0))
            target_x = wx - d["anchor_offset"][0]
            target_y = wy - d["anchor_offset"][1]
            delta_x  = target_x - anchor_start[0]
            delta_y  = target_y - anchor_start[1]
            # Apply delta to ALL selected nodes
            for n in _nodes:
                if n["id"] in d["starts"]:
                    ox, oy = d["starts"][n["id"]]
                    n["x"] = ox + delta_x
                    n["y"] = oy + delta_y
            _draw_all()
        elif _box_sel["active"]:
            # Marquee select — draw the rubber-band rectangle
            cv.delete("box_sel")
            cv.create_rectangle(_box_sel["x0"], _box_sel["y0"], e.x, e.y,
                                outline="#88ccff", dash=(4, 2), width=1,
                                fill="", tags="box_sel")
        elif _wire_src[0]:
            nid, pp, is_out, sx, sy = _wire_src[0]
            cv.delete("tmp_wire")
            _bezier(sx, sy, e.x, e.y, "#446688", ("tmp_wire","wire"))
        elif _pan_drag[0]:
            ox, oy, px, py = _pan_drag[0]
            _pan[0] = px + (e.x - ox); _pan[1] = py + (e.y - oy)
            _draw_all()

    def _on_release(e):
        if _wire_src[0]:
            src_id, src_port, _, _, _ = _wire_src[0]
            pn, pp, is_out = _port_at(e.x, e.y)
            if pn and not is_out and pn["id"] != src_id:
                # Type compatibility check
                src_node = next((n for n in _nodes if n["id"]==src_id), None)
                if src_node:
                    src_def = DEFS[src_node["type"]]
                    src_t = next((p["t"] for p in src_def["outputs"] if p["n"]==src_port), "any")
                    dst_def = DEFS[pn["type"]]
                    dst_t = next((p["t"] for p in dst_def["inputs"] if p["n"]==pp), "any")
                    if src_t == dst_t or "any" in (src_t, dst_t):
                        _push_undo()
                        # Remove any existing wire to this input
                        _wires[:] = [w for w in _wires
                                     if not (w["tn"]==pn["id"] and w["tp"]==pp)]
                        _wires.append({"fn":src_id,"fp":src_port,
                                       "tn":pn["id"],"tp":pp})
            elif not pn:
                # Released on empty space → open quick-add filtered to
                # nodes that have a matching INPUT type. Auto-wires on pick.
                src_node = next((n for n in _nodes if n["id"]==src_id), None)
                if src_node:
                    src_def = DEFS.get(src_node["type"], {})
                    src_t = next((p["t"] for p in src_def.get("outputs", [])
                                  if p["n"]==src_port), "any")
                    _show_quick_add(e.x, e.y,
                                    from_node=src_node, from_port=src_port,
                                    from_type=src_t)
            _wire_src[0] = None
            cv.delete("tmp_wire")
            _draw_all()
        # ── Finalize marquee box-selection ─────────────────────────────
        if _box_sel["active"]:
            _box_sel["active"] = False
            cv.delete("box_sel")
            x0s, y0s = _box_sel["x0"], _box_sel["y0"]
            x1s, y1s = e.x, e.y
            # Tiny box (accidental click) = ignore — keep cleared selection
            if abs(x1s - x0s) > 4 or abs(y1s - y0s) > 4:
                wx0, wy0 = _s2w(min(x0s, x1s), min(y0s, y1s))
                wx1, wy1 = _s2w(max(x0s, x1s), max(y0s, y1s))
                for n in _nodes:
                    nh = _node_height(n["type"])
                    if (n["x"] + NW > wx0 and n["x"] < wx1 and
                            n["y"] + nh > wy0 and n["y"] < wy1):
                        _multi_sel.add(n["id"])
                if _multi_sel and _sel[0] not in _multi_sel:
                    _sel[0] = next(iter(_multi_sel))
                _con_write(f"  📦  Selected {len(_multi_sel)} node(s)",
                           "sys")
            _draw_all()
        _drag[0] = None
        _pan_drag[0] = None

    def _on_right(e):
        node = _node_at(e.x, e.y)
        m = tk.Menu(win, tearoff=0, bg="#080814", fg="#6688aa",
                    activebackground="#111128", activeforeground="#88aaff",
                    font=FONT_SM, relief="flat", bd=0)
        if node:
            m.add_command(label=f"  Edit params — {DEFS[node['type']]['label']}",
                         command=lambda n=node: _edit_params(n))
            m.add_command(label="  Duplicate",
                         command=lambda n=node: _duplicate(n))
            m.add_separator()
            m.add_command(label="  Delete node",
                         command=lambda n=node: _del_node(n))
        else:
            # Check wire nearby
            wire = _wire_near(e.x, e.y)
            if wire:
                m.add_command(label="  Delete wire",
                             command=lambda w=wire: (_push_undo(),
                                                     _wires.remove(w),
                                                     _draw_all()))
            else:
                m.add_command(label="  Add node here",
                             command=lambda: _show_add_menu(e.x, e.y))
        try: m.tk_popup(e.x_root, e.y_root)
        finally: m.grab_release()

    def _on_dbl(e):
        node = _node_at(e.x, e.y)
        if node:
            _edit_params(node)
        else:
            _show_add_menu(e.x, e.y)

    def _on_scroll(e):
        old_z = _zoom[0]
        factor = 1.1 if e.delta > 0 else (1/1.1)
        _zoom[0] = max(0.3, min(3.0, _zoom[0] * factor))
        # Zoom toward mouse
        _pan[0] = e.x - (_zoom[0]/old_z) * (e.x - _pan[0])
        _pan[1] = e.y - (_zoom[0]/old_z) * (e.y - _pan[1])
        zoom_lbl.config(text=f"{int(_zoom[0]*100)}%")
        _draw_all()

    def _on_mid_press(e):
        _pan_drag[0] = (e.x, e.y, _pan[0], _pan[1])

    def _on_alt_press(e):
        _pan_drag[0] = (e.x, e.y, _pan[0], _pan[1])

    cv.bind("<ButtonPress-1>",   _on_press)
    cv.bind("<B1-Motion>",       _on_motion)
    cv.bind("<ButtonRelease-1>", _on_release)
    cv.bind("<ButtonPress-3>",   _on_right)
    cv.bind("<Double-Button-1>", _on_dbl)
    cv.bind("<MouseWheel>",      _on_scroll)
    cv.bind("<ButtonPress-2>",   _on_mid_press)
    cv.bind("<B2-Motion>",       _on_motion)
    cv.bind("<ButtonRelease-2>", _on_release)
    cv.bind("<Alt-ButtonPress-1>",   _on_alt_press)
    cv.bind("<Alt-B1-Motion>",       _on_motion)
    cv.bind("<Alt-ButtonRelease-1>", _on_release)
    cv.bind("<Configure>", lambda e: _draw_all())

    # ── Wire proximity helper ──────────────────────────────────────────────
    def _wire_near(sx, sy, tol=6):
        for w in _wires:
            src = next((n for n in _nodes if n["id"]==w["fn"]), None)
            dst = next((n for n in _nodes if n["id"]==w["tn"]), None)
            if not src or not dst: continue
            x1,y1 = _port_pos(src, w["fp"], True)
            x2,y2 = _port_pos(dst, w["tp"], False)
            # Sample bezier
            for t in [i/8 for i in range(9)]:
                cx1 = x1+abs(x2-x1)*0.5; cx2 = x2-abs(x2-x1)*0.5
                bx = (1-t)**3*x1+3*(1-t)**2*t*cx1+3*(1-t)*t**2*cx2+t**3*x2
                by = (1-t)**3*y1+3*(1-t)**2*t*y1 +3*(1-t)*t**2*y2 +t**3*y2
                if math.hypot(sx-bx, sy-by) < tol:
                    return w
        return None

    # ── Operations ────────────────────────────────────────────────────────
    # Undo + Redo (Redo wasn't there before — added for parity)
    _redo = []

    def _snapshot():
        return (json.dumps(_nodes), json.dumps(_wires))

    def _restore(snap):
        ns, ws = snap
        _nodes.clear(); _nodes.extend(json.loads(ns))
        _wires.clear(); _wires.extend(json.loads(ws))

    def _push_undo():
        _undo.append(_snapshot())
        if len(_undo) > 50: _undo.pop(0)
        _redo.clear()   # any new edit invalidates the redo stack

    def _undo_pop():
        if not _undo: return
        _redo.append(_snapshot())
        _restore(_undo.pop())
        _draw_all()

    def _redo_pop():
        if not _redo: return
        _undo.append(_snapshot())
        _restore(_redo.pop())
        _draw_all()

    # ── Build validator: scan graph for issues + auto-fix infrastructure ──
    _node_errors = {}   # nid -> error message (drawn as red ring)

    def _check_build(verbose=True):
        """Scan the graph for problems. Returns list of (nid_or_None, msg)."""
        issues = []
        types_present = {n["type"] for n in _nodes}
        ids = {n["id"] for n in _nodes}

        # Required nodes
        if "start" not in types_present:
            issues.append((None, "Missing [start] node — graph won't run"))
        if "end" not in types_present:
            issues.append((None, "Missing [end] node — graph runs but never terminates cleanly"))

        # Per-node checks: every non-start node should have an incoming flow wire
        for n in _nodes:
            d = DEFS.get(n["type"], {})
            if n["type"] in ("start", "val_str", "val_num", "val_bool",
                             "get_var", "asset", "noise_gen", "ui_color"):
                # These are fine without incoming flow (sources or value-only)
                continue
            in_ports = [ip for ip in d.get("inputs", []) if ip["t"] == "flow"]
            if in_ports:
                has_in = any(w["tn"] == n["id"] and w["tp"] == in_ports[0]["n"]
                             for w in _wires)
                if not has_in:
                    issues.append((n["id"],
                        f"[{n['type']}] not connected to flow — won't execute"))

        # Wire validity
        for w in _wires:
            if w["fn"] not in ids:
                issues.append((None, f"Dangling wire from missing node {w['fn']}"))
            if w["tn"] not in ids:
                issues.append((None, f"Dangling wire to missing node {w['tn']}"))

        # Build/export check (the user's main ask)
        has_export = any(n["type"] == "export_app" for n in _nodes)
        if not has_export:
            issues.append((None,
                "ℹ  No [export_app] node — graph runs but won't produce a .run bundle"))

        # Update node error map for visual rings
        _node_errors.clear()
        for nid, msg in issues:
            if nid:
                _node_errors[nid] = msg

        if verbose:
            if not issues:
                _con_write("✅  Build check passed — graph looks healthy.", "sys")
            else:
                _con_write(f"🔍  Build check found {len(issues)} issue(s):", "err")
                for nid, msg in issues:
                    tag = f"[{nid}] " if nid else ""
                    _con_write(f"   • {tag}{msg}", "err")
        _draw_all()   # redraw with error rings
        return issues

    def _auto_fix():
        """Auto-add the most common missing pieces (start, end, export_app)."""
        _push_undo()
        types = {n["type"] for n in _nodes}
        added = []

        # 1. Add start_0 if missing
        if "start" not in types:
            _nodes.insert(0, {"id": "start_0", "type": "start",
                              "x": 60, "y": 60, "params": {}})
            added.append("start_0")

        # 2. Locate the rightmost node to place new ones after
        right_x = max((n["x"] for n in _nodes), default=60) + NW + 60
        max_y   = max((n["y"] for n in _nodes), default=60)

        # 3. Add export_app if missing — wire from rightmost flow output
        if "export_app" not in types:
            ex_id = f"export_{uuid.uuid4().hex[:6]}"
            _nodes.append({"id": ex_id, "type": "export_app",
                           "x": right_x, "y": max_y,
                           "params": {"icon": "📦"}})
            # val_str for the app name
            name_id = f"name_{uuid.uuid4().hex[:6]}"
            graph_basename = (os.path.splitext(
                os.path.basename(_cur_file[0] or "MyApp.nbg"))[0]
                              if _cur_file[0] else "MyApp")
            _nodes.append({"id": name_id, "type": "val_str",
                           "x": right_x - NW - 60, "y": max_y + 80,
                           "params": {"value": graph_basename}})
            _wires.append({"fn": name_id, "fp": "value",
                           "tn": ex_id, "tp": "name"})
            # Try to wire flow from a node that has a free flow output
            for n in reversed(_nodes):
                if n["id"] == ex_id or n["id"] == name_id: continue
                d = DEFS.get(n["type"], {})
                flow_outs = [op for op in d.get("outputs", []) if op["t"] == "flow"]
                if flow_outs:
                    used = any(w["fn"] == n["id"] and w["fp"] == flow_outs[0]["n"]
                               for w in _wires)
                    if not used:
                        _wires.append({"fn": n["id"], "fp": flow_outs[0]["n"],
                                       "tn": ex_id, "tp": "flow"})
                        break
            added.extend([ex_id, name_id])

        # 4. Add end if missing — wire from export_app
        if "end" not in {n["type"] for n in _nodes}:
            end_id = f"end_{uuid.uuid4().hex[:6]}"
            _nodes.append({"id": end_id, "type": "end",
                           "x": right_x + NW + 60, "y": max_y,
                           "params": {}})
            # Wire from the export_app or any free flow output
            for n in reversed(_nodes):
                if n["id"] == end_id: continue
                d = DEFS.get(n["type"], {})
                flow_outs = [op for op in d.get("outputs", []) if op["t"] == "flow"]
                if flow_outs:
                    used = any(w["fn"] == n["id"] and w["fp"] == flow_outs[0]["n"]
                               for w in _wires)
                    if not used:
                        _wires.append({"fn": n["id"], "fp": flow_outs[0]["n"],
                                       "tn": end_id, "tp": "flow"})
                        break
            added.append(end_id)

        _con_write(f"🔧  Auto-fix added {len(added)} node(s): {', '.join(added)}",
                   "sys")
        _draw_all()
        _check_build(verbose=False)

    def _show_plugins_dialog():
        """List installed plugins with reload + 'open folder' actions."""
        dlg = tk.Toplevel(win)
        dlg.overrideredirect(True)
        dlg.configure(bg="#0a0a18")
        dlg.attributes("-topmost", True)
        sw_, sh_ = dlg.winfo_screenwidth(), dlg.winfo_screenheight()
        dw, dh = 480, 400
        dlg.geometry(f"{dw}x{dh}+{(sw_-dw)//2}+{(sh_-dh)//2}")

        # Title bar
        bar = tk.Frame(dlg, bg="#1a1a3a", height=28)
        bar.pack(fill="x"); bar.pack_propagate(False)
        tk.Label(bar, text="  🔌  Plugins", bg="#1a1a3a",
                 fg="#88bbff", font=("Segoe UI", 10, "bold")
                 ).pack(side="left", padx=4)
        tk.Button(bar, text="✕", bg="#1a1a3a", fg="#446",
                  font=("Segoe UI", 10, "bold"), relief="flat", bd=0, padx=10,
                  command=dlg.destroy).pack(side="right")

        # List of loaded plugins
        body = tk.Frame(dlg, bg="#0a0a18")
        body.pack(fill="both", expand=True, padx=4, pady=4)
        plugs = get_plugin_info()
        if not plugs:
            tk.Label(body,
                text=("\n\n  No plugins installed yet.\n\n"
                      f"  Drop plugin folders into:\n  {_plugin_dir()}\n\n"
                      "  See plugins/README.txt for the format."),
                bg="#0a0a18", fg="#5577aa", font=("Consolas", 9),
                anchor="w", justify="left").pack(fill="both", expand=True)
        else:
            for m in plugs:
                row = tk.Frame(body, bg="#10102a", pady=6, padx=8)
                row.pack(fill="x", pady=2)
                tk.Label(row, text=f"🔌  {m['name']} v{m['version']}",
                         bg="#10102a", fg="#88ccff",
                         font=("Segoe UI", 10, "bold"), anchor="w"
                         ).pack(fill="x")
                tk.Label(row, text=f"   by {m.get('author','?')}",
                         bg="#10102a", fg="#5577aa",
                         font=("Segoe UI", 8), anchor="w").pack(fill="x")
                if m.get("description"):
                    tk.Label(row, text=f"   {m['description'][:80]}",
                             bg="#10102a", fg="#778899",
                             font=("Segoe UI", 8, "italic"),
                             anchor="w", wraplength=440).pack(fill="x")
                tk.Label(row,
                    text=f"   adds: {', '.join(m.get('ntypes', [])) or '(none)'}",
                    bg="#10102a", fg="#44aa66",
                    font=("Consolas", 8), anchor="w",
                    wraplength=440).pack(fill="x")

        # Action buttons
        bot = tk.Frame(dlg, bg="#0a0a18")
        bot.pack(fill="x", padx=4, pady=4)
        def _open_folder():
            try:
                os.startfile(_plugin_dir())
            except Exception as ex:
                _con_write(f"❌  open: {ex}", "err")
        def _reload():
            dlg.destroy()
            n_before = len(_PLUGIN_REGISTRY)
            load_plugins(verbose=False)
            n_after = len(_PLUGIN_REGISTRY)
            _con_write(
                f"🔌  Reloaded plugins (+{n_after - n_before} new nodes)",
                "sys")
            _draw_all()
        tk.Button(bot, text="📂 Open Plugin Folder",
                  bg="#1a2a4a", fg="#88aaff", font=("Segoe UI", 9),
                  relief="flat", bd=0, padx=12, pady=4,
                  command=_open_folder).pack(side="left", padx=2)
        tk.Button(bot, text="↻ Reload All",
                  bg="#1a4a2a", fg="#88ff88", font=("Segoe UI", 9),
                  relief="flat", bd=0, padx=12, pady=4,
                  command=_reload).pack(side="left", padx=2)
        dlg.bind("<Escape>", lambda e: dlg.destroy())

    def _fix_with_vinx():
        """Send graph + issues to VinX, ask for a corrected graph."""
        if not _HAS_AI:
            _con_write("❌  VinX not available", "err"); return
        issues = _check_build(verbose=False)
        if not issues:
            _con_write("✅  Nothing to fix — graph is healthy.", "sys")
            return
        _con_write("🤖  Asking VinX to fix the graph…", "sys")

        graph_json = json.dumps({"nodes": _nodes, "wires": _wires}, indent=1)
        issues_text = "\n".join(f"- {nid or 'graph'}: {msg}" for nid, msg in issues)
        prompt = (
            "You are NodeBase repair AI. Fix the issues in this graph "
            "and return ONLY valid JSON (no markdown, no explanation):\n\n"
            f"ISSUES:\n{issues_text}\n\n"
            f"CURRENT GRAPH:\n{graph_json}\n\n"
            "Return the FIXED graph as a single JSON object with "
            '\"nodes\" and \"wires\" arrays. Add missing wires/nodes. '
            "Do not delete user content. Output JSON only:"
        )

        def _do():
            try:
                r, ok, err = _nai._ask(prompt, timeout=120)
                if not ok:
                    win.after(0, _con_write, f"❌  VinX: {err}", "err"); return
                graph, jerr = _nai._extract_json(r)
                if not graph:
                    win.after(0, _con_write,
                              f"❌  VinX returned invalid JSON: {jerr}", "err")
                    return
                ok2, graph, verr = _nai._validate(graph)
                if not ok2:
                    win.after(0, _con_write, f"❌  Validation: {verr}", "err")
                    return
                def _apply():
                    _push_undo()
                    _nodes.clear(); _nodes.extend(graph["nodes"])
                    _wires.clear(); _wires.extend(graph["wires"])
                    _draw_all()
                    _check_build(verbose=True)
                    _con_write(
                        f"✨  VinX repaired the graph "
                        f"({len(graph['nodes'])} nodes, "
                        f"{len(graph['wires'])} wires) — Ctrl+Z to undo",
                        "sys")
                win.after(0, _apply)
            except Exception as ex:
                win.after(0, _con_write, f"❌  Fix error: {ex}", "err")
        threading.Thread(target=_do, daemon=True).start()

    def _del_node(node):
        _push_undo()
        _nodes.remove(node)
        nid = node["id"]
        _wires[:] = [w for w in _wires if w["fn"]!=nid and w["tn"]!=nid]
        if _sel[0] == nid: _sel[0] = None
        _draw_all()

    def _duplicate(node):
        _push_undo()
        import copy
        nc = copy.deepcopy(node)
        nc["id"] = str(uuid.uuid4())[:8]
        nc["x"] += 20; nc["y"] += 20
        _nodes.append(nc); _draw_all()

    def _clear():
        if messagebox.askyesno("NodeBase", "Clear graph?", parent=win):
            _push_undo()
            _nodes.clear(); _wires.clear()
            _sel[0] = None; _draw_all()

    def _export_run():
        """Export/Build — package the current graph into a self-contained
        MyApp.run/ bundle that runs on nbcore.vx (no editor needed).

          MyApp.run/
            main.nbg            ← the current graph
            runtime/nbcore.vx   ← the player
            addons/             ← ONLY the .nbgplugin folders this graph uses
        """
        import shutil

        if not _nodes:
            _con_write("📦  Export: graph is empty — nothing to build.", "err")
            return
        name = simpledialog.askstring("Export App", "App name:",
                                      parent=win, initialvalue="MyApp")
        if not name:
            return
        safe = re.sub(r'[^\w\-]', '_', name)[:40] or "MyApp"

        # ── 1. detect every node type used in the graph ──────────────────────
        used = sorted({n.get("type") for n in _nodes if n.get("type")})
        builtin, plugin_types, missing = [], [], []
        for t in used:
            if t in _PLUGIN_REGISTRY:        # provided by a loaded plugin
                plugin_types.append(t)
            elif t in DEFS:                  # built into nbcore (stdlib v1)
                builtin.append(t)
            else:                            # nobody provides this node
                missing.append(t)

        # ── 2. map each plugin node type → its source .nbgplugin folder ──────
        needed = {}            # folder path → manifest dict
        unresolved = []
        for t in plugin_types:
            man = next((m for m in _PLUGIN_MANIFESTS
                        if t in m.get("ntypes", [])), None)
            if man and man.get("folder") and os.path.isdir(man["folder"]):
                needed[man["folder"]] = man
            else:
                unresolved.append(t)

        # ── 3. abort with a clear error if anything is unresolved ────────────
        if missing or unresolved:
            _con_write("📦  EXPORT FAILED — unresolved nodes:", "err")
            for t in missing:
                _con_write(f"   ✗ Missing node: {t}", "err")
                _con_write(f"     No built-in core node and no plugin "
                           f"provides it.", "err")
            for t in unresolved:
                _con_write(f"   ✗ Missing node: {t}", "err")
                _con_write(f"     Required plugin not found / not loaded — "
                           f"install the universal .nbgplugin.", "err")
            _con_write("   Build the missing .nbgplugin, then export again.",
                       "err")
            return

        # ── 4. locate the player runtime (nbcore.vx, sibling of nodebase.vx) ─
        prog_dir   = os.path.dirname(os.path.abspath(__file__))
        nbcore_src = os.path.join(prog_dir, "nbcore.vx")
        if not os.path.isfile(nbcore_src):
            _con_write(f"📦  EXPORT FAILED — nbcore.vx not found:\n"
                       f"   {nbcore_src}", "err")
            return

        # ── 5. build the bundle ──────────────────────────────────────────────
        app_dir = os.path.join(_GRAPH_DIR, f"{safe}.run")
        try:
            if os.path.isdir(app_dir):
                shutil.rmtree(app_dir)        # fresh build
            os.makedirs(os.path.join(app_dir, "runtime"))
            os.makedirs(os.path.join(app_dir, "addons"))

            # main.nbg — the graph source
            json.dump({"nodes": _nodes, "wires": _wires},
                      open(os.path.join(app_dir, "main.nbg"),
                           "w", encoding="utf-8"), indent=2)

            # runtime/nbcore.vx — the player
            shutil.copy2(nbcore_src,
                         os.path.join(app_dir, "runtime", "nbcore.vx"))

            # addons/ — copy ONLY the plugins this graph actually uses
            copied = []
            for folder, man in needed.items():
                base = os.path.basename(folder.rstrip("/\\"))
                if not base.endswith(".nbgplugin"):
                    base = (re.sub(r'[^\w\-]', '_', man.get("name", "plugin"))
                            + ".nbgplugin")
                shutil.copytree(folder,
                                os.path.join(app_dir, "addons", base),
                                dirs_exist_ok=True)
                copied.append(base)

            # run_manifest.json — describes the bundle (v1.1 architecture §15)
            manifest = {
                "name":     name,
                "safe":     safe,
                "engine":   "nbcore/1.0",
                "entry":    "runtime/nbcore.vx",
                "graph":    "main.nbg",
                "addons":   copied,
                "nodes": {
                    "total":   len(_nodes),
                    "core":    builtin,
                    "plugin":  plugin_types,
                },
                "created":  __import__("time").strftime("%Y-%m-%d %H:%M:%S"),
            }
            json.dump(manifest,
                      open(os.path.join(app_dir, "run_manifest.json"),
                           "w", encoding="utf-8"), indent=2)

            # ── report ───────────────────────────────────────────────────────
            _con_write(f"📦  EXPORTED: {safe}.run", "sys")
            _con_write(f"   nodes   : {len(_nodes)} used  "
                       f"({len(builtin)} core, {len(plugin_types)} plugin)",
                       "sys")
            for c in copied:
                _con_write(f"   addon   : {c}", "sys")
            if not copied:
                _con_write(f"   addon   : none — core stdlib only", "sys")
            _con_write(f"   runtime : nbcore.vx", "sys")
            _con_write(f"   manifest: run_manifest.json", "sys")
            _con_write(f"   output  : {app_dir}", "sys")
        except Exception as e:
            _con_write(f"📦  EXPORT FAILED: {e}", "err")

    def _save():
        path = filedialog.asksaveasfilename(
            parent=win, initialdir=_GRAPH_DIR,
            defaultextension=".nbg", filetypes=[("NodeBase Graph","*.nbg")],
            title="Save Graph")
        if not path: return
        json.dump({"nodes":_nodes,"wires":_wires},
                  open(path,"w",encoding="utf-8"), indent=2)
        _cur_file[0] = path
        _title_lbl.config(text=f"  ⬡  NodeBase — {os.path.basename(path)}")
        _con_write(f"💾  Saved: {os.path.basename(path)}", "sys")

    def _load():
        path = filedialog.askopenfilename(
            parent=win, initialdir=_GRAPH_DIR,
            filetypes=[("NodeBase Graph","*.nbg")], title="Load Graph")
        if not path: return
        try:
            data = json.load(open(path, encoding="utf-8"))
            _push_undo()
            _nodes.clear(); _nodes.extend(data.get("nodes",[]))
            _wires.clear(); _wires.extend(data.get("wires",[]))
            _cur_file[0] = path
            _title_lbl.config(text=f"  ⬡  NodeBase — {os.path.basename(path)}")
            _draw_all()
            _con_write(f"📂  Loaded: {os.path.basename(path)}", "sys")
        except Exception as e:
            _con_write(f"❌  Load error: {e}", "err")

    def _run():
        # The executor creates Tk widgets (Toplevels, Canvases, Buttons)
        # inside node executors — `tk.Toplevel()` from a worker thread
        # raises "main thread is not in main loop" on Python 3.11+.
        # Solution: run the executor on the MAIN thread (the F5 keypress
        # already lives there). The UI freezes for the run duration,
        # which is fine for a typical graph (Donut3D builds in ~100 ms).
        # Event-driven follow-ups (ui_button clicks) already run on the
        # main thread, so nothing else needs to change.
        _con_write("", "sys")
        _running[0] = True
        _pulse_t[0] = 0.0
        win.after(40, _pulse_tick)

        def _do_on_main():
            try:
                ex = _Executor(
                    list(_nodes), list(_wires),
                    _con_write,
                    _glow_node,
                )
                ex.run()
            except Exception as _ex:
                _con_write(f"❌  Executor crashed: {_ex}", "err")
                import traceback as _tb
                _con_write(_tb.format_exc(), "err")
            finally:
                _running[0] = False
        # Defer one tick so the "Running..." message paints first.
        win.after(20, _do_on_main)

    # ── Keyboard shortcuts ─────────────────────────────────────────────────
    win.bind("<Control-s>", lambda e: _save())
    win.bind("<Control-o>", lambda e: _load())
    win.bind("<Control-z>", lambda e: _undo_pop())
    win.bind("<Control-y>", lambda e: _redo_pop())
    win.bind("<Control-Shift-Z>", lambda e: _redo_pop())
    # Multi-select shortcuts
    def _select_all(_=None):
        _multi_sel.clear()
        _multi_sel.update(n["id"] for n in _nodes)
        if _nodes: _sel[0] = _nodes[0]["id"]
        _draw_all()
        _con_write(f"  📦  Selected all {len(_multi_sel)} nodes", "sys")
    win.bind("<Control-a>", _select_all)
    win.bind("<Control-A>", _select_all)
    win.bind("<F5>",        lambda e: _run())
    def _del_selected(_=None):
        # If multi-select active, delete ALL; else just primary
        targets = list(_multi_sel) if _multi_sel else (
                  [_sel[0]] if _sel[0] else [])
        if not targets: return
        _push_undo()
        for nid in targets:
            n = next((x for x in _nodes if x["id"] == nid), None)
            if n:
                _nodes.remove(n)
                _wires[:] = [w for w in _wires
                             if w["fn"] != nid and w["tn"] != nid]
        _multi_sel.clear(); _sel[0] = None
        _node_errors.clear()
        _draw_all()
        _con_write(f"  🗑  Deleted {len(targets)} node(s)", "sys")
    # Delete must also be guarded — it removes characters in Entry widgets
    def _del_guard(e):
        f = win.focus_get() if win.winfo_exists() else None
        if isinstance(f, (tk.Entry, tk.Text, tk.Spinbox)):
            return   # let Delete remove characters
        _del_selected(e)
    win.bind("<Delete>", _del_guard)
    win.bind("<Escape>",    lambda e: (_wire_src.__setitem__(0,None),
                                       _multi_sel.clear(),
                                       _box_sel.update(active=False),
                                       cv.delete("tmp_wire"),
                                       cv.delete("box_sel"),
                                       _draw_all(), None))
    # ── Shortcut guard ────────────────────────────────────────────────
    # Single-key shortcuts must NEVER fire while typing in an Entry/Text,
    # otherwise letters get swallowed (e.g. "f" → fit-all instead of being
    # typed into the AI prompt bar). This wrapper skips the handler when
    # focus is on a text input widget.
    def _guard(handler):
        def _wrapped(e):
            try:
                f = win.focus_get()
                if isinstance(f, (tk.Entry, tk.Text, tk.Spinbox)):
                    return  # let the key go to the input
            except Exception:
                pass
            return handler(e)
        return _wrapped

    # Scalable canvas shortcuts — only when canvas has focus
    win.bind("<Key-f>",     _guard(lambda e: _fit_all()))
    win.bind("<Key-c>",     _guard(lambda e: _center_view()))
    win.bind("<Key-m>",     _guard(lambda e: _toggle_minimap()))
    # Ctrl+F → focus the Add-menu search (modifier shortcuts are safe to
    # fire globally since they don't conflict with normal typing)
    win.bind("<Control-f>", lambda e: _show_add_menu(None, None))
    # Spacebar — quick-add at cursor (only when not typing)
    def _space_quick_add(e=None):
        cx_ = cv.winfo_pointerx() - cv.winfo_rootx()
        cy_ = cv.winfo_pointery() - cv.winfo_rooty()
        cw = cv.winfo_width(); ch = cv.winfo_height()
        if not (0 <= cx_ <= cw and 0 <= cy_ <= ch):
            cx_, cy_ = cw // 2, ch // 2
        _show_quick_add(cx_, cy_)
    win.bind("<space>", _guard(_space_quick_add))
    win.focus_set()

    # ── Boot with a Start node ─────────────────────────────────────────────
    _nodes.append({"id":"start_0","type":"start","x":80,"y":120,"params":{}})
    _draw_all()
    _con_write("⬡  NodeBase v1.0 ready.", "sys")
    _con_write("   Double-click canvas to add nodes. F5 to run.", "sys")
