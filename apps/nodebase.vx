# VX:name=NodeBase
# VX:icon=⬡
# VX:net=full
# VX:sig=rqXJT1M2msk7FzOVYxAAFW3R3cLrlj/OXKYU9EyhU2tzIcgKdhSM6O1fRm0p6Paq85kMknWt71xRTvHYRlCLAg==
"""
╔══════════════════════════════════════════════════════════════════════╗
║  NodeBase v1.0  —  Visual Scripting Language for Luci / VX          ║
║  A low-overhead, node-based programming environment                  ║
║  Resource footprint: lighter than Notepad on idle canvas             ║
╠══════════════════════════════════════════════════════════════════════╣
║                                                                      ║
║  DOCUMENTATION                                                       ║
║  ═══════════                                                         ║
║                                                                      ║
║  WHAT IS NODEBASE?                                                   ║
║  NodeBase is a visual dataflow scripting language. Instead of        ║
║  writing code line-by-line, you connect functional blocks called     ║
║  "nodes" using wires. Data flows left-to-right through ports.        ║
║  Control flow moves top-to-bottom via orange "flow" wires.           ║
║                                                                      ║
║  CANVAS CONTROLS                                                     ║
║  ───────────────                                                     ║
║  Middle-drag / Alt+drag  Pan the canvas                              ║
║  Scroll wheel            Zoom in / out (0.3x – 3x)                  ║
║  Double-click canvas     Open add-node menu                          ║
║  Click node              Select (highlight)                          ║
║  Drag node title         Move node                                   ║
║  Right-click node        Delete / Duplicate                          ║
║  Click output port ●     Begin wire                                  ║
║  Release on input port   Connect wire                                ║
║  Right-click wire        Delete wire                                 ║
║  Ctrl+S                  Save graph                                  ║
║  Ctrl+O                  Load graph                                  ║
║  Ctrl+Z                  Undo last action                            ║
║  F5 / Run button         Execute graph                               ║
║  Escape                  Cancel wire drag / deselect                 ║
║                                                                      ║
║  PORT TYPES & COLORS                                                 ║
║  ───────────────────                                                 ║
║  ● Orange  flow    Control flow — sequencing between nodes           ║
║  ● Cyan    string  Text data                                         ║
║  ● Yellow  number  Integer or float                                  ║
║  ● Green   bool    True / False                                      ║
║  ● Purple  list    Array / iterable                                  ║
║  ● Red     file    File path                                         ║
║  ● Gray    any     Accepts any type                                  ║
║                                                                      ║
║  NODE CATEGORIES                                                     ║
║  ───────────────                                                     ║
║  FLOW     Start, End, If, For Each, Set Var, Get Var, Delay          ║
║  VALUE    String, Number, Boolean, Make List                         ║
║  MATH     Math Op, Compare, Clamp, Random                            ║
║  STRING   Concat, String Op, Split, Format                           ║
║  IO       Print, File Read, File Write, Input                        ║
║  AI       Ask VinX, Summarize, Generate                              ║
║  SYSTEM   Run Command, Open App, HTTP Get                            ║
║  UTIL     Note, Type Convert, Length, Index                          ║
║                                                                      ║
║  EXECUTION MODEL                                                     ║
║  ───────────────                                                     ║
║  1. Execution starts at the [Start] node                             ║
║  2. Flow wires (orange) determine sequence                           ║
║  3. Before a node runs, its data inputs are resolved recursively     ║
║  4. Node outputs are cached — reused if wired to multiple targets    ║
║  5. If/branch splits flow; For Each loops until list exhausted       ║
║  6. [End] node terminates execution                                  ║
║                                                                      ║
║  GRAPH FILE FORMAT (.nbg)                                            ║
║  ─────────────────────────                                           ║
║  JSON with two keys:                                                 ║
║    "nodes": list of node objects                                     ║
║    "wires": list of {from_node, from_port, to_node, to_port}         ║
║  Saved to: Luci/Vinx-Desktop/.user/graphs/                          ║
║                                                                      ║
║  BUILT-IN VARIABLES                                                  ║
║  ──────────────────                                                  ║
║  $desktop_path   Path to Luci desktop folder                         ║
║  $home           User home directory                                 ║
║  $os             Operating system name                               ║
║  $time           Current timestamp string                            ║
║                                                                      ║
╚══════════════════════════════════════════════════════════════════════╝
"""

import os, sys, json, math, time, threading, subprocess, uuid
import tkinter as tk
from tkinter import filedialog, simpledialog, messagebox

# ── VinX bridge — make vinx_local importable ─────────────────────────
# vinx_local.py lives in /usr/local/luci/Vinx-AI, NOT in programfiles
# (so the AI model state lives next to its weights instead of next to
# the .vx file). Without this sys.path injection every `import
# vinx_local` below would raise ModuleNotFoundError and the AI Ask /
# AI Summarize nodes would silently report "VinX unavailable".
_VINX_AI_DIR = "/usr/local/luci/Vinx-AI"
if os.path.isdir(_VINX_AI_DIR) and _VINX_AI_DIR not in sys.path:
    sys.path.insert(0, _VINX_AI_DIR)

# ── Graph directory ─────────────────────────────────────────────────
# Graphs are USER CONTENT — they belong under ~/Documents/, where
# the user can see them in the File Manager. NOT under .config/
# (that's for app prefs only, and Cosmic Guard restricts access).
# ROOT_DIR is also imported because other parts of nodebase.vx use it.
try:
    from luci import DOC_DIR, ROOT_DIR
    _GRAPH_DIR = os.path.join(DOC_DIR, "NodeBase")
except ImportError:
    ROOT_DIR   = os.path.expanduser("~")
    _GRAPH_DIR = os.path.join(ROOT_DIR, "Documents", "NodeBase")

os.makedirs(_GRAPH_DIR, exist_ok=True)

# nodebase_ai.py lives in the VinX-AI folder. The old "two
# directories above ROOT_DIR" heuristic broke on Luci OS — after the
# Unix-standard migration ROOT_DIR is /home/luci, so the heuristic
# resolved to "/" and the import silently failed (the "no module"
# error the user keeps hitting in NodeBase Settings). Probe a list
# of plausible install locations instead.
_AI_CANDIDATES = [
    "/usr/local/luci/Vinx-AI",                        # FreeBSD install
    os.path.dirname(os.path.dirname(ROOT_DIR)),       # legacy Windows
    os.path.join(os.path.dirname(__file__), "..", "..", "..", "Vinx-AI"),
]
for _d in _AI_CANDIDATES:
    if _d and os.path.isfile(os.path.join(_d, "nodebase_ai.py")):
        if _d not in sys.path:
            sys.path.insert(0, _d)
        break
try:
    import nodebase_ai as _nai
    _HAS_AI = True
except ImportError:
    _nai = None
    _HAS_AI = False

