    # ── PRO LOGIC NODES ───────────────────────────────────────────────────────
    "function":    {"label":"ƒ  Function",       "cat":"logic",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"a","t":"any"},
                              {"n":"b","t":"any"},{"n":"c","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"result","t":"any"}],
                    "params":[{"n":"name","t":"string","d":"my_func"},
                              {"n":"body","t":"string","d":"return a + b"}]},
