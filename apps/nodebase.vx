                    "outputs":[{"n":"flow","t":"flow"}],
                    "params":[{"n":"name","t":"string","d":"my_signal"}]},
    "async_node":  {"label":"⟳  Async",          "cat":"logic",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"task","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"result","t":"any"}],
                    "params":[]},
    "try_catch":   {"label":"⚠  Try/Catch",      "cat":"logic",
                    "inputs":[{"n":"flow","t":"flow"}],
                    "outputs":[{"n":"try","t":"flow"},{"n":"catch","t":"flow"},
                               {"n":"error","t":"string"}],
                    "params":[]},
    "loop_break":  {"label":"⊗  Loop Break",     "cat":"logic",
                    "inputs":[{"n":"flow","t":"flow"}],
                    "outputs":[],
                    "params":[]},
    "map_node":    {"label":"⤳  Map",            "cat":"logic",  # ✓ works
                    "inputs":[{"n":"flow","t":"flow"},{"n":"list","t":"list"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"result","t":"list"}],
                    "params":[{"n":"expr","t":"string","d":"x * 2"}]},
    "filter_node": {"label":"⊽  Filter",         "cat":"logic",  # ✓ works
                    "inputs":[{"n":"flow","t":"flow"},{"n":"list","t":"list"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"result","t":"list"}],
                    "params":[{"n":"expr","t":"string","d":"x > 0"}]},
    "reduce_node": {"label":"Σ  Reduce",         "cat":"logic",  # ✓ works
                    "inputs":[{"n":"flow","t":"flow"},{"n":"list","t":"list"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"result","t":"any"}],
                    "params":[{"n":"expr","t":"string","d":"acc + x"},
                              {"n":"start","t":"string","d":"0"}]},
    "switch":      {"label":"⊟  Switch",         "cat":"logic",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"value","t":"any"}],
                    "outputs":[{"n":"case_a","t":"flow"},{"n":"case_b","t":"flow"},
                               {"n":"case_c","t":"flow"},{"n":"default","t":"flow"}],
                    "params":[{"n":"a","t":"string","d":""},
                              {"n":"b","t":"string","d":""},
                              {"n":"c","t":"string","d":""}]},
    "router":      {"label":"⤧  Router",         "cat":"logic",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"key","t":"string"}],
                    "outputs":[{"n":"out_a","t":"flow"},{"n":"out_b","t":"flow"}],
                    "params":[{"n":"a","t":"string","d":""},
                              {"n":"b","t":"string","d":""}]},
    "cache":       {"label":"⛁  Cache",          "cat":"logic",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"key","t":"string"},
                              {"n":"value","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"value","t":"any"}],
                    "params":[]},
    "database":    {"label":"⛃  Database",       "cat":"logic",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"query","t":"string"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"rows","t":"list"}],
                    "params":[{"n":"db","t":"string","d":"app.db"}]},
    "history":     {"label":"⏲  History",        "cat":"logic",
                    "inputs":[{"n":"flow","t":"flow"}],
                    "outputs":[{"n":"flow","t":"flow"}],
                    "params":[]},

    # ── FILE / APP SYSTEM ────────────────────────────────────────────────────
    "asset":       {"label":"📎  Asset",         "cat":"app",  # ✓ works
                    "inputs":[{"n":"flow","t":"flow"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"path","t":"string"}],
                    "params":[{"n":"path","t":"string","d":"assets/my.png"}]},
    "asset_brws":  {"label":"📂  Asset Browser", "cat":"app",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"window","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"selected","t":"string"}],
                    "params":[]},
    "import_ast":  {"label":"⮕  Import Asset",   "cat":"app",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"src","t":"string"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"path","t":"string"}],
                    "params":[]},
    "export_app":  {"label":"📦  Export App",    "cat":"app",  # ✓ works
                    "inputs":[{"n":"flow","t":"flow"},{"n":"name","t":"string"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"path","t":"string"}],
                    "params":[{"n":"icon","t":"string","d":"📦"}]},
    "install_app": {"label":"⤓  Install App",    "cat":"app",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"path","t":"string"}],
                    "outputs":[{"n":"flow","t":"flow"}],
                    "params":[]},
    "manifest":    {"label":"≡  App Manifest",   "cat":"app",
                    "inputs":[{"n":"flow","t":"flow"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"manifest","t":"any"}],
                    "params":[{"n":"name","t":"string","d":"My App"},
                              {"n":"version","t":"string","d":"1.0"}]},
    "perms":       {"label":"🔒  Permissions",   "cat":"app",
                    "inputs":[{"n":"flow","t":"flow"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"perms","t":"list"}],
                    "params":[{"n":"file","t":"choice",
                               "choices":["yes","no"],"d":"yes"},
                              {"n":"network","t":"choice",
                               "choices":["yes","no"],"d":"no"}]},
    "save_state":  {"label":"💾  Save State",    "cat":"app",  # ✓ works
                    "inputs":[{"n":"flow","t":"flow"},{"n":"data","t":"any"},
                              {"n":"key","t":"string"}],
                    "outputs":[{"n":"flow","t":"flow"}],
                    "params":[]},
    "load_state":  {"label":"📂  Load State",    "cat":"app",  # ✓ works
                    "inputs":[{"n":"flow","t":"flow"},{"n":"key","t":"string"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"data","t":"any"}],
                    "params":[]},
    "plugin":      {"label":"🔌  Plugin",        "cat":"app",  # ✓ works
                    "inputs":[{"n":"flow","t":"flow"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"module","t":"any"}],
                    "params":[{"n":"name","t":"string","d":"math"}]},

    # ── GPU / SHADER NODES ────────────────────────────────────────────────────
    "shader":      {"label":"⌬  Shader",         "cat":"gpu",
                    "inputs":[{"n":"flow","t":"flow"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"shader","t":"any"}],
                    "params":[{"n":"type","t":"choice",
                               "choices":["vertex","fragment","compute"],
                               "d":"fragment"}]},
    "frag_shader": {"label":"▣  Fragment Shader","cat":"gpu",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"code","t":"string"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"shader","t":"any"}],
                    "params":[]},
    "vert_shader": {"label":"◇  Vertex Shader",  "cat":"gpu",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"code","t":"string"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"shader","t":"any"}],
                    "params":[]},
    "tex_buffer":  {"label":"⛁  Texture Buffer", "cat":"gpu",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"image","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"buffer","t":"any"}],
                    "params":[]},
    "compute":     {"label":"⚙  Compute Pass",   "cat":"gpu",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"shader","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"result","t":"any"}],
                    "params":[{"n":"groups","t":"number","d":64}]},
    "render_tgt":  {"label":"⊟  Render Target",  "cat":"gpu",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"w","t":"number"},
                              {"n":"h","t":"number"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"target","t":"any"}],
                    "params":[]},
    "post_proc":   {"label":"⌬  Post Process",   "cat":"gpu",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"image","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"image","t":"any"}],
                    "params":[{"n":"effect","t":"choice",
                               "choices":["bloom","ssao","fxaa","tonemap","vignette"],
                               "d":"bloom"}]},
    "noise_gen":   {"label":"≈  Noise",          "cat":"gpu",  # ✓ works
                    "inputs":[{"n":"flow","t":"flow"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"value","t":"number"}],
                    "params":[{"n":"type","t":"choice",
                               "choices":["white","perlin","simplex","worley"],
                               "d":"white"},
                              {"n":"seed","t":"number","d":42}]},
    "displace":    {"label":"⤢  Displacement",   "cat":"gpu",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"image","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"image","t":"any"}],
                    "params":[{"n":"strength","t":"number","d":1.0}]},

    # ╔══════════════════════════════════════════════════════════════════╗
    # ║  3D SUBSYSTEM — viewport, primitives, particles, Luna renderer   ║
    # ║  Inspired by Blender's bpy + Houdini SOPs + Cycles render API.   ║
    # ║  Software-rendered: no GPU/OpenGL deps. PIL-backed for portability.║
    # ╚══════════════════════════════════════════════════════════════════╝

    # Viewport — opens a Tk window with a Canvas that hosts the 3D scene.
    "viewport_3d": {"label":"◆  3D Viewport",     "cat":"3d",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"window","t":"any"},
                              {"n":"w","t":"number"},{"n":"h","t":"number"}],
                    "outputs":[{"n":"flow","t":"flow"},
                               {"n":"viewport","t":"any"},
                               {"n":"scene","t":"any"}],
                    "params":[{"n":"bg","t":"string","d":"#0a0a18"},
                              {"n":"fov","t":"number","d":50}]},

    # Primitives — adapted from Blender's bpy.ops.mesh.primitive_*_add
    "prim_cube":   {"label":"◇  Cube",            "cat":"3d",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"scene","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"mesh","t":"any"}],
                    "params":[{"n":"size","t":"number","d":1.0},
                              {"n":"x","t":"number","d":0},
                              {"n":"y","t":"number","d":0},
                              {"n":"z","t":"number","d":0}]},
    "prim_sphere": {"label":"○  Sphere",          "cat":"3d",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"scene","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"mesh","t":"any"}],
                    "params":[{"n":"radius","t":"number","d":1.0},
                              {"n":"segments","t":"number","d":16},
                              {"n":"x","t":"number","d":0},
                              {"n":"y","t":"number","d":0},
                              {"n":"z","t":"number","d":0}]},
    "prim_plane":  {"label":"▭  Plane",           "cat":"3d",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"scene","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"mesh","t":"any"}],
                    "params":[{"n":"size","t":"number","d":2.0}]},
    "prim_cyl":    {"label":"⊜  Cylinder",        "cat":"3d",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"scene","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"mesh","t":"any"}],
                    "params":[{"n":"radius","t":"number","d":1.0},
                              {"n":"height","t":"number","d":2.0},
                              {"n":"segments","t":"number","d":16}]},
    "prim_torus":  {"label":"◯  Torus",           "cat":"3d",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"scene","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"mesh","t":"any"}],
                    "params":[{"n":"major","t":"number","d":1.0},
                              {"n":"minor","t":"number","d":0.3}]},
    "prim_cone":   {"label":"△  Cone",            "cat":"3d",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"scene","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"mesh","t":"any"}],
                    "params":[{"n":"radius","t":"number","d":1.0},
                              {"n":"height","t":"number","d":2.0}]},
    "prim_grid":   {"label":"⊞  Grid",            "cat":"3d",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"scene","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"mesh","t":"any"}],
                    "params":[{"n":"x_subdiv","t":"number","d":10},
                              {"n":"y_subdiv","t":"number","d":10},
                              {"n":"size","t":"number","d":4.0}]},
    "floor_grid":  {"label":"▦  Floor + Grid",   "cat":"3d",   # ✓ works
                    "inputs":[{"n":"flow","t":"flow"},{"n":"scene","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"floor","t":"any"}],
                    "params":[{"n":"size","t":"number","d":10},
                              {"n":"divisions","t":"number","d":20},
                              {"n":"y","t":"number","d":-1.0},
                              {"n":"color","t":"string","d":"#2a3a55"}]},
    "light_omni":  {"label":"💡  Omni Light",     "cat":"3d",   # ✓ works
                    "inputs":[{"n":"flow","t":"flow"},{"n":"scene","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"light","t":"any"}],
                    "params":[{"n":"x","t":"number","d":3},
                              {"n":"y","t":"number","d":4},
                              {"n":"z","t":"number","d":3},
                              {"n":"intensity","t":"number","d":1.0},
                              {"n":"color","t":"string","d":"#ffffff"}]},
    "light_sun":   {"label":"☀  Sun Light",       "cat":"3d",   # ✓ works
                    "inputs":[{"n":"flow","t":"flow"},{"n":"scene","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"light","t":"any"}],
                    "params":[{"n":"dir_x","t":"number","d":-0.5},
                              {"n":"dir_y","t":"number","d":-1.0},
                              {"n":"dir_z","t":"number","d":-0.3},
                              {"n":"intensity","t":"number","d":1.0},
                              {"n":"color","t":"string","d":"#fff8dd"}]},
    "light_spot":  {"label":"🔦  Spot Light",     "cat":"3d",   # ✓ works
                    "inputs":[{"n":"flow","t":"flow"},{"n":"scene","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"light","t":"any"}],
                    "params":[{"n":"x","t":"number","d":0},
                              {"n":"y","t":"number","d":5},
                              {"n":"z","t":"number","d":0},
                              {"n":"angle","t":"number","d":45},
                              {"n":"intensity","t":"number","d":1.5},
                              {"n":"color","t":"string","d":"#ffffff"}]},
    "light_area":  {"label":"▱  Area Light",      "cat":"3d",   # ✓ works
                    "inputs":[{"n":"flow","t":"flow"},{"n":"scene","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"light","t":"any"}],
                    "params":[{"n":"x","t":"number","d":2},
                              {"n":"y","t":"number","d":3},
                              {"n":"z","t":"number","d":0},
                              {"n":"size","t":"number","d":2.0},
                              {"n":"intensity","t":"number","d":2.0},
                              {"n":"color","t":"string","d":"#ffffff"}]},
    "object_mgr":  {"label":"⊞  Object Manager",  "cat":"3d",   # ✓ works
                    "inputs":[{"n":"flow","t":"flow"},{"n":"window","t":"any"},
                              {"n":"scene","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"}],
                    "params":[]},
    "set_mode":    {"label":"⌬  Viewport Mode",   "cat":"3d",   # ✓ works
                    "inputs":[{"n":"flow","t":"flow"},{"n":"scene","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"}],
                    "params":[{"n":"mode","t":"choice",
                               "choices":["wireframe","shaded","rendered"],
                               "d":"wireframe"}]},
    "shadow_settings":{"label":"🌑  Shadow Settings","cat":"3d", # ✓ works
                    "inputs":[{"n":"flow","t":"flow"},{"n":"scene","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"}],
                    "params":[{"n":"enable","t":"choice",
                               "choices":["on","off"],"d":"on"},
                              {"n":"darkness","t":"number","d":0.45},
                              {"n":"softness","t":"number","d":0.0}]},
    "light_handles":{"label":"💡  Light Handles","cat":"3d", # ✓ works
                    "inputs":[{"n":"flow","t":"flow"},{"n":"scene","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"}],
                    "params":[{"n":"show","t":"choice",
                               "choices":["on","off"],"d":"on"},
                              {"n":"size","t":"number","d":0.3}]},
    "camera_mode": {"label":"📷  Camera Mode","cat":"3d",   # ✓ works
                    "inputs":[{"n":"flow","t":"flow"},{"n":"scene","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"}],
                    "params":[{"n":"mode","t":"choice",
                               "choices":["view","edit"],"d":"view"}]},
    "pos":         {"label":"⤢  Position",       "cat":"3d",   # ✓ works
                    "inputs":[{"n":"flow","t":"flow"},{"n":"target","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"target","t":"any"}],
                    "params":[{"n":"x","t":"number","d":0},
                              {"n":"y","t":"number","d":0},
                              {"n":"z","t":"number","d":0}]},
    "rotation":    {"label":"↻  Rotation",       "cat":"3d",   # ✓ works
                    "inputs":[{"n":"flow","t":"flow"},{"n":"target","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"target","t":"any"}],
                    "params":[{"n":"rx","t":"number","d":0},
                              {"n":"ry","t":"number","d":0},
                              {"n":"rz","t":"number","d":0}]},
    "scale":       {"label":"⤡  Scale",          "cat":"3d",   # ✓ works
                    "inputs":[{"n":"flow","t":"flow"},{"n":"target","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"target","t":"any"}],
                    "params":[{"n":"sx","t":"number","d":1.0},
                              {"n":"sy","t":"number","d":1.0},
                              {"n":"sz","t":"number","d":1.0}]},
    "gizmo_mode":  {"label":"⛓  Gizmo Mode",     "cat":"3d",   # ✓ works
                    "inputs":[{"n":"flow","t":"flow"},{"n":"scene","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"}],
                    "params":[{"n":"mode","t":"choice",
                               "choices":["translate","rotate","scale"],
                               "d":"translate"}]},

    # Particle systems — fire/smoke/water/dust
    "pt_emit_3d":  {"label":"✦  3D Emitter",      "cat":"3d",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"scene","t":"any"},
                              {"n":"x","t":"number"},{"n":"y","t":"number"},
                              {"n":"z","t":"number"}],
                    "outputs":[{"n":"flow","t":"flow"},
                               {"n":"particles","t":"any"}],
                    "params":[{"n":"count","t":"number","d":500},
                              {"n":"rate","t":"number","d":60},
                              {"n":"life","t":"number","d":2.0}]},
    "pt_fire":     {"label":"🔥  Fire",           "cat":"3d",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"emitter","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"sim","t":"any"}],
                    "params":[{"n":"intensity","t":"number","d":1.0},
                              {"n":"buoyancy","t":"number","d":1.5},
                              {"n":"color_hot","t":"string","d":"#ffeebb"},
                              {"n":"color_cool","t":"string","d":"#ff4400"}]},
    "pt_smoke":    {"label":"💨  Smoke",          "cat":"3d",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"emitter","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"sim","t":"any"}],
                    "params":[{"n":"density","t":"number","d":0.6},
                              {"n":"dissipate","t":"number","d":0.04}]},
    "pt_water":    {"label":"💧  Water",          "cat":"3d",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"emitter","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"sim","t":"any"}],
                    "params":[{"n":"viscosity","t":"number","d":0.05},
                              {"n":"surface_tension","t":"number","d":0.7}]},
    "pt_dust":     {"label":"·  Dust",            "cat":"3d",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"emitter","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"sim","t":"any"}],
                    "params":[{"n":"size","t":"number","d":0.05}]},
    "pt_force":    {"label":"➤  3D Force",        "cat":"3d",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"sim","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"}],
                    "params":[{"n":"type","t":"choice",
                               "choices":["gravity","wind","turbulence","vortex","attractor"],
                               "d":"gravity"},
                              {"n":"strength","t":"number","d":1.0}]},

    # ── LUNA RENDERER — custom path-tracing-inspired renderer ─────────────
    # "Luna" because: lunar/light-bouncing concept. Pure Python, software,
    # adapted from Cycles BVH ideas + Blender's render passes design.
    "luna_render": {"label":"☾  Luna Render",     "cat":"3d",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"scene","t":"any"},
                              {"n":"camera","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"image","t":"any"}],
                    "params":[{"n":"w","t":"number","d":640},
                              {"n":"h","t":"number","d":480},
                              {"n":"samples","t":"number","d":4},
                              {"n":"bounces","t":"number","d":2},
                              {"n":"mode","t":"choice",
                               "choices":["wireframe","flat","gouraud","raytrace","pathtrace"],
                               "d":"flat"}]},
    "luna_pass":   {"label":"☼  Render Pass",     "cat":"3d",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"render","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"image","t":"any"}],
                    "params":[{"n":"pass","t":"choice",
                               "choices":["beauty","depth","normal","albedo",
                                          "shadow","reflection","specular","ao",
                                          "emission","mist","cryptomatte"],
                               "d":"beauty"}]},
    "luna_denoise":{"label":"⌬  Denoise",         "cat":"3d",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"image","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"image","t":"any"}],
                    "params":[{"n":"strength","t":"number","d":0.5}]},
    "luna_compose":{"label":"⊞  Compose",         "cat":"3d",
                    "inputs":[{"n":"flow","t":"flow"},
                              {"n":"a","t":"any"},{"n":"b","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"image","t":"any"}],
                    "params":[{"n":"op","t":"choice",
                               "choices":["over","add","multiply","screen","mix"],
                               "d":"over"}]},

    # 3D scene operations (transforms, modifiers — Blender-inspired)
    "mod_subdiv":  {"label":"⊞  Subdivide",       "cat":"3d",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"mesh","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"mesh","t":"any"}],
                    "params":[{"n":"levels","t":"number","d":2}]},
    "mod_array":   {"label":"⏍  Array",           "cat":"3d",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"mesh","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"mesh","t":"any"}],
                    "params":[{"n":"count","t":"number","d":4},
                              {"n":"offset_x","t":"number","d":2.0}]},
    "mod_mirror":  {"label":"⇆  Mirror",          "cat":"3d",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"mesh","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"mesh","t":"any"}],
                    "params":[{"n":"axis","t":"choice",
                               "choices":["x","y","z"],"d":"x"}]},
    "mod_bevel":   {"label":"◎  Bevel",           "cat":"3d",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"mesh","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"mesh","t":"any"}],
                    "params":[{"n":"width","t":"number","d":0.1},
                              {"n":"segments","t":"number","d":2}]},
    "transform":   {"label":"⤢  Transform",       "cat":"3d",
                    "inputs":[{"n":"flow","t":"flow"},{"n":"mesh","t":"any"}],
                    "outputs":[{"n":"flow","t":"flow"},{"n":"mesh","t":"any"}],
                    "params":[{"n":"px","t":"number","d":0},
                              {"n":"py","t":"number","d":0},
                              {"n":"pz","t":"number","d":0},
                              {"n":"rx","t":"number","d":0},
                              {"n":"ry","t":"number","d":0},
                              {"n":"rz","t":"number","d":0},
                              {"n":"sx","t":"number","d":1},
                              {"n":"sy","t":"number","d":1},
                              {"n":"sz","t":"number","d":1}]},
})

